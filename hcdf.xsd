<?xml version="1.0" encoding="UTF-8"?>
<!--
  HCDF (Hardware Configuration Descriptive Format) XML Schema Definition
  Version: 1.0

  HCDF describes cyber-physical robotic systems: physical structure (kinematics,
  sensors, actuators, geometry) and cyber infrastructure (networking, TSN, MACsec,
  firmware, device discovery, connectivity topology).

  Copyright (c) 2026 CogniPilot Foundation
  Licensed under Apache-2.0

  Semantic constraints not expressible in XSD 1.0 (enforced by tooling):
    - Revolute/prismatic joints require axis + limit; fixed joints forbid them
    - speed-tx/speed-rx mutually exclusive with speed on ports
    - T1 links: one PHY master, one PHY slave per link
    - Schedule gate durations must sum to cycle-time-us
    - Chain hop port references must match device port definitions
    - EtherCAT FMMU offset+size ranges must not overlap
    - Mimic joint references must name an existing joint
    - All files in an include chain must use the same body-frame and world-frame

  IMPORTANT: Do NOT use xs:choice with minOccurs="0" maxOccurs="unbounded".
  This causes exponential backtracking in libxml2 (xmllint hangs).
  Use xs:sequence with per-element cardinality instead.
  Validate with Python lxml (validate.py), never xmllint.
-->
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           version="1.0"
           elementFormDefault="unqualified">

  <!-- ================================================================ -->
  <!-- SIMPLE TYPES (Enumerations)                                     -->
  <!-- ================================================================ -->

  <xs:simpleType name="BodyFrame">
    <xs:annotation><xs:documentation>Body-frame axis convention describing how the robot's local coordinate axes are oriented relative to its physical body. The three-letter code specifies the direction each axis points: first letter = X, second = Y, third = Z. F=Forward, B=Back, L=Left, R=Right, U=Up, D=Down. FLU (X-forward, Y-left, Z-up): common in ground robotics, humanoids, and wheeled platforms. Positive X faces the direction the robot drives or walks. FRD (X-forward, Y-right, Z-down): common in aerospace, aviation, and flight controllers. Matches the aircraft body-frame convention where Z points toward the ground. Choosing a convention affects how all pose xyz and rpy values in the document are interpreted. Semantic rule for composition: all files in an include chain must use the same body-frame convention. Tooling should validate this at include-resolve time.</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="FLU"/>
      <xs:enumeration value="FRD"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="WorldFrame">
    <xs:annotation><xs:documentation>World-frame (navigation frame) axis convention describing how global/map coordinate axes are oriented. ENU (X-east, Y-north, Z-up): common in geographic information systems, ground robotics, and surveying. Z-up aligns with gravity opposition, making vertical reasoning intuitive. NED (X-north, Y-east, Z-down): common in aerospace, aviation, marine navigation, and most inertial navigation systems. Z-down aligns with gravity direction, matching accelerometer sign conventions in flight controllers. The world-frame convention determines how global poses, waypoints, and map coordinates are interpreted. Independent of body-frame: a ground robot may use body-frame=FLU with world-frame=ENU, while a drone may use body-frame=FRD with world-frame=NED. Semantic rule for composition: all files in an include chain must use the same world-frame convention.</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="ENU"/>
      <xs:enumeration value="NED"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="JointType">
    <xs:annotation><xs:documentation>Enumeration of kinematic joint types. revolute: bounded single-axis rotation. continuous: unbounded single-axis rotation. prismatic: bounded linear translation. fixed: rigid (zero DOF). ball: 3-DOF spherical. universal: 2-DOF (requires axis + axis2). planar: 2-DOF translation on a plane. screw: helical (requires thread_pitch).</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="revolute"/>
      <xs:enumeration value="continuous"/>
      <xs:enumeration value="prismatic"/>
      <xs:enumeration value="fixed"/>
      <xs:enumeration value="ball"/>
      <xs:enumeration value="universal"/>
      <xs:enumeration value="planar"/>
      <xs:enumeration value="screw"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="MotorType">
    <xs:annotation><xs:documentation>Motor or actuator technology type. bldc: brushless DC motor. brushed: brushed DC motor. stepper: stepper motor. servo: hobby/industrial servo. linear: linear actuator. hydraulic: hydraulic actuator. pneumatic: pneumatic actuator. thrust: thrust motor (propeller, jet, rocket). ice: internal combustion engine (gasoline, diesel — for generators or direct mechanical drive).</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="bldc"/>
      <xs:enumeration value="brushed"/>
      <xs:enumeration value="stepper"/>
      <xs:enumeration value="servo"/>
      <xs:enumeration value="linear"/>
      <xs:enumeration value="hydraulic"/>
      <xs:enumeration value="pneumatic"/>
      <xs:enumeration value="thrust"/>
      <xs:enumeration value="ice"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="PortType">
    <xs:annotation><xs:documentation>Physical wired port interface type. Includes data buses, camera/sensor serial links, debug interfaces, general-purpose signal connectors, and power. SIGNAL is for mixed-signal connectors carrying any combination of analog/digital IO, encoder, Hall, thermistor, etc. — use when the connector doesn't fit a standard bus type. Camera interfaces (MIPI-CSI, GMSL2, ASA-ML, FPD-Link, CoaXPress) are local to the SoC and do NOT traverse the TSN network.</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <!-- Data buses -->
      <xs:enumeration value="ethernet"/>
      <xs:enumeration value="SPI"/>
      <xs:enumeration value="I2C"/>
      <xs:enumeration value="UART"/>
      <xs:enumeration value="CAN"/>
      <xs:enumeration value="USB"/>
      <!-- Camera/sensor serial interfaces (local, not on TSN network) -->
      <xs:enumeration value="MIPI-CSI"/>
      <xs:enumeration value="GMSL"/>
      <xs:enumeration value="GMSL2"/>
      <xs:enumeration value="ASA-ML"/>
      <xs:enumeration value="FPD-Link"/>
      <xs:enumeration value="CoaXPress"/>
      <!-- Debug -->
      <xs:enumeration value="JTAG"/>
      <xs:enumeration value="SWD"/>
      <!-- General-purpose -->
      <xs:enumeration value="SIGNAL"/>
      <!-- Other -->
      <xs:enumeration value="POWER"/>
      <xs:enumeration value="CARD"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="AntennaType">
    <xs:annotation><xs:documentation>Wireless antenna technology type. wifi: IEEE 802.11 (any band). bluetooth: Bluetooth Classic or BLE. lora: LoRa/LoRaWAN. cellular: 4G/5G cellular. uwb: Ultra-Wideband (IEEE 802.15.4z). gnss: GNSS reception (GPS, Galileo, GLONASS, BeiDou). NFC: Near Field Communication. 802.15.4: IEEE 802.15.4 (Zigbee, Thread).</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="wifi"/>
      <xs:enumeration value="bluetooth"/>
      <xs:enumeration value="lora"/>
      <xs:enumeration value="cellular"/>
      <xs:enumeration value="uwb"/>
      <xs:enumeration value="gnss"/>
      <xs:enumeration value="NFC"/>
      <xs:enumeration value="802.15.4"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="BusType">
    <xs:annotation><xs:documentation>Shared-medium bus protocol type. CAN: Controller Area Network (CAN 2.0B, CAN-FD, CAN-XL). UART: multi-drop serial (STS servo, Dynamixel, RS-485 multidrop). I2C: multi-target I2C bus. SPI: SPI with multiple chip-selects on shared MISO/MOSI/CLK. ethernet: 10BASE-T1S multidrop Ethernet (802.3cg PLCA) — the only Ethernet variant that is a true shared bus. For point-to-point Ethernet use link; for daisy-chain bridged Ethernet use chain. power: power distribution bus (shared voltage rail).</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="CAN"/>
      <xs:enumeration value="UART"/>
      <xs:enumeration value="I2C"/>
      <xs:enumeration value="SPI"/>
      <xs:enumeration value="ethernet"/>
      <xs:enumeration value="power"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="BusTopology">
    <xs:annotation><xs:documentation>Physical wiring topology of a shared bus. daisy-chain: devices wired in series. star: devices wired to a central hub. multidrop: devices tapped along a common wire (e.g., CAN, 10BASE-T1S).</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="daisy-chain"/>
      <xs:enumeration value="star"/>
      <xs:enumeration value="multidrop"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="ChainProtocol">
    <xs:annotation><xs:documentation>Protocol/PHY standard for a bridged daisy-chain. 802.3dm: IEEE 802.3dm multi-drop Ethernet for automotive/robotics. 100base-t1: 100 Mbit/s single-pair Ethernet (IEEE 802.3bw). 1000base-t1: 1 Gbit/s single-pair Ethernet (IEEE 802.3bp). 10gbase-t1: 10 Gbit/s single-pair Ethernet. ethercat: EtherCAT (IEC 61158). profinet: PROFINET IRT. sercos: SERCOS III.</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="802.3dm"/>
      <xs:enumeration value="100base-t1"/>
      <xs:enumeration value="1000base-t1"/>
      <xs:enumeration value="10gbase-t1"/>
      <xs:enumeration value="ethercat"/>
      <xs:enumeration value="profinet"/>
      <xs:enumeration value="sercos"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="ChainMode">
    <xs:annotation><xs:documentation>Forwarding mode for a daisy-chain. switched: each hop is a store-and-forward bridge (e.g., TSN Ethernet). pass-through: frames are processed on-the-fly by each device's hardware without store-and-forward buffering (e.g., EtherCAT).</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="switched"/>
      <xs:enumeration value="pass-through"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="ChainTopology">
    <xs:annotation><xs:documentation>Physical topology of a daisy-chain. line: open-ended chain from first hop to last. ring: last hop connects back to first hop for redundancy (requires port-primary and port-secondary on hops).</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="line"/>
      <xs:enumeration value="ring"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="NoiseType">
    <xs:annotation><xs:documentation>Noise distribution model for sensor simulation. gaussian: Gaussian (normal) distribution with mean and stddev. uniform: uniform distribution over a range. none: no noise applied (ideal sensor).</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="gaussian"/>
      <xs:enumeration value="uniform"/>
      <xs:enumeration value="none"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="PhyRole">
    <xs:annotation><xs:documentation>PHY master/slave role for point-to-point single-pair Ethernet links (100BASE-T1, 1000BASE-T1, 802.3dm). Semantic rule: each T1 link requires exactly one master and one slave. auto: device negotiates role at link-up.</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="master"/>
      <xs:enumeration value="slave"/>
      <xs:enumeration value="auto"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="MacsecPolicy">
    <xs:annotation><xs:documentation>IEEE 802.1AE MACsec enforcement policy. must-secure: drop all frames that are not MACsec-protected (strict security). should-secure: prefer MACsec but accept unprotected frames (transitional). integrity-only: authenticate frames via ICV but do not encrypt payload. disabled: no MACsec processing.</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="must-secure"/>
      <xs:enumeration value="should-secure"/>
      <xs:enumeration value="integrity-only"/>
      <xs:enumeration value="disabled"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="MacsecCipher">
    <xs:annotation><xs:documentation>MACsec cipher suite per IEEE 802.1AE. gcm-aes-128: GCM-AES-128 (default, widely supported). gcm-aes-256: GCM-AES-256. gcm-aes-xpn-128: Extended Packet Numbering with AES-128 (for long-lived associations). gcm-aes-xpn-256: Extended Packet Numbering with AES-256.</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="gcm-aes-128"/>
      <xs:enumeration value="gcm-aes-256"/>
      <xs:enumeration value="gcm-aes-xpn-128"/>
      <xs:enumeration value="gcm-aes-xpn-256"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="PreemptionClass">
    <xs:annotation><xs:documentation>IEEE 802.1Qbu frame preemption classification. express: frames in this traffic class cannot be preempted (high priority, latency-sensitive). preemptable: frames can be interrupted mid-transmission to allow express traffic through.</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="express"/>
      <xs:enumeration value="preemptable"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="KeyAgreement">
    <xs:annotation><xs:documentation>MACsec key agreement protocol. psk: Pre-Shared Key (simpler, manual key distribution). eap-tls: EAP-TLS via IEEE 802.1X (certificate-based, suitable for scalable deployments).</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="psk"/>
      <xs:enumeration value="eap-tls"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="KeyStoreType">
    <xs:annotation><xs:documentation>Credential storage backend for MACsec key material. secure-element: hardware secure element (e.g., ATECC608). hsm: Hardware Security Module. tpm: Trusted Platform Module (TPM 2.0). file: filesystem-based key storage (development only). runtime: keys provisioned at runtime by an external agent.</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="secure-element"/>
      <xs:enumeration value="hsm"/>
      <xs:enumeration value="tpm"/>
      <xs:enumeration value="file"/>
      <xs:enumeration value="runtime"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="DcMode">
    <xs:annotation><xs:documentation>EtherCAT Distributed Clock mode for a hop. free-run: no clock synchronization (device uses local oscillator). sync0: synchronized to SYNC0 pulse from the DC reference clock. sync0-sync1: synchronized to both SYNC0 and SYNC1 pulses for multi-rate processing.</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="free-run"/>
      <xs:enumeration value="sync0"/>
      <xs:enumeration value="sync0-sync1"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="HopRole">
    <xs:annotation><xs:documentation>Role of a device in a daisy-chain. root: chain controller / EtherCAT master (first hop, initiates frames). master: intermediate forwarding hop. tail: last hop in the chain (for line topology, frames turn around here).</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="root"/>
      <xs:enumeration value="master"/>
      <xs:enumeration value="tail"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="BusParticipantRole">
    <xs:annotation><xs:documentation>Role of a device on a shared bus. controller: bus master that initiates transactions (e.g., I2C controller, SPI controller, CAN node with scheduling authority). target: responds to controller requests (e.g., I2C target, SPI target). source: produces data onto the bus (e.g., sensor streaming). sink: consumes data from the bus (e.g., actuator receiving commands).</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="controller"/>
      <xs:enumeration value="target"/>
      <xs:enumeration value="source"/>
      <xs:enumeration value="sink"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="EeePolicyValue">
    <xs:annotation><xs:documentation>IEEE 802.3az Energy Efficient Ethernet policy for the network. enabled: allow ports to enter Low Power Idle when no traffic (saves power, adds wake latency). disabled: ports remain active at all times (deterministic latency, higher power). Typically disabled for TSN networks where latency guarantees are critical.</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="enabled"/>
      <xs:enumeration value="disabled"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="AxisValue">
    <xs:annotation><xs:documentation>Sensor axis alignment mapping. Maps a sensor's internal axis to the component's body frame axis. Supports positive and negative directions: X, -X, Y, -Y, Z, -Z. Used to correct for sensors mounted in non-standard orientations.</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="X"/>
      <xs:enumeration value="-X"/>
      <xs:enumeration value="Y"/>
      <xs:enumeration value="-Y"/>
      <xs:enumeration value="Z"/>
      <xs:enumeration value="-Z"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="TransmissionType">
    <xs:annotation><xs:documentation>Mechanical power transmission mechanism between motor and joint. simple: direct drive or single-stage reduction. differential: differential gear mechanism (couples two motors to two outputs). belt: belt/pulley transmission. gear: spur or helical gear train. planetary: planetary (epicyclic) gear set (compact, high ratio). cycloidal: cycloidal drive (high ratio, zero backlash, high shock load capacity — used in robot joints). harmonic: harmonic drive / strain-wave gearing (very high ratio in compact form, used in robot arms — Harmonic Drive AG). strain-wave: same as harmonic (alternate name). worm: worm gear (high ratio, self-locking, lower efficiency — used where back-driving prevention needed).</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="simple"/>
      <xs:enumeration value="differential"/>
      <xs:enumeration value="belt"/>
      <xs:enumeration value="gear"/>
      <xs:enumeration value="planetary"/>
      <xs:enumeration value="cycloidal"/>
      <xs:enumeration value="harmonic"/>
      <xs:enumeration value="strain-wave"/>
      <xs:enumeration value="worm"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="CompRole">
    <xs:annotation><xs:documentation>Functional role of a component in the robot. sensor: sensing-only device (e.g., camera module, IMU board). compute: processing unit (e.g., SoC, SBC, FPGA). actuator: motor driver or actuator assembly. parent: structural/mechanical parent that groups child components (e.g., chassis, arm segment).</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="sensor"/>
      <xs:enumeration value="compute"/>
      <xs:enumeration value="actuator"/>
      <xs:enumeration value="parent"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="TunnelProtocol">
    <xs:annotation><xs:documentation>Encapsulation protocol for tunneling one chain's traffic over another network. etg-1700: EtherCAT-over-EtherCAT tunneling (ETG.1700 specification). ieee-1722: IEEE 1722 AVTP encapsulation (used for EtherCAT-over-TSN). raw: raw Ethernet frame encapsulation with no additional headers.</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="etg-1700"/>
      <xs:enumeration value="ieee-1722"/>
      <xs:enumeration value="raw"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="ConfidentialityOffset">
    <xs:annotation><xs:documentation>MACsec confidentiality offset in bytes per IEEE 802.1AE. Specifies how many bytes of payload after the SecTAG remain unencrypted. 0: encrypt entire payload (maximum security). 30: leave first 30 bytes unencrypted (exposes L3/L4 headers for QoS classification). 50: leave first 50 bytes unencrypted (exposes more header fields).</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="0"/>
      <xs:enumeration value="30"/>
      <xs:enumeration value="50"/>
    </xs:restriction>
  </xs:simpleType>

  <!-- Sensor sub-type enumerations -->
  <xs:simpleType name="InertialSensorType">
    <xs:annotation><xs:documentation>Inertial sensor sub-type. accel: accelerometer only (3-axis linear acceleration). gyro: gyroscope only (3-axis angular rate). accel_gyro: combined IMU with both accelerometer and gyroscope (6-axis).</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="accel"/>
      <xs:enumeration value="gyro"/>
      <xs:enumeration value="accel_gyro"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="EmSensorType">
    <xs:annotation><xs:documentation>Near-field electromagnetic sensor sub-type. Measures static or quasi-static EM fields — NOT propagating radio waves (those are rf). mag: magnetometer (measures Earth's magnetic field or local fields). metal_detector: inductive proximity sensing. eddy_current: non-destructive testing via induced currents. emf: electromotive force measurement. hall-effect: Hall effect proximity/position sensor. fluxgate: fluxgate magnetometer (high-precision compass).</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="mag"/>
      <xs:enumeration value="metal_detector"/>
      <xs:enumeration value="eddy_current"/>
      <xs:enumeration value="emf"/>
      <xs:enumeration value="hall-effect"/>
      <xs:enumeration value="fluxgate"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="OpticalSensorType">
    <xs:annotation><xs:documentation>Optical sensor sub-type. camera: visible-spectrum image sensor (RGB, mono, stereo, depth). thermal: infrared thermal camera (LWIR/MWIR). lidar: Light Detection and Ranging (spinning or solid-state). tof: Time-of-Flight depth sensor. optical_flow: optical flow sensor for velocity estimation.</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="camera"/>
      <xs:enumeration value="thermal"/>
      <xs:enumeration value="lidar"/>
      <xs:enumeration value="tof"/>
      <xs:enumeration value="optical_flow"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="RfSensorType">
    <xs:annotation><xs:documentation>Radio-frequency sensor sub-type. Uses propagating radio waves for ranging, positioning, or imaging — distinct from em which measures static/quasi-static fields. gnss: satellite navigation receiver. uwb: Ultra-Wideband ranging. radar: radio detection and ranging (24/77/79 GHz). radio_altimeter: radio altitude measurement.</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="gnss"/>
      <xs:enumeration value="uwb"/>
      <xs:enumeration value="radar"/>
      <xs:enumeration value="radio_altimeter"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="ChemicalSensorType">
    <xs:annotation><xs:documentation>Chemical/environmental sensor sub-type. gas: gas concentration sensor (CO2, VOC, methane, etc.). ph: pH sensor for liquid acidity measurement. humidity: relative humidity sensor.</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="gas"/>
      <xs:enumeration value="ph"/>
      <xs:enumeration value="humidity"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="ForceSensorType">
    <xs:annotation><xs:documentation>Force/torque sensor sub-type. strain: strain gauge for deformation measurement. pressure: pressure transducer (barometric or contact). torque: rotary torque sensor. load_cell: load cell for weight/force measurement.</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="strain"/>
      <xs:enumeration value="pressure"/>
      <xs:enumeration value="torque"/>
      <xs:enumeration value="load_cell"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="EncoderSensorType">
    <xs:annotation><xs:documentation>Encoder measurement type. incremental: relative position from index/home, requires homing. absolute: absolute position within one revolution (single-turn) or multiple revolutions (multi-turn). linear: linear position encoder (e.g., optical strip, magnetic linear).</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="incremental"/>
      <xs:enumeration value="absolute"/>
      <xs:enumeration value="linear"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="EncoderPrinciple">
    <xs:annotation><xs:documentation>Physical sensing principle of the encoder. optical: light source + photodetector + code disk (e.g., US Digital, Broadcom AEDR). magnetic: Hall effect or magnetoresistive element + rotating magnet (e.g., AS5048A, AS5600). inductive: resolver, electromagnetic induction between coils. capacitive: capacitance change between rotating plates. resistive: potentiometer, resistance proportional to position.</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="optical"/>
      <xs:enumeration value="magnetic"/>
      <xs:enumeration value="inductive"/>
      <xs:enumeration value="capacitive"/>
      <xs:enumeration value="resistive"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="TemperatureSensorType">
    <xs:annotation><xs:documentation>Temperature sensor type. thermistor: NTC or PTC resistive element (common in motors for winding temp). rtd: Resistance Temperature Detector (PT100/PT1000, high accuracy). thermocouple: K/J/T/E type junction (wide range, industrial). ir: non-contact infrared temperature sensor.</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="thermistor"/>
      <xs:enumeration value="rtd"/>
      <xs:enumeration value="thermocouple"/>
      <xs:enumeration value="ir"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="RadiationSensorType">
    <xs:annotation><xs:documentation>Radiation sensor sub-type for nuclear inspection, environmental monitoring, and space robotics. geiger: Geiger-Muller tube for ionizing radiation counting (alpha, beta, gamma). scintillation: scintillation detector for gamma spectroscopy (higher energy resolution than Geiger). neutron: neutron detector for nuclear material detection. dosimeter: cumulative radiation dose measurement.</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="geiger"/>
      <xs:enumeration value="scintillation"/>
      <xs:enumeration value="neutron"/>
      <xs:enumeration value="dosimeter"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="AudioSensorType">
    <xs:annotation><xs:documentation>Audio/acoustic sensor sub-type. microphone: audio capture for speech, sound localization, acoustic monitoring. ultrasonic: ultrasonic transducer for proximity sensing and ranging (typically 40kHz). sonar: underwater acoustic ranging and imaging. hydrophone: underwater passive acoustic sensor for listening.</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="microphone"/>
      <xs:enumeration value="ultrasonic"/>
      <xs:enumeration value="sonar"/>
      <xs:enumeration value="hydrophone"/>
    </xs:restriction>
  </xs:simpleType>

  <!-- ================================================================ -->
  <!-- LEAF TYPES (Values, Geometry, Pose, Noise)                      -->
  <!-- ================================================================ -->

  <!-- Simple value with unit (speed, bitrate, sensor range, torque-constant, etc.) -->
  <xs:complexType name="measured_value" mixed="true">
    <xs:annotation><xs:documentation>A scalar measurement with an optional unit. The text content is the numeric value. HCDF assumes SI units by default — if the unit attribute is omitted, the parent element's documented default SI unit applies (meters for length, kg for mass, radians for angles, seconds for time, Hz for frequency, V for voltage, A for current, W for power, ohm for resistance, Nm for torque, N for force, degC for temperature, Mbps for network speed). Specify unit explicitly only when using a non-SI unit or when the context is ambiguous (e.g., velocity-constant where unit distinguishes Ke from Kv). Example: &lt;speed&gt;100&lt;/speed&gt; means 100 Mbps (SI default for speed). &lt;velocity-constant unit="RPM/V"&gt;920&lt;/velocity-constant&gt; needs explicit unit.</xs:documentation></xs:annotation>
    <xs:attribute name="unit" type="xs:string">
      <xs:annotation><xs:documentation>Physical unit of the measurement. Optional — if omitted, the SI default for the parent element applies. Specify explicitly for non-SI units (e.g., "RPM/V", "deg", "rpm", "g", "dps", "mK") or when the unit is ambiguous.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- Value with range (port voltage, temperature ranges) -->
  <xs:complexType name="range_value" mixed="true">
    <xs:annotation><xs:documentation>A value with minimum and maximum bounds and an optional unit. The text content is the nominal value. Used for port voltage ranges, temperature operating ranges, and similar bounded quantities. SI defaults apply when unit is omitted (V for voltage, degC for temperature, etc.).</xs:documentation></xs:annotation>
    <xs:attribute name="unit" type="xs:string">
      <xs:annotation><xs:documentation>Physical unit. Optional — SI default applies if omitted.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="min" type="xs:double">
      <xs:annotation><xs:documentation>Minimum acceptable value in the specified unit.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="max" type="xs:double">
      <xs:annotation><xs:documentation>Maximum acceptable value in the specified unit.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- Rated value (motor current/voltage with nominal/continuous/peak/max) -->
  <xs:complexType name="rated_value" mixed="true">
    <xs:annotation><xs:documentation>A value with multiple rating levels for motor electrical parameters. Text content is the primary value. Used for motor voltage (default unit: V) and current (default unit: A) where different operating regimes apply (nominal steady-state, continuous thermal limit, short-term peak, absolute maximum). SI defaults apply when unit is omitted.</xs:documentation></xs:annotation>
    <xs:attribute name="unit" type="xs:string">
      <xs:annotation><xs:documentation>Physical unit. Optional — V for voltage elements, A for current elements by SI default.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="nominal" type="xs:double">
      <xs:annotation><xs:documentation>Nominal (design-point) operating value. The steady-state value the motor is designed for.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="continuous" type="xs:double">
      <xs:annotation><xs:documentation>Maximum continuous value the motor can sustain indefinitely without overheating.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="peak" type="xs:double">
      <xs:annotation><xs:documentation>Peak value the motor can sustain for a short duration (typically seconds to minutes) before thermal limits are reached.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="max" type="xs:double">
      <xs:annotation><xs:documentation>Absolute maximum value. Exceeding this causes permanent damage or triggers hardware protection.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- Pose: HCDF convention is string content "x y z roll pitch yaw" -->
  <xs:complexType name="pose">
    <xs:annotation><xs:documentation>6-DOF pose (position + orientation) of an element relative to its parent frame. Specify position via xyz and orientation via either rpy (Euler angles) or quat (quaternion). If both rpy and quat are given, quat takes precedence.</xs:documentation></xs:annotation>
    <xs:attribute name="xyz" type="xs:string" default="0 0 0">
      <xs:annotation><xs:documentation>Position as three space-separated doubles "x y z" in meters. Default: "0 0 0" (origin of parent frame).</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="rpy" type="xs:string" default="0 0 0">
      <xs:annotation><xs:documentation>Orientation as three space-separated Euler angles "roll pitch yaw" in radians (XYZ extrinsic convention). Default: "0 0 0" (no rotation).</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="quat" type="xs:string">
      <xs:annotation><xs:documentation>Orientation as quaternion "x y z w" (Hamilton convention, scalar-last). Optional; if present, overrides rpy.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- Color: RGBA 0-1 range -->
  <xs:complexType name="color">
    <xs:annotation><xs:documentation>RGBA color specification for visual materials.</xs:documentation></xs:annotation>
    <xs:attribute name="rgba" type="xs:string" default="0 0 0 1">
      <xs:annotation><xs:documentation>Four space-separated floats "R G B A" each in [0, 1]. R=red, G=green, B=blue, A=alpha (1=opaque, 0=transparent). Default: "0 0 0 1" (opaque black).</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- ===== Geometry Primitives ===== -->

  <xs:complexType name="box">
    <xs:annotation><xs:documentation>Axis-aligned box geometry primitive centered at the parent pose origin.</xs:documentation></xs:annotation>
    <xs:all><xs:element name="size" type="xs:string" minOccurs="1">
      <xs:annotation><xs:documentation>Box dimensions as three space-separated doubles "width depth height" in meters (X Y Z extents).</xs:documentation></xs:annotation>
    </xs:element></xs:all>
  </xs:complexType>

  <xs:complexType name="cylinder">
    <xs:annotation><xs:documentation>Cylinder geometry primitive centered at the parent pose origin, aligned with the Z axis.</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="radius" type="xs:double" minOccurs="1">
        <xs:annotation><xs:documentation>Cylinder radius in meters.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="length" type="xs:double" minOccurs="1">
        <xs:annotation><xs:documentation>Cylinder length (height) along the Z axis in meters.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="sphere">
    <xs:annotation><xs:documentation>Sphere geometry primitive centered at the parent pose origin.</xs:documentation></xs:annotation>
    <xs:all><xs:element name="radius" type="xs:double" minOccurs="1">
      <xs:annotation><xs:documentation>Sphere radius in meters.</xs:documentation></xs:annotation>
    </xs:element></xs:all>
  </xs:complexType>

  <xs:complexType name="capsule">
    <xs:annotation><xs:documentation>Capsule (cylinder with hemispherical caps) geometry primitive, aligned with the Z axis. Total height = length + 2 * radius.</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="radius" type="xs:double" minOccurs="1">
        <xs:annotation><xs:documentation>Capsule radius (cylinder and hemisphere radius) in meters.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="length" type="xs:double" minOccurs="1">
        <xs:annotation><xs:documentation>Length of the cylindrical section in meters (excludes hemispherical caps).</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="cone">
    <xs:annotation><xs:documentation>Solid cone primitive. Base circle of given radius, tapering to a point at the given length along the Z axis. Use for nose cones, drill bits, funnels, pointed housings. Distinct from frustum which is a truncated cone for FOV visualization.</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="radius" type="xs:double" minOccurs="1">
        <xs:annotation><xs:documentation>Radius of the cone base in meters.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="length" type="xs:double" minOccurs="1">
        <xs:annotation><xs:documentation>Height of the cone from base to apex in meters.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="ellipsoid">
    <xs:annotation><xs:documentation>Ellipsoid primitive defined by three semi-axis radii. A sphere is a special case where all three radii are equal. Use for approximating heads, torsos, drone fuselages, and other non-uniform rounded shapes. Supported by SDF.</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="radii" type="xs:string" minOccurs="1">
        <xs:annotation><xs:documentation>Three semi-axis radii as "rx ry rz" in meters. Example: "0.1 0.08 0.15" for an egg-shaped ellipsoid.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="mesh">
    <xs:annotation><xs:documentation>External 3D mesh geometry loaded from a file. Supports GLB, glTF, STL, OBJ, and DAE formats.</xs:documentation></xs:annotation>
    <xs:attribute name="uri" type="xs:anyURI" use="required">
      <xs:annotation><xs:documentation>URI of the mesh file (relative to the HCDF document or absolute). Required.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="scale" type="xs:string" default="1 1 1">
      <xs:annotation><xs:documentation>Scale factors as three space-separated doubles "sx sy sz" applied to the mesh. Default: "1 1 1" (no scaling).</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:simpleType name="FrustumShape">
    <xs:annotation><xs:documentation>Cross-section shape of a frustum used for sensor field-of-view visualization.</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="conical"/>
      <xs:enumeration value="pyramidal"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:complexType name="frustum">
    <xs:annotation><xs:documentation>Frustum (truncated cone/pyramid) for sensor field-of-view visualization. Not a solid physics primitive — use cone/box/cylinder for collision. The shape attribute determines the cross-section: "conical" (circular, uses fov angle) or "pyramidal" (rectangular, uses hfov + vfov). Semantic rule: conical requires fov; pyramidal requires hfov + vfov.</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="near" type="xs:double" minOccurs="1">
        <xs:annotation><xs:documentation>Near plane distance from sensor origin in meters.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="far" type="xs:double" minOccurs="1">
        <xs:annotation><xs:documentation>Far plane distance from sensor origin in meters.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="fov" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Full cone angle in radians (for shape="conical"). Defines a circular cross-section FOV.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="hfov" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Horizontal field of view in radians (for shape="pyramidal").</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="vfov" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Vertical field of view in radians (for shape="pyramidal").</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
    <xs:attribute name="shape" type="FrustumShape" use="required">
      <xs:annotation><xs:documentation>Cross-section shape: "conical" (circular, single fov angle) or "pyramidal" (rectangular, hfov + vfov).</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- Geometry container: exactly one primitive -->
  <xs:complexType name="geometry">
    <xs:annotation><xs:documentation>Geometry container holding exactly one geometric primitive. Solid primitives (box, cylinder, sphere, capsule, cone, ellipsoid, mesh) are used for collision bounds and visual shapes. Frustum is used for sensor field-of-view visualization.</xs:documentation></xs:annotation>
    <xs:choice>
      <xs:element name="box" type="box">
        <xs:annotation><xs:documentation>Axis-aligned box primitive.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="cylinder" type="cylinder">
        <xs:annotation><xs:documentation>Cylinder primitive aligned with the Z axis.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="sphere" type="sphere">
        <xs:annotation><xs:documentation>Sphere primitive.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="capsule" type="capsule">
        <xs:annotation><xs:documentation>Capsule (cylinder + hemispherical caps) primitive.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="cone" type="cone">
        <xs:annotation><xs:documentation>Solid cone primitive (base radius + height).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="ellipsoid" type="ellipsoid">
        <xs:annotation><xs:documentation>Ellipsoid with three semi-axis radii.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="mesh" type="mesh">
        <xs:annotation><xs:documentation>External 3D mesh file reference (GLB, glTF, STL, OBJ).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="frustum" type="frustum">
        <xs:annotation><xs:documentation>Frustum for sensor FOV (conical or pyramidal cross-section).</xs:documentation></xs:annotation>
      </xs:element>
    </xs:choice>
  </xs:complexType>

  <!-- Noise model -->
  <xs:complexType name="noise">
    <xs:annotation><xs:documentation>Sensor noise model for simulation. Specifies the statistical distribution and parameters applied to ideal sensor readings. For gaussian type: output = ideal + N(mean, stddev) + bias where bias ~ N(bias-mean, bias-stddev). For uniform type: output = ideal + U(mean - stddev, mean + stddev).</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="mean" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Mean of the noise distribution. Default: 0. Units match the sensor's measurement unit.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="stddev" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Standard deviation of the noise distribution. Default: 0. Units match the sensor's measurement unit.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="bias-mean" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Mean of the bias random walk (constant offset that drifts slowly over time). Default: 0.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="bias-stddev" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Standard deviation of the bias random walk. Default: 0.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="precision" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Quantization precision (ADC resolution). Output is rounded to the nearest multiple of this value. Units match the sensor's measurement unit.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
    <xs:attribute name="type" type="NoiseType" use="required">
      <xs:annotation><xs:documentation>Noise distribution type. Required. Use "gaussian" for realistic sensor simulation, "none" for ideal sensors.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- COMPONENT INTERNALS                                             -->
  <!-- ================================================================ -->

  <!-- Inertial properties -->
  <xs:complexType name="inertial_properties">
    <xs:annotation><xs:documentation>Inertial properties of a rigid body component. Defines mass, center of mass, and rotational inertia for dynamics simulation. Equivalent to URDF's inertial element.</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="mass" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Total mass of the component in kilograms (kg).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="com" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Center of mass position as "x y z" in meters relative to the component origin.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="inertia" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Rotational inertia tensor as "ixx ixy ixz iyy iyz izz" in kg*m^2. Six unique components of the symmetric 3x3 inertia matrix about the center of mass.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
  </xs:complexType>

  <!-- Model reference: GLB/glTF with SHA256 -->
  <xs:complexType name="model_ref">
    <xs:annotation><xs:documentation>Reference to an external 3D model file (GLB or glTF) for high-fidelity visual representation. Preferred over geometry primitives when available.</xs:documentation></xs:annotation>
    <xs:attribute name="uri" type="xs:anyURI" use="required">
      <xs:annotation><xs:documentation>URI of the 3D model file (GLB/glTF format). Relative to the HCDF document or absolute. Required.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="sha" type="xs:string">
      <xs:annotation><xs:documentation>SHA-256 hash of the referenced file for content integrity verification. Optional but recommended for reproducible builds.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- Material: inline (within visual) -->
  <xs:complexType name="material_inline">
    <xs:annotation><xs:documentation>Inline material definition for a visual element. Either defines color directly or references a globally defined material by name.</xs:documentation></xs:annotation>
    <xs:all><xs:element name="color" type="color" minOccurs="0">
      <xs:annotation><xs:documentation>RGBA color for this material. Optional if referencing a global material by name.</xs:documentation></xs:annotation>
    </xs:element></xs:all>
    <xs:attribute name="name" type="xs:string">
      <xs:annotation><xs:documentation>Reference to a globally defined material name (from top-level material elements), or a local name for this inline material definition.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- Visual: 3D model reference. <model> is primary, <geometry> is fallback. -->
  <xs:complexType name="visual">
    <xs:annotation><xs:documentation>Visual representation of a component for rendering. Contains either a high-fidelity 3D model reference or a geometry primitive fallback (or both, where model is preferred and geometry is the fallback). Multiple visuals per component are allowed for multi-part rendering.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="pose" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Pose of the visual relative to the component origin as "x y z roll pitch yaw" (meters and radians). Default: identity (no offset).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="model" type="model_ref" minOccurs="0">
        <xs:annotation><xs:documentation>High-fidelity 3D model reference (GLB/glTF). Preferred over geometry when available.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="geometry" type="geometry" minOccurs="0">
        <xs:annotation><xs:documentation>Geometry primitive fallback for rendering when no 3D model is available.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="material" type="material_inline" minOccurs="0">
        <xs:annotation><xs:documentation>Material properties (color, texture) for this visual. Overrides any material in the referenced model.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Unique name for this visual within the component. Required. Used for programmatic toggling and identification.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="toggle" type="xs:string">
      <xs:annotation><xs:documentation>Toggle group name. Visuals sharing the same toggle group can be shown/hidden together at runtime (e.g., "leds", "covers").</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- Surface properties -->
  <xs:complexType name="friction">
    <xs:annotation><xs:documentation>Friction coefficients for contact simulation between surfaces.</xs:documentation></xs:annotation>
    <xs:attribute name="static" type="xs:double" default="0">
      <xs:annotation><xs:documentation>Static friction coefficient (dimensionless). Force required to initiate sliding. Default: 0.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="dynamic" type="xs:double" default="0">
      <xs:annotation><xs:documentation>Dynamic (kinetic) friction coefficient (dimensionless). Force during sliding. Must be less than or equal to static. Default: 0.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="contact">
    <xs:annotation><xs:documentation>Contact dynamics parameters for collision response in physics simulation.</xs:documentation></xs:annotation>
    <xs:attribute name="stiffness" type="xs:double">
      <xs:annotation><xs:documentation>Contact stiffness in N/m. Higher values create harder contacts with less penetration.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="damping" type="xs:double">
      <xs:annotation><xs:documentation>Contact damping coefficient in N*s/m. Dissipates energy during contact to reduce bouncing.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="surface">
    <xs:annotation><xs:documentation>Surface physics properties for collision geometry. Defines friction, restitution (bounciness), and contact dynamics used by physics simulators.</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="friction" type="friction" minOccurs="0">
        <xs:annotation><xs:documentation>Static and dynamic friction coefficients.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="restitution" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Coefficient of restitution (bounciness). 0 = perfectly inelastic (no bounce), 1 = perfectly elastic (full bounce). Dimensionless, range [0, 1].</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="contact" type="contact" minOccurs="0">
        <xs:annotation><xs:documentation>Contact dynamics parameters (stiffness, damping) for physics simulation.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
    <xs:attribute name="material" type="xs:string">
      <xs:annotation><xs:documentation>Reference to a named global material that provides default surface properties. Inline friction/restitution/contact elements override the referenced material's values.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- Collision -->
  <xs:complexType name="collision">
    <xs:annotation><xs:documentation>Collision geometry for physics simulation and proximity detection. Typically a simplified version of the visual geometry (bounding box, convex hull, or low-poly mesh). Multiple collision elements per component are allowed for complex shapes.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="pose" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Pose of the collision geometry relative to the component origin as "x y z roll pitch yaw" (meters and radians). Default: identity.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="geometry" type="geometry" minOccurs="1">
        <xs:annotation><xs:documentation>Geometry primitive or mesh defining the collision boundary. Required.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="surface" type="surface" minOccurs="0">
        <xs:annotation><xs:documentation>Surface physics properties (friction, restitution, contact) for this collision shape.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Unique name for this collision shape within the component. Required.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- Frame -->
  <xs:complexType name="frame">
    <xs:annotation><xs:documentation>Named coordinate frame attached to a component. Used for expressing sensor mounts, tool center points, mounting holes, or any reference point that other elements can relate to via the relative-to attribute.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="description" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Human-readable description of the frame's purpose (e.g., "camera mount point", "tool center point").</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="pose" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Pose of the frame relative to the component origin (or to the frame named in relative-to) as "x y z roll pitch yaw" (meters and radians).</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Unique name for this frame within the component. Required. Referenced by other elements using the frame name.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="relative-to" type="xs:string">
      <xs:annotation><xs:documentation>Name of another frame that this frame's pose is relative to. If omitted, the pose is relative to the component origin.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="type" type="xs:string">
      <xs:annotation><xs:documentation>Frame purpose type: "tcp" (Tool Center Point for end-effector control), "sensor-origin" (sensor reference frame), "attachment" (mechanical mounting point), "optical" (camera optical frame, Z-forward convention). Optional — omit for general-purpose frames.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- Material: global definition -->
  <xs:complexType name="material_global">
    <xs:annotation><xs:documentation>Globally defined material that can be referenced by name from visual and surface elements throughout the HCDF document. Defines appearance (color) and physics (surface properties) in one reusable definition.</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="description" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Human-readable description of the material (e.g., "anodized aluminum", "carbon fiber composite").</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="color" type="color" minOccurs="0">
        <xs:annotation><xs:documentation>RGBA color of the material for visual rendering.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="surface" type="surface" minOccurs="0">
        <xs:annotation><xs:documentation>Surface physics properties (friction, restitution, contact) when this material is involved in collisions.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
    <xs:attribute name="name" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Unique name for this material. Required. Referenced from visual material elements and collision surfaces.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- PORTS & ANTENNAS                                                -->
  <!-- ================================================================ -->

  <!-- Port power capabilities -->
  <xs:complexType name="voltage_capability" mixed="true">
    <xs:annotation><xs:documentation>Port voltage capability. Text content is the nominal voltage. Attributes define the acceptable operating range. Used for power ports and powered Ethernet (PoDL).</xs:documentation></xs:annotation>
    <xs:attribute name="unit" type="xs:string">
      <xs:annotation><xs:documentation>Voltage unit (typically "V").</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="min" type="xs:double">
      <xs:annotation><xs:documentation>Minimum input/output voltage in the specified unit.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="max" type="xs:double">
      <xs:annotation><xs:documentation>Maximum input/output voltage in the specified unit.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="current_capability" mixed="true">
    <xs:annotation><xs:documentation>Port current capability. Text content is the rated current value. Used for power delivery sizing.</xs:documentation></xs:annotation>
    <xs:attribute name="unit" type="xs:string">
      <xs:annotation><xs:documentation>Current unit (typically "A" or "mA").</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="max" type="xs:double">
      <xs:annotation><xs:documentation>Maximum current the port can source or sink in the specified unit.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="power_capability" mixed="true">
    <xs:annotation><xs:documentation>Port power capability. Text content is the rated power value. Used for total power budget calculations.</xs:documentation></xs:annotation>
    <xs:attribute name="unit" type="xs:string">
      <xs:annotation><xs:documentation>Power unit (typically "W" or "mW").</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="max" type="xs:double">
      <xs:annotation><xs:documentation>Maximum power the port can source or sink in the specified unit.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- PHY config -->
  <xs:complexType name="phy_config">
    <xs:annotation><xs:documentation>Physical layer configuration for an Ethernet port. Required for single-pair Ethernet links (100BASE-T1, 1000BASE-T1, 802.3dm) where PHY master/slave role must be explicitly configured. Semantic rule: each point-to-point T1 link requires exactly one master and one slave.</xs:documentation></xs:annotation>
    <xs:attribute name="role" type="PhyRole" use="required">
      <xs:annotation><xs:documentation>PHY master/slave role. Required. master: provides clock reference. slave: recovers clock from master. auto: negotiate at link-up (not recommended for deterministic systems).</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- TSN port capabilities -->
  <xs:complexType name="tsn_gptp_capability">
    <xs:annotation><xs:documentation>IEEE 802.1AS gPTP capability of a port. Indicates whether the port supports hardware timestamping and grandmaster election.</xs:documentation></xs:annotation>
    <xs:attribute name="hw-timestamping" type="xs:boolean" default="false">
      <xs:annotation><xs:documentation>Whether the port supports IEEE 802.1AS hardware timestamping for nanosecond-accurate clock synchronization. Default: false.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="gm-capable" type="xs:boolean" default="false">
      <xs:annotation><xs:documentation>Whether the device behind this port can serve as gPTP grandmaster clock. Default: false.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="tsn_qbv_capability">
    <xs:annotation><xs:documentation>IEEE 802.1Qbv Time-Aware Shaper capability of a port. Defines the port's gate scheduling hardware resources.</xs:documentation></xs:annotation>
    <xs:attribute name="traffic-classes" type="xs:unsignedInt" default="8">
      <xs:annotation><xs:documentation>Number of traffic classes (priority queues) supported by the port. Default: 8 (IEEE 802.1Q maximum).</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="hw-queues" type="xs:unsignedInt" default="8">
      <xs:annotation><xs:documentation>Number of hardware transmit queues. Default: 8. May differ from traffic-classes if queue-to-TC mapping is used.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="max-gcl-entries" type="xs:unsignedInt">
      <xs:annotation><xs:documentation>Maximum number of Gate Control List entries the port hardware supports. Limits the complexity of Qbv schedules that can be programmed.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="tsn_preemption_capability">
    <xs:annotation><xs:documentation>IEEE 802.1Qbu/802.3br frame preemption capability. Allows express traffic to interrupt preemptable frames mid-transmission, reducing worst-case latency for high-priority traffic.</xs:documentation></xs:annotation>
    <xs:attribute name="min-fragment-size" type="xs:unsignedInt" default="64">
      <xs:annotation><xs:documentation>Minimum preemptable fragment size in bytes. Preempted frames are split at fragment boundaries no smaller than this. Default: 64 bytes.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="tsn_psfp_capability">
    <xs:annotation><xs:documentation>IEEE 802.1Qci Per-Stream Filtering and Policing capability. Provides ingress filtering, rate policing, and stream identification for protecting against misbehaving talkers.</xs:documentation></xs:annotation>
    <xs:attribute name="max-filters" type="xs:unsignedInt">
      <xs:annotation><xs:documentation>Maximum number of stream filters the port hardware supports.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="max-gates" type="xs:unsignedInt">
      <xs:annotation><xs:documentation>Maximum number of stream gates (time-based ingress windows) the port hardware supports.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="max-meters" type="xs:unsignedInt">
      <xs:annotation><xs:documentation>Maximum number of flow meters for bandwidth policing the port hardware supports.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="tsn_frer_capability">
    <xs:annotation><xs:documentation>IEEE 802.1CB Frame Replication and Elimination for Reliability capability. Provides seamless redundancy by duplicating streams over disjoint paths and eliminating duplicates at the receiver.</xs:documentation></xs:annotation>
    <xs:attribute name="seq-encoding" type="xs:string" default="r-tag">
      <xs:annotation><xs:documentation>Sequence number encoding format. Default: "r-tag" (IEEE 802.1CB R-TAG). Alternatives include "hsrp" for HSR/PRP sequence tags.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="tsn_ats_capability">
    <xs:annotation><xs:documentation>IEEE 802.1Qcr Asynchronous Traffic Shaping capability. Provides per-stream shaping without requiring time synchronization, useful for non-gPTP-capable devices.</xs:documentation></xs:annotation>
    <xs:attribute name="max-groups" type="xs:unsignedInt">
      <xs:annotation><xs:documentation>Maximum number of ATS shaping groups the port hardware supports.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="tsn_cbs_capability">
    <xs:annotation><xs:documentation>IEEE 802.1Qav Credit-Based Shaper capability. Provides bandwidth reservation for AVB/TSN streams by limiting burst size via credit accumulation. Presence indicates CBS support. The max-sr-classes attribute specifies how many SR (Stream Reservation) classes the port hardware supports.</xs:documentation></xs:annotation>
    <xs:attribute name="max-sr-classes" type="xs:unsignedInt" default="2">
      <xs:annotation><xs:documentation>Maximum number of SR (Stream Reservation) classes supported. Standard AVB defines 2 classes (A and B). Some hardware supports additional classes. Default: 2.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="tsn_port_capabilities">
    <xs:annotation><xs:documentation>TSN (Time-Sensitive Networking) capabilities of a port. Declares which IEEE 802.1 TSN sub-standards the port hardware supports. Used by network planners to determine valid schedule and stream placements.</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="gptp" type="tsn_gptp_capability" minOccurs="0">
        <xs:annotation><xs:documentation>IEEE 802.1AS gPTP time synchronization capability.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="qbv" type="tsn_qbv_capability" minOccurs="0">
        <xs:annotation><xs:documentation>IEEE 802.1Qbv Time-Aware Shaper capability.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="cbs" type="tsn_cbs_capability" minOccurs="0">
        <xs:annotation><xs:documentation>IEEE 802.1Qav Credit-Based Shaper capability.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="preemption" type="tsn_preemption_capability" minOccurs="0">
        <xs:annotation><xs:documentation>IEEE 802.1Qbu/802.3br frame preemption capability.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="psfp" type="tsn_psfp_capability" minOccurs="0">
        <xs:annotation><xs:documentation>IEEE 802.1Qci Per-Stream Filtering and Policing capability.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="frer" type="tsn_frer_capability" minOccurs="0">
        <xs:annotation><xs:documentation>IEEE 802.1CB Frame Replication and Elimination for Reliability capability.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="ats" type="tsn_ats_capability" minOccurs="0">
        <xs:annotation><xs:documentation>IEEE 802.1Qcr Asynchronous Traffic Shaping capability.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="macsec_capability">
    <xs:annotation><xs:documentation>IEEE 802.1AE MACsec hardware capability of a port. Lists the cipher suites the port's MACsec engine can accelerate in hardware.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="cipher" type="MacsecCipher" minOccurs="1" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>A supported MACsec cipher suite. At least one must be listed. Multiple entries indicate the port can negotiate among them.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="lldp_capability">
    <xs:annotation><xs:documentation>IEEE 802.1AB LLDP (Link Layer Discovery Protocol) capability of a port.</xs:documentation></xs:annotation>
    <xs:attribute name="tsn-tlvs" type="xs:boolean" default="false">
      <xs:annotation><xs:documentation>Whether the port supports TSN-specific LLDP TLVs for automatic TSN capability discovery and configuration (IEEE 802.1Qcc). Default: false.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="plca_capability">
    <xs:annotation><xs:documentation>IEEE 802.3cg PLCA (Physical Layer Collision Avoidance) capability for 10BASE-T1S multi-drop Ethernet. PLCA provides deterministic medium access by assigning time slots to each node.</xs:documentation></xs:annotation>
    <xs:attribute name="max-nodes" type="xs:unsignedInt" default="8">
      <xs:annotation><xs:documentation>Maximum number of PLCA nodes this port supports on a single multi-drop segment. Default: 8.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="eee_capability">
    <xs:annotation><xs:documentation>IEEE 802.3az Energy Efficient Ethernet capability of a port.</xs:documentation></xs:annotation>
    <xs:attribute name="supported" type="xs:boolean" default="false">
      <xs:annotation><xs:documentation>Whether the port supports EEE Low Power Idle mode. Default: false. Note: EEE adds wake latency and is typically disabled for TSN ports.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="port_capabilities">
    <xs:annotation><xs:documentation>Hardware capabilities of a physical port. Declares data rates, PHY configuration, TSN features, MACsec support, and power delivery characteristics. Elements must appear in order: data, PHY, TSN, power. Semantic rule: use either speed OR speed-tx + speed-rx, not both.</xs:documentation></xs:annotation>
    <xs:sequence>
      <!-- Data (use speed OR speed-tx+speed-rx, not both) -->
      <xs:element name="speed" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Symmetric port speed (same TX and RX rate). Mutually exclusive with speed-tx/speed-rx. Example: 1000 with unit="Mbps".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="speed-tx" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Transmit speed for asymmetric ports. Must be paired with speed-rx. Mutually exclusive with speed.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="speed-rx" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Receive speed for asymmetric ports. Must be paired with speed-tx. Mutually exclusive with speed.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="bitrate" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Raw bit rate for non-Ethernet serial ports (CAN, UART, SPI, I2C). Example: 500000 with unit="bps" for CAN 500 kbit/s.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="baud" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Baud rate (symbols per second) for UART ports where baud differs from bitrate. Example: 115200 with unit="Bd".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="standard" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>PHY standard this port implements (e.g., "100base-t1", "1000base-t", "802.3dm", "25gbase-sr"). Free-form string matching IEEE 802.3 clause names.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="protocol" type="xs:string" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Higher-layer protocol(s) the port supports (e.g., "EtherCAT", "PROFINET", "CAN-FD", "Modbus-RTU"). Multiple protocol elements indicate multi-protocol capability.</xs:documentation></xs:annotation>
      </xs:element>
      <!-- PHY -->
      <xs:element name="phy" type="phy_config" minOccurs="0">
        <xs:annotation><xs:documentation>PHY layer configuration (master/slave role). Required for single-pair Ethernet (T1) ports.</xs:documentation></xs:annotation>
      </xs:element>
      <!-- TSN -->
      <xs:element name="tsn" type="tsn_port_capabilities" minOccurs="0">
        <xs:annotation><xs:documentation>TSN sub-standard capabilities supported by this port's hardware.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="macsec" type="macsec_capability" minOccurs="0">
        <xs:annotation><xs:documentation>MACsec hardware cipher suites supported by this port.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="lldp" type="lldp_capability" minOccurs="0">
        <xs:annotation><xs:documentation>LLDP discovery capability including TSN TLV support.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="plca" type="plca_capability" minOccurs="0">
        <xs:annotation><xs:documentation>PLCA multi-drop capability for 10BASE-T1S ports.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="eee" type="eee_capability" minOccurs="0">
        <xs:annotation><xs:documentation>Energy Efficient Ethernet capability.</xs:documentation></xs:annotation>
      </xs:element>
      <!-- Power -->
      <xs:element name="voltage" type="voltage_capability" minOccurs="0">
        <xs:annotation><xs:documentation>Voltage range the port can supply or accept (for power ports and PoDL).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="current" type="current_capability" minOccurs="0">
        <xs:annotation><xs:documentation>Maximum current the port can source or sink.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="power" type="power_capability" minOccurs="0">
        <xs:annotation><xs:documentation>Maximum power the port can deliver or consume.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="typical-power" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Typical power consumption under normal operating conditions. Unit: "W". Used alongside max power for realistic runtime estimation. Max power gives worst-case budget; typical-power gives expected runtime. Example: a motor controller may draw max="120" W during acceleration but typical="35" W during steady operation.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="connector" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Physical connector type (e.g., "RJ45", "M12-D", "XT60", "JST-GH", "USB-C", "SMA"). Free-form string.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <!-- Port -->
  <xs:complexType name="port">
    <xs:annotation><xs:documentation>Physical wired connection interface on a component or switch. The name attribute is the HCDF logical identifier used in link/chain references. The iface attribute is the OS-level interface name (e.g., eth0, swp0, can0) as seen by the device for agent configuration. Contains capabilities describing electrical, protocol, TSN, and power characteristics.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="capabilities" type="port_capabilities" minOccurs="0">
        <xs:annotation><xs:documentation>Hardware capabilities of this port (speeds, protocols, TSN features, power). Optional; omit for ports whose capabilities are implied by type (e.g., simple JTAG/SWD debug ports).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="pose" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Physical location of the port connector on the component as "x y z roll pitch yaw" (meters and radians) relative to the component origin.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="geometry" type="geometry" minOccurs="0">
        <xs:annotation><xs:documentation>Geometry of the port connector for visualization (e.g., a box representing an RJ45 jack).</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required">
      <xs:annotation><xs:documentation>HCDF logical name for this port. Required. Used in link, chain, and bus references to identify connection endpoints (e.g., "eth0", "can_bus", "power_in").</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="iface" type="xs:string">
      <xs:annotation><xs:documentation>OS-level network interface name as seen by the device's operating system (e.g., "eth0", "swp0", "can0", "spi0.1"). Used by runtime agents for interface configuration. Optional; defaults to the HCDF name if not specified.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="type" type="PortType" use="required">
      <xs:annotation><xs:documentation>Physical interface type of this port. Required. Determines the valid capabilities and connection types.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="visual" type="xs:string">
      <xs:annotation><xs:documentation>Name of a visual element on this component whose geometry represents this port in 3D visualization. Alternative to inline geometry.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="mesh" type="xs:string">
      <xs:annotation><xs:documentation>URI of a mesh file representing this port's physical connector shape. Alternative to geometry element.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="electrical" type="xs:string">
      <xs:annotation><xs:documentation>Electrical output type for SIGNAL ports: "push-pull" (drives both high and low — standard for most digital interfaces), "open-drain" (drives low only, requires external pull-up — allows wired-OR/AND with multiple devices on same line, used for interrupt lines, I2C SDA/SCL), "open-collector" (same as open-drain but BJT-based), "tristate" (can be high, low, or high-impedance — used for shared buses). Only relevant for SIGNAL port type. Optional.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="antenna_capabilities">
    <xs:annotation><xs:documentation>Wireless antenna hardware capabilities. Declares supported frequency bands, wireless standards, protocols, gain, and polarization.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="band" type="xs:string" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Supported frequency band (e.g., "2.4GHz", "5GHz", "900MHz", "L1/L2" for GNSS). Multiple band elements for multi-band antennas.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="standard" type="xs:string" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Wireless standard supported (e.g., "802.11ax", "bluetooth-5.3", "lora-1.0.4"). Multiple standards for multi-standard radios.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="protocol" type="xs:string" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Higher-layer wireless protocol (e.g., "DroneCAN", "MAVLink", "DDS", "Zenoh"). Multiple protocol elements for multi-protocol capability.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="gain" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Antenna gain in dBi (decibels relative to isotropic). Higher gain = more directional.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="polarization" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Antenna polarization type (e.g., "RHCP", "LHCP", "linear-vertical", "linear-horizontal", "dual").</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <!-- Antenna -->
  <xs:complexType name="antenna">
    <xs:annotation><xs:documentation>Wireless radio antenna on a component. Used for WiFi, Bluetooth, LoRa, cellular, UWB, GNSS, NFC, and IEEE 802.15.4 connections. Antennas are referenced by name in wireless link definitions.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="capabilities" type="antenna_capabilities" minOccurs="0">
        <xs:annotation><xs:documentation>Wireless capabilities of this antenna (bands, standards, gain, polarization).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="pose" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Physical location and orientation of the antenna on the component as "x y z roll pitch yaw" (meters and radians).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="geometry" type="geometry" minOccurs="0">
        <xs:annotation><xs:documentation>Geometry for visualization of the antenna (e.g., a cylinder for a whip antenna).</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required">
      <xs:annotation><xs:documentation>HCDF logical name for this antenna. Required. Used in wireless link definitions to identify endpoints.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="type" type="AntennaType" use="required">
      <xs:annotation><xs:documentation>Wireless technology type. Required. Determines the valid capabilities and link types.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="visual" type="xs:string">
      <xs:annotation><xs:documentation>Name of a visual element on this component whose geometry represents this antenna.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="mesh" type="xs:string">
      <xs:annotation><xs:documentation>URI of a mesh file representing the antenna's physical shape.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- DYNAMIC SURFACES                                                -->
  <!-- ================================================================ -->

  <xs:complexType name="prop_surface">
    <xs:annotation><xs:documentation>Propeller surface — generates thrust from rotation. Used on multirotors, fixed-wing aircraft, boats, and underwater vehicles. The associated motor provides torque; the propeller converts it to thrust based on diameter, pitch, and blade geometry.</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="diameter" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Propeller diameter tip-to-tip. Unit: "m" or "in".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="pitch" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Propeller pitch — theoretical distance advanced per revolution in ideal fluid. Unit: "m" or "in".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="blades" type="xs:unsignedInt" minOccurs="0">
        <xs:annotation><xs:documentation>Number of blades (typically 2, 3, or 4).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="direction" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Rotation direction viewed from above/front: "CW" (clockwise) or "CCW" (counter-clockwise). Critical for torque balancing on multirotors.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="aerofoil_surface">
    <xs:annotation><xs:documentation>Aerodynamic lifting surface (wing, horizontal stabilizer, canard). Generates lift and drag from airflow over an airfoil cross-section. Key parameters determine flight performance: lift coefficient, stall characteristics, and induced drag.</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="span" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Wing span (tip-to-tip for one wing, or half-span if describing one side). Unit: "m".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="chord" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Mean aerodynamic chord (leading edge to trailing edge). Unit: "m".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="profile" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Airfoil profile designation (e.g., "NACA2412", "NACA0012", "ClarkY", "E387"). Determines lift/drag characteristics.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="sweep" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Wing sweep angle. Positive = swept back. Unit: "deg".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="dihedral" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Wing dihedral angle. Positive = tips higher than root. Affects roll stability. Unit: "deg".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="area" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Wing planform area. Unit: "m2". If omitted, computed from span x chord.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="hydrofoil_surface">
    <xs:annotation><xs:documentation>Hydrodynamic lifting surface — generates lift in water. Used on underwater vehicles (AUVs), hydrofoil boats, and submarine planes. Same principles as aerofoil but in water (much higher fluid density).</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="span" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Foil span. Unit: "m".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="chord" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Mean chord length. Unit: "m".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="profile" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Foil profile (e.g., "NACA0012", "Eppler817").</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="area" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Foil planform area. Unit: "m2".</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="control_surface_def">
    <xs:annotation><xs:documentation>Aerodynamic control surface (aileron, elevon, elevator, rudder, flap, spoiler). A hinged portion of a wing or tail that deflects to change aerodynamic forces. The joint connecting this comp defines the hinge axis; this element defines the aerodynamic properties.</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="chord-ratio" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Ratio of control surface chord to parent wing/tail chord (0-1). Typical: 0.2-0.3 for ailerons, 0.3-0.5 for flaps.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="span-fraction" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Fraction of parent wing span covered by this control surface (0-1).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="deflection" type="range_value" minOccurs="0">
        <xs:annotation><xs:documentation>Deflection range. min = max deflection in one direction, max = other direction. Unit: "deg". Example: min="-25" max="25".</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
    <xs:attribute name="type" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Control surface type: "aileron", "elevator", "rudder", "elevon", "flaperon", "flap", "spoiler", "canard", "ruddervator", "v-tail".</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="wheel_surface">
    <xs:annotation><xs:documentation>Wheel ground contact surface. Defines the tire/wheel geometry and friction properties for ground vehicles. The motor driving this wheel is defined separately; the wheel surface describes the contact interface with the ground.</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="radius" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Wheel outer radius (including tire). Unit: "m".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="width" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Tire/wheel width (contact patch width). Unit: "m".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="friction" type="friction" minOccurs="0">
        <xs:annotation><xs:documentation>Tire-ground friction coefficients (static and dynamic).</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
    <xs:attribute name="type" type="xs:string">
      <xs:annotation><xs:documentation>Wheel type: "driven" (has motor), "steering" (steerable), "caster" (passive swivel), "omni" (omnidirectional rollers), "mecanum" (45-degree rollers). Optional.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="track_surface">
    <xs:annotation><xs:documentation>Tracked vehicle surface (tank treads, rubber tracks). Defines the track geometry and ground contact properties. Used for high-traction vehicles on rough terrain.</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="width" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Track width. Unit: "m".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="length" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Track ground contact length. Unit: "m".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="ground-pressure" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Ground pressure (vehicle weight / total track contact area). Unit: "kPa". Lower = better soft terrain performance.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="friction" type="friction" minOccurs="0">
        <xs:annotation><xs:documentation>Track-ground friction coefficients.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
  </xs:complexType>

  <!-- Surface container: one or more dynamic surfaces on a component -->
  <xs:complexType name="surface_element">
    <xs:annotation><xs:documentation>Dynamic surface that interacts with the environment (air, water, or ground). Includes aerodynamic surfaces (wings, control surfaces, propellers), hydrodynamic surfaces (hydrofoils), and ground contact surfaces (wheels, tracks). Each surface has a name and contains exactly one surface type definition. The comp's joints define the actuation (hinge axes, deflection); the surface defines the physical interaction properties.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="prop" type="prop_surface" minOccurs="0">
        <xs:annotation><xs:documentation>Propeller surface — thrust from rotation.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="aerofoil" type="aerofoil_surface" minOccurs="0">
        <xs:annotation><xs:documentation>Aerodynamic lifting surface — wing, stabilizer, canard.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="hydrofoil" type="hydrofoil_surface" minOccurs="0">
        <xs:annotation><xs:documentation>Hydrodynamic lifting surface — underwater foil.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="control-surface" type="control_surface_def" minOccurs="0">
        <xs:annotation><xs:documentation>Aerodynamic control surface — aileron, elevator, rudder, elevon, flap.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="wheel" type="wheel_surface" minOccurs="0">
        <xs:annotation><xs:documentation>Wheel ground contact surface.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="track" type="track_surface" minOccurs="0">
        <xs:annotation><xs:documentation>Tracked vehicle surface (tank treads).</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Unique name for this surface within the component.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="visual" type="xs:string">
      <xs:annotation><xs:documentation>Name of the visual element containing this surface's mesh for 3D highlighting.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="mesh" type="xs:string">
      <xs:annotation><xs:documentation>GLTF mesh node name within the visual for 3D highlighting of this surface.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- POWER / ENERGY SOURCES                                          -->
  <!-- ================================================================ -->

  <xs:complexType name="battery_source">
    <xs:annotation><xs:documentation>Rechargeable battery energy source. Defines cell configuration, chemistry, capacity, and discharge limits. An agent uses this to compute runtime (energy / total power consumption) and validate that bus voltage stays within all consumers' operating range throughout discharge.</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="chemistry" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Cell chemistry: "LiFePO4" (3.2V/cell, safest, longest life), "Li-ion" (3.7V/cell, highest energy density), "LiPo" (3.7V/cell, high discharge rate), "NiMH" (1.2V/cell), "lead-acid" (2.0V/cell).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="cells-series" type="xs:unsignedInt" minOccurs="0">
        <xs:annotation><xs:documentation>Number of cells in series (determines voltage: cells x cell_voltage). Example: 8S LiFePO4 = 25.6V nominal.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="cells-parallel" type="xs:unsignedInt" minOccurs="0">
        <xs:annotation><xs:documentation>Number of cells in parallel (multiplies capacity and max current).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="nominal-voltage" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Nominal pack voltage. Unit: "V". Equals cells-series x cell nominal voltage.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="capacity" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Battery capacity. Unit: "Ah" (amp-hours). Energy = capacity x nominal-voltage.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="energy" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Total stored energy. Unit: "Wh" (watt-hours). Can be computed from capacity x voltage but useful to state explicitly.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="max-discharge" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Maximum continuous discharge rate. Unit: "C" (multiples of capacity). Example: 3C on a 12Ah pack = 36A max continuous.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="min-voltage" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Minimum safe pack voltage (low-voltage cutoff). Unit: "V". Discharging below this damages the cells.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="max-voltage" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Maximum charge voltage (full charge). Unit: "V".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="max-charge-rate" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Maximum charge rate. Unit: "C" (multiples of capacity). Example: 1C on 12Ah = 12A max charge current. Fast-charge capable batteries may support 2-4C. Determines minimum charge time: time_hours = 1/charge_rate_C.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="charge-protocol" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Charging protocol: "cc-cv" (constant-current then constant-voltage — standard for Li-ion/LiPo/LiFePO4), "cc" (constant-current only — NiMH, NiCd), "fast-charge" (proprietary fast-charge protocol), "trickle" (low-rate maintenance charge). Determines charger compatibility.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="cycle-life" type="xs:unsignedInt" minOccurs="0">
        <xs:annotation><xs:documentation>Rated cycle life — number of charge/discharge cycles to 80% capacity retention. LiFePO4: 2000-5000 cycles. Li-ion: 300-500. LiPo: 200-300. An agent can estimate remaining battery health.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="flow_characterization">
    <xs:annotation><xs:documentation>Flow characterization for a fuel/gas tank — how fluid exits the tank and at what rate. Without this, a tank is just a container; the flow characterization tells an agent how fast energy can be delivered to consumers. An agent uses this to compute: max power delivery (flow_rate x energy_density), surge capability (peak flow for acceleration transients), and runtime at load (volume x density / operating_flow_rate).</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="method" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>How fluid exits the tank: "pressurized" (self-pressurizing from stored pressure, passive — e.g., compressed gas through orifice), "regulated" (pressure regulator controls outlet pressure, active or passive mechanical — e.g., hydrogen fuel cell supply), "pumped" (electric or mechanical pump draws fluid — e.g., gasoline fuel pump), "gravity" (gravity-fed, no pressurization — e.g., open agricultural spray tanks).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="outlet-pressure" type="range_value" minOccurs="0">
        <xs:annotation><xs:documentation>Pressure at the tank outlet / consumer input. For regulated systems this is the regulated setpoint; for pressurized systems it decreases as the tank empties. Use min/max to capture the range. Unit: "bar" or "psi". Example: min="1.5" max="3.0" unit="bar" for a regulated hydrogen supply.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="max-flow-rate" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Maximum sustained (continuous) flow rate the delivery system can provide. Unit depends on fluid: "g/s" or "kg/s" for gases, "L/min" or "L/hr" for liquids, "SLPM" (standard liters per minute) for compressed gases at standard conditions. This is the continuous limit — determined by regulator capacity, pump displacement, or orifice size.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="peak-flow-rate" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Peak (burst) flow rate available for short transients. May exceed max-flow-rate for seconds due to accumulator pressure, pump overspeed, or regulator overshoot. Unit: same as max-flow-rate. If not specified, assume peak = max (no burst capability).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="regulator" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Regulation mechanism controlling outlet pressure and/or flow: "passive-mechanical" (spring-loaded diaphragm regulator — simple, no power needed), "solenoid-proportional" (electronically controlled proportional valve — precise, needs power), "solenoid-on-off" (bang-bang valve — simple digital control), "return-line" (fuel pump + return line to tank — common in automotive), "none" (unregulated — pressure drops as tank empties).</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="tank_source">
    <xs:annotation><xs:documentation>Fuel/gas tank energy source. For combustion engines, hydrogen fuel cells, compressed air systems, or pneumatic actuators. Defines fuel type, volume, pressure, energy content, and flow characterization (how fluid exits and at what rate). An agent needs both capacity (how much energy is stored) and flow (how fast it can be delivered) to compute runtime and power capability.</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="fuel" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Fuel type: "gasoline", "diesel", "hydrogen", "compressed-air", "nitrogen", "propane", "ethanol", "jet-a". Determines energy density and handling requirements.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="volume" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Tank volume. Unit: "L" (liters) or "gal" (US gallons).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="pressure" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Storage pressure (for compressed gases). Unit: "bar" or "psi". Example: 350 bar for hydrogen, 200 bar for compressed air.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="energy" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Total stored energy. Unit: "Wh" or "kJ".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="flow" type="flow_characterization" minOccurs="0">
        <xs:annotation><xs:documentation>Flow characterization — how fluid exits the tank and at what rate. Defines delivery method (pressurized, regulated, pumped, gravity), outlet pressure, max/peak flow rates, and regulation mechanism. Without this, the tank is just a capacity number with no delivery information.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="fuel_cell">
    <xs:annotation><xs:documentation>Fuel cell energy source — converts chemical fuel (hydrogen, methanol, etc.) directly to electricity through electrochemical reaction. Unlike batteries (stored charge) or tanks (stored fuel for combustion), fuel cells continuously generate electricity as long as fuel is supplied. The tank element should describe the fuel storage; the fuel cell describes the conversion.</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="type" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Fuel cell technology: "pem" (Proton Exchange Membrane — most common for robots, uses hydrogen), "dmfc" (Direct Methanol — uses methanol, lower power density), "sofc" (Solid Oxide — high temp, high efficiency, slow startup).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="fuel" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Input fuel type: "hydrogen", "methanol", "natural-gas", "propane".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="rated-power" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Continuous rated electrical power output. Unit: "W" or "kW".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="peak-power" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Peak (burst) electrical power output. Unit: "W" or "kW".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="efficiency" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Electrical conversion efficiency as a fraction (0-1). PEM typical: 0.40-0.60. SOFC typical: 0.50-0.65.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="output-voltage" type="range_value" minOccurs="0">
        <xs:annotation><xs:documentation>Output voltage range. Unit: "V". Fuel cell output varies with load — min at max power, max at no load.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="power_source">
    <xs:annotation><xs:documentation>Energy source on a component. Contains one or more source types (battery, tank, fuel-cell). An agent computes runtime, power budget, and weight impact from this data. The component's POWER port defines the electrical output; the power-source defines the stored energy.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="battery" type="battery_source" minOccurs="0">
        <xs:annotation><xs:documentation>Rechargeable battery energy source.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="tank" type="tank_source" minOccurs="0">
        <xs:annotation><xs:documentation>Fuel/gas tank energy source.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="fuel-cell" type="fuel_cell" minOccurs="0">
        <xs:annotation><xs:documentation>Fuel cell energy converter (PEM, DMFC, SOFC). Generates electricity from fuel continuously.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Unique name for this power source.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="role" type="xs:string">
      <xs:annotation><xs:documentation>Power source role in the system: "primary" (main power source), "backup" (engaged on primary failure), "hot-swap" (can be replaced while system runs on other source), "ups" (uninterruptible — provides power during switchover). An agent uses this for power redundancy analysis.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="group" type="xs:string">
      <xs:annotation><xs:documentation>Power source group name for failover pairing. Sources in the same group can substitute for each other. Example: group="main" on two hot-swap batteries means either can power the system alone while the other is replaced.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="visual" type="xs:string">
      <xs:annotation><xs:documentation>Name of the visual element containing this power source's mesh for 3D highlighting.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="mesh" type="xs:string">
      <xs:annotation><xs:documentation>GLTF mesh node name within the visual for 3D highlighting of this power source.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- HMI (Human-Machine Interface)                                   -->
  <!-- ================================================================ -->

  <xs:simpleType name="HmiType">
    <xs:annotation><xs:documentation>Human-Machine Interface element type. display: visual output (LCD, OLED, LED matrix, e-ink). speaker: audio output (speaker, buzzer, piezo). led-status: status indicator LED(s) (on/off, color). led-illumination: scene illumination (headlights, work lights, IR illumination for night vision cameras). button: physical pushbutton or switch input. touchscreen: combined display + touch input. indicator: generic visual/audio indicator.</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="display"/>
      <xs:enumeration value="speaker"/>
      <xs:enumeration value="buzzer"/>
      <xs:enumeration value="led-status"/>
      <xs:enumeration value="led-illumination"/>
      <xs:enumeration value="button"/>
      <xs:enumeration value="touchscreen"/>
      <xs:enumeration value="indicator"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:complexType name="hmi_element">
    <xs:annotation><xs:documentation>Human-Machine Interface element — displays, speakers, buttons, LEDs, and other devices for human interaction or scene manipulation. Unlike sensors (which observe) and motors (which actuate mechanisms), HMI elements communicate with humans or modify the visual/acoustic environment. Examples: status LEDs on a robot body, a speaker for audio alerts, a touchscreen for operator control, IR illumination LEDs for night-vision cameras, an e-stop button.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="description" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Human-readable description of this HMI element.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="pose" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Position and orientation relative to component origin.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="geometry" type="geometry" minOccurs="0">
        <xs:annotation><xs:documentation>Visualization geometry for this HMI element.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Unique name for this HMI element within the component.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="type" type="HmiType" use="required">
      <xs:annotation><xs:documentation>HMI element type (display, speaker, buzzer, led-status, led-illumination, button, touchscreen, indicator).</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="visual" type="xs:string">
      <xs:annotation><xs:documentation>Name of the visual element containing this HMI's mesh for 3D highlighting.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="mesh" type="xs:string">
      <xs:annotation><xs:documentation>GLTF mesh node name within the visual for 3D highlighting.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- SENSORS                                                         -->
  <!-- ================================================================ -->

  <xs:complexType name="axis_align">
    <xs:annotation><xs:documentation>Axis alignment mapping from a sensor's internal coordinate frame to the component's body frame. Used to correct for sensors mounted in non-standard orientations without changing the pose.</xs:documentation></xs:annotation>
    <xs:attribute name="x" type="AxisValue" default="X">
      <xs:annotation><xs:documentation>Which body-frame axis the sensor's X axis maps to. Default: X (no remapping).</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="y" type="AxisValue" default="Y">
      <xs:annotation><xs:documentation>Which body-frame axis the sensor's Y axis maps to. Default: Y (no remapping).</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="z" type="AxisValue" default="Z">
      <xs:annotation><xs:documentation>Which body-frame axis the sensor's Z axis maps to. Default: Z (no remapping).</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="sensor_driver">
    <xs:annotation><xs:documentation>Sensor driver identification and configuration. Maps the physical sensor to a software driver by name and provides axis alignment correction for the driver's coordinate frame.</xs:documentation></xs:annotation>
    <xs:sequence><xs:element name="axis-align" type="axis_align" minOccurs="0">
      <xs:annotation><xs:documentation>Axis remapping from sensor internal axes to component body frame. Optional; omit if sensor axes match body frame.</xs:documentation></xs:annotation>
    </xs:element></xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Driver identifier string used by the runtime to load the correct sensor driver (e.g., "bmi088", "icm42688p", "bmp390"). Required.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- FIFO configuration for sensors with hardware sample buffering -->
  <xs:complexType name="fifo_config">
    <xs:annotation><xs:documentation>Hardware FIFO (First-In-First-Out) buffer configuration. Many sensors (IMUs, ADCs) collect samples into a hardware FIFO and trigger an interrupt when the watermark level is reached. This reduces interrupt overhead and allows burst processing. Effective update rate = ODR / watermark.</xs:documentation></xs:annotation>
    <xs:attribute name="depth" type="xs:unsignedInt">
      <xs:annotation><xs:documentation>Maximum FIFO depth in samples (hardware limit, e.g., 256 for ICM45686, 512 for BMI088). This is the total buffer capacity before overflow.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="watermark" type="xs:unsignedInt">
      <xs:annotation><xs:documentation>Watermark level in samples — interrupt fires when this many samples have accumulated. Controls the effective processing rate: effective_rate = ODR / watermark. Example: ODR=3200Hz, watermark=8 → 400Hz interrupt rate, 8 samples per burst.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- Sensor measurement parameters for a single axis/channel (e.g., accel, gyro) -->
  <xs:complexType name="sensor_params">
    <xs:annotation><xs:documentation>Measurement parameters for a sensor axis or channel. Defines the operating range, resolution, sampling rate (ODR), anti-aliasing filter bandwidth, FIFO configuration, and noise model. ODR and bandwidth are distinct: ODR is the hardware sampling rate, bandwidth is the LPF cutoff frequency. The effective processing rate depends on ODR and FIFO watermark.</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="range" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Full-scale measurement range (e.g., 16 with unit="g" for +/-16g accelerometer, 2000 with unit="dps" for gyroscope).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="resolution" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Measurement resolution — smallest detectable change (e.g., 0.488 with unit="mg" for 16-bit at 16g range).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="odr" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Output Data Rate — hardware sampling frequency in Hz. This is how fast the ADC converts, regardless of how often software processes the data. Example: 3200 with unit="Hz". Determines Nyquist frequency (odr/2) and aliasing behavior.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="bandwidth" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Anti-aliasing low-pass filter cutoff frequency in Hz. Determines the useful signal bandwidth. Typically at or below ODR/2 (Nyquist). Example: 1600 with unit="Hz" for ODR=3200Hz. Lower bandwidth reduces noise but limits frequency response.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="fifo" type="fifo_config" minOccurs="0">
        <xs:annotation><xs:documentation>Hardware FIFO buffer configuration. When present, the sensor collects samples at ODR rate into a buffer and interrupts at ODR/watermark rate. Example: ODR=3200Hz, fifo watermark=8 → 400Hz interrupt rate delivering 8 samples per burst.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="noise" type="noise" minOccurs="0">
        <xs:annotation><xs:documentation>Noise model for this measurement axis. Includes spectral density (stddev), bias instability (bias-mean, bias-stddev), and quantization precision.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
  </xs:complexType>

  <!-- Base sensor type: common elements shared by em, rf, chemical, force sensors.
       Inertial and optical sensors have unique children so they don't extend this. -->
  <!-- Data output: bandwidth and frame size for network planning -->
  <xs:complexType name="data_output">
    <xs:annotation><xs:documentation>Sensor data output characteristics for network bandwidth planning. An agent uses this to validate that network links and TSN schedules can carry the sensor's data. Only relevant for high-bandwidth sensors (cameras, lidars, radars) that transmit over the network. Not needed for low-bandwidth sensors (IMU, baro, mag) connected via SPI/I2C.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="bandwidth" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Raw output data rate. Unit: "Mbps" or "Gbps". Example: 7000 Mbps for 1920x1080 RGB at 30fps uncompressed. This is the maximum bandwidth the sensor can produce.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="bandwidth-compressed" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Compressed output data rate when hardware compression is enabled. Unit: "Mbps". Example: 20 Mbps for H.265 compressed 1080p@30fps. If the sensor outputs compressed data over the network, use this for bandwidth planning instead of raw bandwidth.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="frame-size" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Size of a single output frame/scan. Unit: "bytes". Example: 6220800 for 1920x1080x3 RGB frame. Used with update-rate to calculate bandwidth: frame-size x update-rate = bandwidth.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <!-- Base sensor type: universal elements shared by all sensor subtypes.
       ODR/bandwidth/FIFO are NOT here — they belong in sensor_params (accel/gyro only).
       Most sensors (GNSS, gas, mag, pressure) don't have hardware FIFO or configurable ODR. -->
  <xs:complexType name="sensor_base">
    <xs:annotation><xs:documentation>Base sensor type with elements common to ALL sensor subtypes: pose, driver, range, resolution, noise, data output, and geometry. Extended by em, rf, chemical, force, and encoder sensor types. ODR/bandwidth/FIFO are NOT included here — those are specific to high-rate inertial sensors and live in sensor_params (accel/gyro blocks).</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="pose" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Pose of the sensor relative to the component origin as "x y z roll pitch yaw" (meters and radians).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="driver" type="sensor_driver" minOccurs="0">
        <xs:annotation><xs:documentation>Driver IC identification and axis alignment configuration.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="range" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Full-scale measurement range with unit.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="resolution" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Measurement resolution — smallest detectable change.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="noise" type="noise" minOccurs="0">
        <xs:annotation><xs:documentation>Noise model for the sensor output.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="data-output" type="data_output" minOccurs="0">
        <xs:annotation><xs:documentation>Output bandwidth and frame size for network planning. Only needed for sensors that transmit significant data over the network (cameras, lidars, radars).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="geometry" type="geometry" minOccurs="0">
        <xs:annotation><xs:documentation>Visualization geometry for the sensor.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="camera_intrinsics">
    <xs:annotation><xs:documentation>Camera intrinsic parameters following the pinhole camera model. Defines image dimensions, pixel format, and focal length/principal point for projection calculations.</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="width" type="xs:unsignedInt" minOccurs="0">
        <xs:annotation><xs:documentation>Image width in pixels.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="height" type="xs:unsignedInt" minOccurs="0">
        <xs:annotation><xs:documentation>Image height in pixels.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="format" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Pixel format string (e.g., "RGB8", "MONO8", "YUYV", "BAYER_RGGB8", "DEPTH_FLOAT32").</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="fx" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Focal length in pixels along the X axis (horizontal).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="fy" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Focal length in pixels along the Y axis (vertical).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="cx" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Principal point X coordinate in pixels (typically image_width / 2).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="cy" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Principal point Y coordinate in pixels (typically image_height / 2).</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="camera_distortion">
    <xs:annotation><xs:documentation>Camera lens distortion parameters following the Brown-Conrady model. Used by vision pipelines to undistort images.</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="k1" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>First radial distortion coefficient. Positive = barrel distortion, negative = pincushion.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="k2" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Second radial distortion coefficient.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="k3" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Third radial distortion coefficient (for wide-angle lenses).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="p1" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>First tangential distortion coefficient (decentering).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="p2" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Second tangential distortion coefficient (decentering).</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="camera_calibration">
    <xs:annotation><xs:documentation>Camera calibration results from an actual calibration procedure on a specific unit. Distinct from the design-spec intrinsics/distortion: those are nominal datasheet values, while calibration contains measured values for this particular camera+lens assembly. An agent doing visual servoing, SLAM, or stereo depth must use the calibrated values. If calibration is present, it overrides the design-spec intrinsics and distortion for runtime use.</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="fx" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Calibrated focal length in pixels along X axis. Overrides intrinsics/fx for runtime use.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="fy" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Calibrated focal length in pixels along Y axis. Overrides intrinsics/fy.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="cx" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Calibrated principal point X in pixels. Often differs from image center by several pixels due to lens/sensor alignment.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="cy" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Calibrated principal point Y in pixels.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="k1" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Calibrated radial distortion coefficient k1.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="k2" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Calibrated radial distortion coefficient k2.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="k3" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Calibrated radial distortion coefficient k3 (for wide-angle lenses).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="p1" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Calibrated tangential distortion coefficient p1.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="p2" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Calibrated tangential distortion coefficient p2.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="reprojection-error" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>RMS reprojection error from the calibration — the quality metric. Unit: "px" (pixels). Values below 0.5 px are excellent; 0.5-1.0 px is good; above 1.0 px suggests the calibration should be redone. An agent can use this to assess confidence in the calibration.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="date" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Date the calibration was performed in ISO 8601 format (YYYY-MM-DD). An agent can flag stale calibrations (e.g., older than 6 months or after a lens change).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="temperature" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Ambient temperature during calibration. Unit: "degC". Focal length varies with temperature due to thermal expansion of the lens and mount — calibrations at 20°C may not be accurate at -10°C or 50°C.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="method" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Calibration method and target used. Examples: "checkerboard-8x6-30mm" (8x6 inner corners, 30mm square size), "charuco-5x7-40mm" (ChArUco board), "apriltag-6x6-50mm", "circle-grid-4x11-asymmetric". Records how the calibration was done for reproducibility.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="images" type="xs:unsignedInt" minOccurs="0">
        <xs:annotation><xs:documentation>Number of calibration images used. More images generally means better coverage of the image plane and more reliable results. Typical: 20-50 images from diverse angles.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="sensor_fov">
    <xs:annotation><xs:documentation>Field-of-view definition for an optical sensor. Each FoV represents a distinct sensing cone/pyramid (e.g., a stereo camera has two FoVs). Contains the FoV geometry, design-spec intrinsics, distortion model, calibration results, and noise parameters. The intrinsics/distortion elements hold nominal datasheet values; the calibration element holds measured values from an actual calibration on this specific unit. If calibration is present, agents should use it over the design specs.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="description" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Human-readable description of this FoV (e.g., "left stereo camera", "forward-facing depth").</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="pose" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Pose of the FoV origin relative to the sensor origin as "x y z roll pitch yaw" (meters and radians). For stereo cameras, this encodes the baseline offset.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="geometry" type="geometry" minOccurs="0">
        <xs:annotation><xs:documentation>FoV volume geometry for visualization. Typically a frustum (conical or pyramidal).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="intrinsics" type="camera_intrinsics" minOccurs="0">
        <xs:annotation><xs:documentation>Design-spec camera intrinsic parameters (focal length, principal point, image size) from the datasheet. For calibrated values, use the calibration element instead.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="distortion" type="camera_distortion" minOccurs="0">
        <xs:annotation><xs:documentation>Design-spec lens distortion coefficients (Brown-Conrady model). For calibrated values, use the calibration element instead.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="calibration" type="camera_calibration" minOccurs="0">
        <xs:annotation><xs:documentation>Measured calibration results for this specific camera unit. Contains calibrated intrinsics (fx, fy, cx, cy), distortion coefficients (k1-k3, p1-p2), reprojection error, calibration date, temperature, and method. When present, agents should use these values instead of the design-spec intrinsics/distortion.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="noise" type="noise" minOccurs="0">
        <xs:annotation><xs:documentation>Per-pixel noise model for this FoV (e.g., depth noise for ToF sensors).</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Unique name for this FoV within the sensor (e.g., "left", "right", "depth", "rgb"). Required.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="color" type="xs:string">
      <xs:annotation><xs:documentation>Visualization color for the FoV cone in the 3D viewer (e.g., "0.2 0.8 0.2 0.3" for translucent green RGBA).</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- ===== Sensor-specific parameter blocks ===== -->

  <xs:complexType name="camera_params">
    <xs:annotation><xs:documentation>Camera-specific parameters affecting perception pipeline design, bandwidth planning, and environmental capability. Applies to optical sensors with type="camera" or type="thermal".</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="shutter" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Shutter type: "global" (all pixels exposed simultaneously — no motion blur, required for high-speed robotics) or "rolling" (rows exposed sequentially — causes skew/wobble on fast motion, acceptable for slow scenes).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="hdr" type="xs:boolean" minOccurs="0">
        <xs:annotation><xs:documentation>High Dynamic Range capability. true = can capture indoor shadows and outdoor sunlight in one frame. Critical for robots transitioning between lighting conditions.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="dynamic-range" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Dynamic range. Unit: "dB". Standard: 60dB. HDR: 120dB+.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="depth-range" type="range_value" minOccurs="0">
        <xs:annotation><xs:documentation>For depth/RGBD cameras: usable depth measurement range. min = closest, max = farthest. Unit: "m".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="compression" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Output compression: "raw" (uncompressed, highest bandwidth — 1080p@30fps is ~1.5Gbps), "jpeg" (lossy per-frame), "h264" (lossy inter-frame), "h265" (best compression, ~5-20Mbps for 1080p). Affects network bandwidth requirements.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="trigger" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Trigger mode: "free-running" (camera controls timing), "hardware" (external GPIO triggers capture — needed for multi-camera synchronization), "software" (software command triggers).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="ir-cut" type="xs:boolean" minOccurs="0">
        <xs:annotation><xs:documentation>IR cut filter present. true = blocks infrared (standard color camera). false = passes IR (for night vision with IR illumination or NIR sensing).</xs:documentation></xs:annotation>
      </xs:element>
      <!-- Thermal camera specific -->
      <xs:element name="spectral-band" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Infrared spectral band for thermal cameras: "LWIR" (8-14um, most common, uncooled), "MWIR" (3-5um, cooled, higher sensitivity), "SWIR" (1-3um, see through fog/smoke). Not applicable for visible cameras.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="netd" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Noise Equivalent Temperature Difference — thermal camera sensitivity. Lower = better. Unit: "mK". Typical uncooled LWIR: 40-60mK. Cooled MWIR: 15-25mK.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="temperature-range" type="range_value" minOccurs="0">
        <xs:annotation><xs:documentation>Calibrated temperature measurement range for thermal cameras. Unit: "degC". Example: min="-20" max="150" for industrial, min="-40" max="500" for high-temp.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="lidar_params">
    <xs:annotation><xs:documentation>Lidar-specific parameters defining scan geometry, point cloud density, and environmental robustness. Applies to optical sensors with type="lidar".</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="scan-type" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Scanning mechanism: "mechanical" (spinning head — 360° FOV but vibration-sensitive, has wear parts), "solid-state" (no moving parts, limited FOV, very robust), "mems" (MEMS mirror, compact, moderate FOV), "flash" (illuminates entire scene at once, short range, no scanning).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="channels" type="xs:unsignedInt" minOccurs="0">
        <xs:annotation><xs:documentation>Number of vertical channels (laser/detector pairs). More = denser vertical coverage. Typical: 16, 32, 64, 128.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="points-per-second" type="xs:unsignedInt" minOccurs="0">
        <xs:annotation><xs:documentation>Total point measurement rate. Determines point cloud density and downstream processing/bandwidth. Example: 300000 (Livox Mid-360), 1200000 (Hesai XT32).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="scan-rate" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Frame/rotation rate. For mechanical: rotations per second. For solid-state: frame rate. Unit: "Hz". Typical: 10-20.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="returns" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Return mode: "single" (first or strongest only), "dual" (first + strongest), "triple" (first + second + strongest). Multi-return sees through rain, dust, and vegetation.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="wavelength" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Laser wavelength. 905nm = common, lower cost, affected by sunlight. 1550nm = eye-safe at higher power, better rain/fog penetration, more expensive. Unit: "nm".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="horizontal-fov" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Horizontal field of view. 360 for spinning lidars, 60-120 for solid-state. Unit: "deg".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="vertical-fov" type="range_value" minOccurs="0">
        <xs:annotation><xs:documentation>Vertical field of view as min/max angle. Example: min="-25" max="15" unit="deg".</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="radar_params">
    <xs:annotation><xs:documentation>Radar-specific parameters for 4D imaging radar and distance/velocity sensing. Applies to rf sensors with type="radar".</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="frequency" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Operating frequency. 77-79GHz = automotive standard (high resolution). 24GHz = industrial (longer range, lower resolution). Unit: "GHz".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="modulation" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Modulation scheme: "fmcw" (Frequency-Modulated Continuous Wave — automotive standard, measures range + velocity simultaneously) or "pulsed" (traditional, longer range).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="azimuth-fov" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Horizontal field of view. Unit: "deg". Typical: 120 short-range, 20 long-range.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="elevation-fov" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Vertical field of view (4D imaging radar). Unit: "deg". Presence indicates elevation-capable radar.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="azimuth-resolution" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Azimuth angular resolution — minimum angle to separate two targets horizontally. Unit: "deg".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="elevation-resolution" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Elevation angular resolution. Unit: "deg".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="range-resolution" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Range resolution — minimum distance to separate two targets at the same angle. Unit: "m". Determined by chirp bandwidth.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="velocity-range" type="range_value" minOccurs="0">
        <xs:annotation><xs:documentation>Maximum measurable radial velocity. Unit: "m/s".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="velocity-resolution" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Velocity resolution — minimum speed difference to separate two targets. Unit: "m/s".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="max-detections" type="xs:unsignedInt" minOccurs="0">
        <xs:annotation><xs:documentation>Maximum simultaneous target detections per frame.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="mimo" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>MIMO antenna configuration as "NtxMrx" (e.g., "3tx4rx" = 12 virtual channels). More virtual channels = better angular resolution.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="gnss_params">
    <xs:annotation><xs:documentation>GNSS receiver-specific parameters defining constellation support, correction capabilities, and positioning accuracy. Applies to rf sensors with type="gnss".</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="constellation" type="xs:string" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Supported satellite constellation: GPS, GLONASS, Galileo, BeiDou, QZSS, NavIC. More = better urban canyon performance.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="frequency" type="xs:string" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Supported frequency band: L1, L2, L5, E1, E5a, E5b, B1, B2. Multi-frequency enables ionospheric correction.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="rtk" type="xs:boolean" minOccurs="0">
        <xs:annotation><xs:documentation>RTK (Real-Time Kinematic) capable. true = cm-level positioning with base station or NTRIP corrections.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="accuracy-standalone" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Horizontal accuracy without corrections (CEP50). Unit: "m". Typical: 1.5m single-freq, 1.0m multi-freq.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="accuracy-rtk" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Horizontal accuracy with RTK fix. Unit: "m". Typical: 0.01-0.02m.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="pps" type="xs:boolean" minOccurs="0">
        <xs:annotation><xs:documentation>Pulse-Per-Second output for precise time synchronization. Can serve as time reference for gPTP or sensor timestamping.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="dead-reckoning" type="xs:boolean" minOccurs="0">
        <xs:annotation><xs:documentation>Built-in dead reckoning with IMU fusion for GNSS-denied environments (tunnels, urban canyons).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="anti-spoofing" type="xs:boolean" minOccurs="0">
        <xs:annotation><xs:documentation>Anti-spoofing capability. Detects and rejects fake GNSS signals.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <!-- ===== Sensor subtypes ===== -->
  <xs:complexType name="inertial_sensor">
    <xs:annotation><xs:documentation>Inertial measurement sensor (accelerometer, gyroscope, or combined IMU). Contains pose, driver identification, and separate parameter blocks for accelerometer and gyroscope axes.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="pose" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Pose of the inertial sensor relative to the sensor group origin as "x y z roll pitch yaw" (meters and radians).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="driver" type="sensor_driver" minOccurs="0">
        <xs:annotation><xs:documentation>Driver identification and axis alignment for the inertial sensor IC.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="accel" type="sensor_params" minOccurs="0">
        <xs:annotation><xs:documentation>Accelerometer measurement parameters (range in g, resolution, noise, bandwidth). Present when type is "accel" or "accel_gyro".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="gyro" type="sensor_params" minOccurs="0">
        <xs:annotation><xs:documentation>Gyroscope measurement parameters (range in deg/s, resolution, noise, bandwidth). Present when type is "gyro" or "accel_gyro".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="geometry" type="geometry" minOccurs="0">
        <xs:annotation><xs:documentation>Geometry for visualizing the inertial sensor package.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="type" type="InertialSensorType" use="required">
      <xs:annotation><xs:documentation>Inertial sensor sub-type. Required. Determines which parameter sub-elements (accel, gyro) are expected.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="em_sensor">
    <xs:annotation><xs:documentation>Electromagnetic field sensor (magnetometer, metal detector, eddy current probe, EMF sensor). Extends sensor_base with all common elements (pose, driver, range, resolution, ODR, bandwidth, FIFO, noise, geometry).</xs:documentation></xs:annotation>
    <xs:complexContent>
      <xs:extension base="sensor_base">
        <xs:attribute name="type" type="EmSensorType" use="required">
          <xs:annotation><xs:documentation>Electromagnetic sensor sub-type (mag, metal_detector, eddy_current, emf). Required.</xs:documentation></xs:annotation>
        </xs:attribute>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="optical_sensor">
    <xs:annotation><xs:documentation>Optical sensor (camera, lidar, ToF, optical flow). Contains one or more field-of-view definitions, each with its own intrinsics, distortion, and noise model.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="pose" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Pose of the optical sensor module relative to the sensor group origin as "x y z roll pitch yaw" (meters and radians).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="driver" type="sensor_driver" minOccurs="0">
        <xs:annotation><xs:documentation>Driver identification for the optical sensor (e.g., "oak-d-pro", "rplidar-a2", "vl53l5cx").</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="geometry" type="geometry" minOccurs="0">
        <xs:annotation><xs:documentation>Geometry for visualizing the optical sensor housing.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="fov" type="sensor_fov" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Field-of-view definition(s). One per sensing cone/pyramid. Stereo cameras have two FoVs; omnidirectional lidars may have one 360-degree FoV.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="data-output" type="data_output" minOccurs="0">
        <xs:annotation><xs:documentation>Output bandwidth for network planning. Cameras and lidars generate significant data — an agent uses this to validate TSN schedules and link capacity.</xs:documentation></xs:annotation>
      </xs:element>
      <!-- Type-specific parameter blocks (use the one matching your type) -->
      <xs:element name="camera-params" type="camera_params" minOccurs="0">
        <xs:annotation><xs:documentation>Camera-specific parameters (shutter, HDR, compression, trigger, thermal specs). Use when type="camera" or type="thermal".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="lidar-params" type="lidar_params" minOccurs="0">
        <xs:annotation><xs:documentation>Lidar-specific parameters (scan-type, channels, points-per-second, returns, wavelength). Use when type="lidar".</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="type" type="OpticalSensorType" use="required">
      <xs:annotation><xs:documentation>Optical sensor sub-type (camera, thermal, lidar, tof, optical_flow). Required.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="rf_sensor">
    <xs:annotation><xs:documentation>Radio-frequency sensor (GNSS receiver, UWB ranger, radar, radio altimeter). Extends sensor_base with type-specific parameter blocks for radar and GNSS.</xs:documentation></xs:annotation>
    <xs:complexContent>
      <xs:extension base="sensor_base">
        <xs:sequence>
          <xs:element name="radar-params" type="radar_params" minOccurs="0">
            <xs:annotation><xs:documentation>Radar-specific parameters (frequency, modulation, FOV, resolution, velocity, MIMO). Use when type="radar".</xs:documentation></xs:annotation>
          </xs:element>
          <xs:element name="gnss-params" type="gnss_params" minOccurs="0">
            <xs:annotation><xs:documentation>GNSS-specific parameters (constellations, frequencies, RTK, accuracy, PPS). Use when type="gnss".</xs:documentation></xs:annotation>
          </xs:element>
        </xs:sequence>
        <xs:attribute name="type" type="RfSensorType" use="required">
          <xs:annotation><xs:documentation>RF sensor sub-type (gnss, uwb, radar, radio_altimeter). Required.</xs:documentation></xs:annotation>
        </xs:attribute>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="chemical_sensor">
    <xs:annotation><xs:documentation>Chemical/environmental sensor (gas detector, pH sensor, humidity sensor). Extends sensor_base with all common elements.</xs:documentation></xs:annotation>
    <xs:complexContent>
      <xs:extension base="sensor_base">
        <xs:attribute name="type" type="ChemicalSensorType" use="required">
          <xs:annotation><xs:documentation>Chemical sensor sub-type (gas, ph, humidity). Required.</xs:documentation></xs:annotation>
        </xs:attribute>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="force_sensor">
    <xs:annotation><xs:documentation>Force/torque sensor (strain gauge, pressure transducer, torque sensor, load cell). Extends sensor_base with all common elements.</xs:documentation></xs:annotation>
    <xs:complexContent>
      <xs:extension base="sensor_base">
        <xs:attribute name="type" type="ForceSensorType" use="required">
          <xs:annotation><xs:documentation>Force sensor sub-type (strain, pressure, torque, load_cell). Required.</xs:documentation></xs:annotation>
        </xs:attribute>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="encoder_sensor">
    <xs:annotation><xs:documentation>Position/velocity encoder sensor. Extends sensor_base with encoder-specific attributes: measurement type (incremental, absolute, linear), physical sensing principle (optical, magnetic, inductive, capacitive, resistive), and communication interface (quadrature, SSI, BiSS, EnDat, SPI). Can be mounted on a motor shaft, joint output, wheel, or linear axis. Motors and transmissions reference encoder sensors by name.</xs:documentation></xs:annotation>
    <xs:complexContent>
      <xs:extension base="sensor_base">
        <xs:attribute name="type" type="EncoderSensorType" use="required">
          <xs:annotation><xs:documentation>Encoder measurement type: incremental (relative, needs homing), absolute (absolute position per revolution or multi-turn), or linear. Required.</xs:documentation></xs:annotation>
        </xs:attribute>
        <xs:attribute name="principle" type="EncoderPrinciple">
          <xs:annotation><xs:documentation>Physical sensing principle: optical, magnetic, inductive, capacitive, or resistive.</xs:documentation></xs:annotation>
        </xs:attribute>
        <xs:attribute name="interface" type="xs:string">
          <xs:annotation><xs:documentation>Communication interface: quadrature, ssi, biss, endat, spi, analog.</xs:documentation></xs:annotation>
        </xs:attribute>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="temperature_sensor">
    <xs:annotation><xs:documentation>Temperature sensor — thermistor, RTD, thermocouple, or IR. Common use: motor winding temperature monitoring (NTC thermistor in motor signal connector), ambient temperature, battery cell temperature. Extends sensor_base with temperature sensor type attribute.</xs:documentation></xs:annotation>
    <xs:complexContent>
      <xs:extension base="sensor_base">
        <xs:attribute name="type" type="TemperatureSensorType" use="required">
          <xs:annotation><xs:documentation>Temperature sensor type: thermistor (NTC/PTC, common in motors), rtd (PT100/PT1000, high accuracy), thermocouple (K/J/T type, wide range), ir (non-contact infrared). Required.</xs:documentation></xs:annotation>
        </xs:attribute>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="radiation_sensor">
    <xs:annotation><xs:documentation>Radiation sensor for detecting ionizing radiation. Used on nuclear inspection robots, space robots, and environmental monitoring platforms. Extends sensor_base with radiation type attribute.</xs:documentation></xs:annotation>
    <xs:complexContent>
      <xs:extension base="sensor_base">
        <xs:attribute name="type" type="RadiationSensorType" use="required">
          <xs:annotation><xs:documentation>Radiation sensor type (geiger, scintillation, neutron, dosimeter). Required.</xs:documentation></xs:annotation>
        </xs:attribute>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="audio_sensor">
    <xs:annotation><xs:documentation>Audio/acoustic sensor for sound capture, ultrasonic ranging, and underwater acoustics. Can be a passive receiver (microphone, hydrophone) or an active transducer (ultrasonic, sonar) that emits and receives. Extends sensor_base with audio type attribute and optional frequency/directivity parameters.</xs:documentation></xs:annotation>
    <xs:complexContent>
      <xs:extension base="sensor_base">
        <xs:sequence>
          <xs:element name="frequency-range" type="range_value" minOccurs="0">
            <xs:annotation><xs:documentation>Operating frequency range. Unit: "Hz" or "kHz". Example: min="20" max="20000" unit="Hz" for audible microphone, min="38" max="42" unit="kHz" for 40kHz ultrasonic. Defines the acoustic bandwidth.</xs:documentation></xs:annotation>
          </xs:element>
          <xs:element name="sensitivity" type="measured_value" minOccurs="0">
            <xs:annotation><xs:documentation>Microphone sensitivity. Unit: "dBV/Pa" (typical: -44 to -26 dBV/Pa for MEMS microphones). For ultrasonic: transmit SPL in dB at reference distance.</xs:documentation></xs:annotation>
          </xs:element>
          <xs:element name="channels" type="xs:unsignedInt" minOccurs="0">
            <xs:annotation><xs:documentation>Number of acoustic channels. 1 for mono, 2+ for microphone array (used for beamforming and sound localization).</xs:documentation></xs:annotation>
          </xs:element>
          <xs:element name="beam-width" type="measured_value" minOccurs="0">
            <xs:annotation><xs:documentation>Acoustic beam width for directional transducers (ultrasonic, sonar). Unit: "deg". Narrower beam = longer range, lower angular coverage.</xs:documentation></xs:annotation>
          </xs:element>
        </xs:sequence>
        <xs:attribute name="type" type="AudioSensorType" use="required">
          <xs:annotation><xs:documentation>Audio sensor type (microphone, ultrasonic, sonar, hydrophone). Required.</xs:documentation></xs:annotation>
        </xs:attribute>
        <xs:attribute name="active" type="xs:boolean" default="false">
          <xs:annotation><xs:documentation>Whether this is an active transducer (emits and receives) or passive (receives only). true for ultrasonic/sonar emitter+receiver pairs; false for microphones and hydrophones.</xs:documentation></xs:annotation>
        </xs:attribute>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="sensor">
    <xs:annotation><xs:documentation>Sensor hardware container grouped by physical measurement category. Contains sub-elements for inertial (accel, gyro), electromagnetic (mag), optical (camera, lidar, tof, optical flow), RF (gnss, uwb, radar), chemical (gas, ph, humidity), force (strain, pressure, torque, load cell), encoder (position/velocity feedback), temperature (thermistor, RTD, thermocouple, IR), radiation (geiger, scintillation, neutron, dosimeter), and audio (microphone, ultrasonic, sonar, hydrophone) sensors. Each sub-sensor has pose, driver identification, measurement parameters, and noise model.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="inertial" type="inertial_sensor" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Inertial measurement unit(s) — accelerometers and/or gyroscopes.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="em" type="em_sensor" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Electromagnetic sensor(s) — magnetometers, metal detectors, eddy current probes.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="optical" type="optical_sensor" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Optical sensor(s) — cameras, lidars, ToF sensors, optical flow sensors.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="rf" type="rf_sensor" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Radio-frequency sensor(s) — GNSS receivers, UWB rangers, radars, radio altimeters.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="chemical" type="chemical_sensor" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Chemical/environmental sensor(s) — gas detectors, pH sensors, humidity sensors.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="force" type="force_sensor" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Force/torque sensor(s) — strain gauges, pressure transducers, torque sensors, load cells.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="encoder" type="encoder_sensor" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Position/velocity encoder(s) — motor-side, joint-side, wheel, or linear. Optical, magnetic, inductive, capacitive, or resistive principle.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="temperature" type="temperature_sensor" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Temperature sensor(s) — thermistors, RTDs, thermocouples, IR. Common: motor winding temp, battery cell temp, ambient.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="radiation" type="radiation_sensor" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Radiation sensor(s) — Geiger counters, scintillation detectors, neutron sensors, dosimeters.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="audio" type="audio_sensor" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Audio/acoustic sensor(s) — microphones, ultrasonic transducers, sonar, hydrophones.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Unique name for this sensor group within the component (e.g., "imu_main", "front_camera_suite"). Required.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="update-rate" type="xs:double">
      <xs:annotation><xs:documentation>Sensor output update rate in Hz. Applies to all sub-sensors in this group unless overridden. Optional.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- MOTORS & TRANSMISSIONS                                          -->
  <!-- ================================================================ -->

  <xs:complexType name="control_modes">
    <xs:annotation><xs:documentation>Control interfaces supported by the motor. Determines how an agent can command this actuator: position (servo-like), velocity (speed control), torque/force (direct effort), current (low-level FOC).</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="mode" type="xs:string" minOccurs="1" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>A supported control mode: "position", "velocity", "torque", "force", "current", "pwm". Multiple modes means the motor supports switching between them.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="motor">
    <xs:annotation><xs:documentation>Motor or actuator with electrical, mechanical, and thermal parameters. Voltage and current use rated_value type with nominal/continuous/peak/max ratings. Connected to joints via transmission elements.</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="pose" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Pose of the motor relative to the component origin as "x y z roll pitch yaw" (meters and radians).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="voltage" type="rated_value" minOccurs="0">
        <xs:annotation><xs:documentation>Motor voltage ratings with nominal/continuous/peak/max levels. Unit: typically "V".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="current" type="rated_value" minOccurs="0">
        <xs:annotation><xs:documentation>Motor current ratings with nominal/continuous/peak/max levels. Unit: typically "A".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="resistance" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Terminal-to-terminal winding resistance. Unit: typically "ohm".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="torque-constant" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Motor torque constant (Kt). Torque output per ampere of current. Unit: typically "Nm/A".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="velocity-constant" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Motor velocity constant — the proportionality between voltage and rotational speed. This single element covers both Ke (back-EMF constant) and Kv (speed constant) conventions; the unit attribute determines which: use unit="V/RPM" or unit="V.s/rad" for Ke (back-EMF style, common on industrial servo and hub motor datasheets, e.g., 0.109 V/RPM for ZLLG65ASM250-L); use unit="RPM/V" for Kv (speed constant style, common on drone/RC BLDC datasheets, e.g., 920 RPM/V). Ke and Kv are reciprocals of each other — an agent computes one from the other as needed.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="max-speed" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Maximum no-load shaft speed. Unit: typically "rpm" or "rad/s".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="stall-torque" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Stall torque at rated voltage. Unit: typically "Nm".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="thermal-resistance" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Thermal resistance from winding to ambient. Unit: typically "degC/W". Used for thermal derating calculations.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="max-temperature" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Maximum allowable winding temperature before demagnetization or insulation failure. Unit: typically "degC".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="thrust-axis" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Direction of thrust force as "x y z" unit vector relative to the component frame. Only for type="thrust". Example: "0 0 1" for upward thrust.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="max-thrust" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Maximum thrust force output. Unit: "N". Only for type="thrust".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="pole-pairs" type="xs:unsignedInt" minOccurs="0">
        <xs:annotation><xs:documentation>Number of magnetic pole pairs in the motor. Determines the electrical frequency: electrical_freq = mechanical_rpm × pole_pairs / 60. Critical for BLDC commutation (Hall sensor transitions per revolution = pole_pairs × 6), ESC configuration, and back-EMF frequency. Example: 15 pole pairs for ZLLG65ASM250-L hub motor, 7 for typical drone motor, 2 for industrial servo.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="displacement" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Engine displacement for internal combustion motors. Unit: "cc" (cubic centimeters) or "L" (liters). Only applicable for type="ice". Example: 50cc for a small generator, 0.8L for a robot mower engine.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="cylinders" type="xs:unsignedInt" minOccurs="0">
        <xs:annotation><xs:documentation>Number of cylinders for internal combustion motors. Only applicable for type="ice".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="stroke" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Linear travel range for linear actuators. Unit: "m" or "mm". Defines the maximum extension distance. Only applicable for type="linear".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="control-modes" type="control_modes" minOccurs="0">
        <xs:annotation><xs:documentation>Supported control interfaces for this motor.</xs:documentation></xs:annotation>
      </xs:element>
      <!-- Load curve key operating points (from motor test data) -->
      <xs:element name="no-load-speed" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>No-load shaft speed at rated voltage. Unit: "rpm". From motor load test. Higher than rated speed. Example: 257.9 rpm for ZLLG65ASM250-L at 24V.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="no-load-current" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>No-load current draw at rated voltage. Unit: "A". The minimum current the motor draws when spinning freely. Important for idle power budget. Example: 0.974A.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="max-power-out" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Maximum mechanical power output from load test. Unit: "W". The peak of the power-vs-torque curve. Example: 158.8W at 11.61 Nm for ZLLG65ASM250-L.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="max-efficiency" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Peak efficiency from load test. Unit: "percent". The best-case power_out/power_in ratio. Example: 68.4% at 3.84 Nm / 216.3 RPM. An agent should target this operating point for best runtime.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
    <xs:attribute name="name" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Unique name for this motor within the component (e.g., "shoulder_motor", "wheel_fl"). Required. Referenced by transmission elements.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="type" type="MotorType">
      <xs:annotation><xs:documentation>Motor technology type (bldc, brushed, stepper, servo, linear, hydraulic, pneumatic, thrust, ice). Optional; useful for selecting appropriate control algorithms.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="construction" type="xs:string">
      <xs:annotation><xs:documentation>Motor physical construction: "inrunner" (rotor inside stator — higher RPM, common in industrial servos and drone motors), "outrunner" (rotor outside stator — higher torque, common in hub motors and large drone motors), "axial-flux" (flat pancake design — very thin, high torque density), "pancake" (flat form factor). Only relevant for BLDC/brushed motors.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="visual" type="xs:string">
      <xs:annotation><xs:documentation>Name of the visual element containing this motor's mesh for 3D highlighting.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="mesh" type="xs:string">
      <xs:annotation><xs:documentation>GLTF mesh node name within the visual for 3D highlighting of this motor.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="encoder" type="xs:string">
      <xs:annotation><xs:documentation>Name reference to an encoder sensor on this component. Identifies motor-side position feedback. The encoder is a full sensor with its own pose, driver, noise model, and resolution.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="hall" type="xs:string">
      <xs:annotation><xs:documentation>Name reference to a Hall sensor on this component used for BLDC commutation. Typically an em-type sensor with 3 Hall elements (U/V/W) providing 6-step commutation signals. Often shares the motor signal connector with the encoder.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="thermistor" type="xs:string">
      <xs:annotation><xs:documentation>Name reference to a temperature sensor on this component monitoring motor winding temperature. Typically an NTC thermistor embedded in the motor stator. Used for thermal protection — the agent can monitor temperature and derate or shut down before exceeding max-temperature.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="transmission_endpoint">
    <xs:annotation><xs:documentation>Reference to a motor or joint endpoint in a transmission. Uses a dotted path "comp.element" to identify the target across components.</xs:documentation></xs:annotation>
    <xs:attribute name="ref" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Dotted reference path to the motor or joint (e.g., "shoulder_comp.shoulder_motor" or "shoulder_joint"). Required.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="transmission">
    <xs:annotation><xs:documentation>Mechanical power transmission connecting a motor to a joint. Defines the gear reduction ratio, efficiency, and backlash for the mechanical coupling between motor output and joint input.</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="motor" type="transmission_endpoint" minOccurs="0">
        <xs:annotation><xs:documentation>Reference to the motor that drives this transmission. Uses dotted path "comp_name.motor_name".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="joint" type="transmission_endpoint" minOccurs="0">
        <xs:annotation><xs:documentation>Reference to the joint that this transmission drives. Uses the joint name.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="reduction" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Gear reduction ratio (motor_speed / joint_speed). Values greater than 1 indicate speed reduction / torque multiplication. For example, 100 means the motor turns 100 times for each joint revolution.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="efficiency" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Mechanical efficiency of the transmission as a fraction in [0, 1]. 1.0 = lossless, 0.9 = 90% efficient. Accounts for friction losses in gears, belts, and bearings.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="backlash" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Mechanical backlash (dead zone) at the joint output. Unit: typically "rad" for rotary or "m" for linear transmissions.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
    <xs:attribute name="name" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Unique name for this transmission (e.g., "shoulder_trans", "wheel_fl_belt"). Required.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="type" type="TransmissionType">
      <xs:annotation><xs:documentation>Mechanical transmission type (simple, differential, belt, gear, planetary, cycloidal, harmonic, strain-wave, worm). Optional; defaults to simple if not specified.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="encoder" type="xs:string">
      <xs:annotation><xs:documentation>Name reference to a joint-side encoder sensor. This is the encoder on the output side of the transmission (after the gearbox), providing higher-accuracy joint position feedback than the motor-side encoder. Optional — not all transmissions have output encoders.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="visual" type="xs:string">
      <xs:annotation><xs:documentation>Name of the visual element containing this transmission's mesh for 3D highlighting.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="mesh" type="xs:string">
      <xs:annotation><xs:documentation>GLTF mesh node name within the visual for 3D highlighting of this transmission.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- JOINTS                                                          -->
  <!-- ================================================================ -->

  <xs:complexType name="joint_parent">
    <xs:annotation><xs:documentation>Parent component reference in a joint. The parent is the component that remains "fixed" while the child moves relative to it through the joint's degrees of freedom.</xs:documentation></xs:annotation>
    <xs:attribute name="comp" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Name of the parent component. Required. Must match a comp name defined in the HCDF document.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="joint_child">
    <xs:annotation><xs:documentation>Child component reference in a joint. The child is the component that moves relative to the parent through the joint's degrees of freedom.</xs:documentation></xs:annotation>
    <xs:attribute name="comp" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Name of the child component. Required. Must match a comp name defined in the HCDF document.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="axis">
    <xs:annotation><xs:documentation>Joint axis of rotation or translation. Defines the direction vector along or around which the joint moves, expressed in the joint's local frame.</xs:documentation></xs:annotation>
    <xs:attribute name="xyz" type="xs:string" default="1 0 0">
      <xs:annotation><xs:documentation>Axis direction vector as three space-separated doubles "x y z". Does not need to be unit-length (will be normalized). Default: "1 0 0" (X axis). Examples: "0 0 1" for Z-axis rotation, "0 1 0" for Y-axis.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="joint_limit">
    <xs:annotation><xs:documentation>Position, velocity, effort, acceleration, and jerk limits for a joint. Required for revolute and prismatic joints. Units depend on joint type: radians and Nm for revolute, meters and N for prismatic.</xs:documentation></xs:annotation>
    <xs:attribute name="lower" type="xs:double" default="0">
      <xs:annotation><xs:documentation>Lower position limit. Radians for revolute joints, meters for prismatic. Default: 0.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="upper" type="xs:double" default="0">
      <xs:annotation><xs:documentation>Upper position limit. Radians for revolute joints, meters for prismatic. Default: 0. Semantic rule: upper must be greater than or equal to lower for non-continuous joints.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="effort" type="xs:double" default="0">
      <xs:annotation><xs:documentation>Maximum joint effort (torque for revolute in Nm, force for prismatic in N). Default: 0 (unlimited if not specified by tooling).</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="velocity" type="xs:double" default="0">
      <xs:annotation><xs:documentation>Maximum joint velocity (rad/s for revolute, m/s for prismatic). Default: 0 (unlimited if not specified by tooling).</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="acceleration" type="xs:double">
      <xs:annotation><xs:documentation>Maximum joint acceleration (rad/s^2 for revolute, m/s^2 for prismatic). Optional; used for trajectory planning.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="jerk" type="xs:double">
      <xs:annotation><xs:documentation>Maximum joint jerk (rad/s^3 for revolute, m/s^3 for prismatic). Optional; used for smooth trajectory generation.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="joint_dynamics">
    <xs:annotation><xs:documentation>Joint dynamics parameters for simulation. Defines viscous damping, Coulomb friction, and optional spring behavior.</xs:documentation></xs:annotation>
    <xs:attribute name="damping" type="xs:double" default="0">
      <xs:annotation><xs:documentation>Viscous damping coefficient. Nm/(rad/s) for revolute, N/(m/s) for prismatic. Default: 0.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="friction" type="xs:double" default="0">
      <xs:annotation><xs:documentation>Coulomb friction torque/force. Nm for revolute, N for prismatic. Applied as constant resistance opposing motion. Default: 0.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="spring_stiffness" type="xs:double" default="0">
      <xs:annotation><xs:documentation>Spring stiffness. Nm/rad for revolute, N/m for prismatic. Creates a restoring force toward spring_reference position. Default: 0 (no spring).</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="spring_reference" type="xs:double" default="0">
      <xs:annotation><xs:documentation>Spring rest position. Radians for revolute, meters for prismatic. The position at which the spring exerts zero force. Default: 0.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="joint_calibration">
    <xs:annotation><xs:documentation>Joint calibration data for homing and reference position determination. Used to relate encoder readings to absolute joint positions.</xs:documentation></xs:annotation>
    <xs:attribute name="reference_position" type="xs:double" default="0">
      <xs:annotation><xs:documentation>Absolute joint position (radians or meters) corresponding to the calibration reference mark. Default: 0.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="rising" type="xs:double">
      <xs:annotation><xs:documentation>Joint position (radians or meters) at the rising edge of the calibration sensor during a positive-direction sweep.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="falling" type="xs:double">
      <xs:annotation><xs:documentation>Joint position (radians or meters) at the falling edge of the calibration sensor during a positive-direction sweep.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="mimic">
    <xs:annotation><xs:documentation>Mimic joint constraint. Makes this joint's position track another joint's position via a linear relationship: position = multiplier * leader_position + offset. Used for mechanically coupled joints (e.g., parallel gripper fingers, coupled four-bar linkages).</xs:documentation></xs:annotation>
    <xs:attribute name="joint" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Name of the leader joint to mimic. Required. Semantic rule: must reference an existing joint defined in the HCDF document.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="multiplier" type="xs:double" default="1">
      <xs:annotation><xs:documentation>Scaling factor applied to the leader joint's position. Default: 1.0 (identical motion). Use -1 for opposite-direction coupling.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="offset" type="xs:double" default="0">
      <xs:annotation><xs:documentation>Constant offset added after scaling (radians for revolute, meters for prismatic). Default: 0.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="loop_closure">
    <xs:annotation><xs:documentation>Marks a joint as closing a kinematic loop. Contains the predecessor/successor bodies and which DOFs are constrained at the closure point. Used by dynamics solvers (HyRoDyn, Drake) to handle parallel mechanisms that URDF's tree-only structure cannot represent.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="predecessor" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Predecessor body (comp name) in the kinematic loop at this closure point.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="successor" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Successor body (comp name) in the kinematic loop at this closure point.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="constraint-axes" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>6-value string "tx ty tz rx ry rz" where 1=constrained, 0=free. Example: "1 1 1 1 1 0" constrains all except rotation around Z.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="joint">
    <xs:annotation><xs:documentation>Kinematic connection between two components defining degrees of freedom. Supports 8 joint types: revolute (bounded rotation), continuous (unbounded rotation), prismatic (linear), fixed (rigid), ball (3-DOF spherical), universal (2-DOF), planar (2D translation), and screw (helical). Semantic rule: revolute/prismatic require axis + limit; fixed forbids them; universal requires axis + axis2.</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="description" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Human-readable description of the joint's purpose (e.g., "left shoulder pitch", "front-left wheel spin").</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="parent" type="joint_parent" minOccurs="1">
        <xs:annotation><xs:documentation>Parent component of the joint. Required. The parent remains fixed while the child moves.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="child" type="joint_child" minOccurs="1">
        <xs:annotation><xs:documentation>Child component of the joint. Required. The child moves relative to the parent.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="origin" type="pose" minOccurs="0">
        <xs:annotation><xs:documentation>Pose of the joint frame relative to the parent component's origin. Defines where the joint is located and how it is oriented on the parent body.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="axis" type="axis" minOccurs="0">
        <xs:annotation><xs:documentation>Primary axis of rotation/translation in the joint frame. Required for revolute, continuous, prismatic, universal, and screw joints. Forbidden for fixed joints.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="axis2" type="axis" minOccurs="0">
        <xs:annotation><xs:documentation>Secondary axis for universal joints (2-DOF). Defines the second rotation axis, which must be perpendicular to the primary axis. Only used when type="universal".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="limit" type="joint_limit" minOccurs="0">
        <xs:annotation><xs:documentation>Position, velocity, effort, acceleration, and jerk limits. Required for revolute and prismatic joints. Optional for continuous (velocity/effort limits only). Forbidden for fixed.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="dynamics" type="joint_dynamics" minOccurs="0">
        <xs:annotation><xs:documentation>Damping, friction, and spring parameters for simulation.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="calibration" type="joint_calibration" minOccurs="0">
        <xs:annotation><xs:documentation>Calibration reference data for homing the joint to an absolute position.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="mimic" type="mimic" minOccurs="0">
        <xs:annotation><xs:documentation>Mimic constraint that makes this joint track another joint's position.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="loop" type="loop_closure" minOccurs="0">
        <xs:annotation><xs:documentation>Loop closure marker. Present when this joint closes a kinematic loop (parallel mechanism). The kinematic tree parser should treat this joint as a constraint, not a parent-child relationship. Used for four-bar linkages, delta robots, Stewart platforms.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
    <xs:attribute name="name" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Unique name for this joint (e.g., "left_shoulder_pitch", "wheel_fl_spin"). Required. Referenced by transmission elements and mimic constraints.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="type" type="JointType" use="required">
      <xs:annotation><xs:documentation>Joint type determining degrees of freedom and required sub-elements. Required.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="thread_pitch" type="xs:double">
      <xs:annotation><xs:documentation>Thread pitch for screw joints in meters per revolution. Defines the linear advance per full rotation. Only applicable when type="screw".</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- NETWORK: Unified connectivity + configuration                   -->
  <!-- Groups all topology (links, buses, chains) and all network      -->
  <!-- configuration (gPTP, schedules, MACsec, EEE, stream profiles)   -->
  <!-- in a single element. Replaces separate link/bus/chain/tsn-domain -->
  <!-- at the root level.                                              -->
  <!-- ================================================================ -->

  <!-- ===== Topology: Links ===== -->

  <xs:complexType name="vlan">
    <xs:annotation><xs:documentation>IEEE 802.1Q VLAN tag assignment for a link, chain, or spur. Segments network traffic into virtual LANs for isolation and QoS mapping.</xs:documentation></xs:annotation>
    <xs:attribute name="id" type="xs:unsignedInt" use="required">
      <xs:annotation><xs:documentation>VLAN identifier (VID), range 1-4094. Required. Frames on this link/chain are tagged with this VID.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="pcp" type="xs:unsignedInt">
      <xs:annotation><xs:documentation>Priority Code Point (PCP), range 0-7. Maps to a traffic class for QoS. Higher values = higher priority. Optional; if omitted, PCP is determined by the traffic class mapping.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="macsec_policy">
    <xs:annotation><xs:documentation>Per-link or per-chain IEEE 802.1AE MACsec security policy. Overrides the network-wide macsec default when present. Specifies policy intent only — actual keys are provisioned at runtime.</xs:documentation></xs:annotation>
    <xs:attribute name="policy" type="MacsecPolicy" use="required">
      <xs:annotation><xs:documentation>MACsec enforcement level. Required. must-secure drops unprotected frames; should-secure prefers MACsec; integrity-only authenticates without encrypting; disabled turns MACsec off.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="cipher" type="MacsecCipher" default="gcm-aes-128">
      <xs:annotation><xs:documentation>Cipher suite for this link/chain. Default: gcm-aes-128.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="key-agreement" type="KeyAgreement" default="psk">
      <xs:annotation><xs:documentation>Key agreement protocol. Default: psk (pre-shared key).</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="key-ref" type="xs:string">
      <xs:annotation><xs:documentation>Reference identifier for the key material in the key store. Opaque string resolved at runtime by the MACsec key agreement daemon.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="confidentiality-offset" type="ConfidentialityOffset" default="0">
      <xs:annotation><xs:documentation>Number of bytes after the SecTAG to leave unencrypted (0, 30, or 50). Default: 0 (encrypt everything). Use 30 to expose L3/L4 headers for hardware QoS classification on non-MACsec-aware switches.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="wired">
    <xs:annotation><xs:documentation>Wired point-to-point link physical layer definition. Contains exactly two port references (the two endpoints), plus optional VLAN, MACsec, and IP configuration.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="port" type="xs:string" minOccurs="2" maxOccurs="2">
        <xs:annotation><xs:documentation>Dotted port reference "comp_name.port_name" identifying an endpoint of this link. Exactly two required (one per end). Order does not matter for Ethernet links; for T1 links, PHY master/slave is set on the port, not here.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="vlan" type="vlan" minOccurs="0">
        <xs:annotation><xs:documentation>VLAN tag assignment for traffic on this link.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="macsec" type="macsec_policy" minOccurs="0">
        <xs:annotation><xs:documentation>Per-link MACsec policy override. If omitted, the network-wide macsec default applies.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="ip" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>IP address assignment for this link in CIDR notation (e.g., "10.0.1.0/24"). Optional; used by runtime agents for interface configuration.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="standard" type="xs:string" use="required">
      <xs:annotation><xs:documentation>PHY standard for the wired link (e.g., "100base-t1", "1000base-t", "25gbase-sr", "802.3dm"). Required. Must be compatible with both endpoint ports' capabilities.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="wireless">
    <xs:annotation><xs:documentation>Wireless link physical layer definition. Contains exactly two antenna references (the two endpoints) and an optional SSID for WiFi links.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="antenna" type="xs:string" minOccurs="2" maxOccurs="2">
        <xs:annotation><xs:documentation>Dotted antenna reference "comp_name.antenna_name" identifying an endpoint of this wireless link. Exactly two required.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="ssid" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>WiFi SSID (network name) for WiFi links. Optional; only applicable when standard is an 802.11 variant.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="standard" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Wireless standard for this link (e.g., "802.11ax", "bluetooth-5.3", "lora-1.0.4"). Required. Must be compatible with both endpoint antennas' capabilities.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="link">
    <xs:annotation><xs:documentation>Point-to-point connection between exactly two ports (wired) or two antennas (wireless). The standard attribute identifies the PHY standard (e.g., 25gbase-sr, 100base-t1, 802.3dm). Can include VLAN assignment, MACsec policy, and IP configuration.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="description" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Human-readable description of the link's purpose (e.g., "compute-to-switch uplink", "WiFi telemetry link").</xs:documentation></xs:annotation>
      </xs:element>
      <xs:choice>
        <xs:element name="wired" type="wired">
          <xs:annotation><xs:documentation>Wired point-to-point link (Ethernet, T1 Ethernet, fiber).</xs:documentation></xs:annotation>
        </xs:element>
        <xs:element name="wireless" type="wireless">
          <xs:annotation><xs:documentation>Wireless link (WiFi, Bluetooth, LoRa, cellular, UWB).</xs:documentation></xs:annotation>
        </xs:element>
      </xs:choice>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Unique name for this link within the network (e.g., "spine_uplink", "arm_t1", "wifi_telemetry"). Required.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- ===== Topology: Buses ===== -->

  <xs:complexType name="plca_coordinator">
    <xs:annotation><xs:documentation>PLCA coordinator designation for IEEE 802.3cg 10BASE-T1S multi-drop Ethernet. The coordinator provides the beacon that synchronizes time slot allocation for all nodes on the segment.</xs:documentation></xs:annotation>
    <xs:attribute name="device" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Component name of the PLCA coordinator device. Required.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="port" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Port name on the coordinator device connected to this bus. Required.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="plca_config">
    <xs:annotation><xs:documentation>IEEE 802.3cg PLCA configuration for 10BASE-T1S multi-drop Ethernet buses. Defines the coordinator, node count, and burst parameters for deterministic medium access.</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="coordinator" type="plca_coordinator" minOccurs="0">
        <xs:annotation><xs:documentation>Device and port that serves as the PLCA coordinator (beacon source). Exactly one coordinator per bus segment.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="node-count" type="xs:unsignedInt" minOccurs="0">
        <xs:annotation><xs:documentation>Total number of PLCA nodes on this bus segment. Used to size the transmit opportunity cycle. Should match the number of participants.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="burst-count" type="xs:unsignedInt" minOccurs="0">
        <xs:annotation><xs:documentation>Maximum number of additional frames a node may send in its transmit opportunity after the first frame. 0 = single frame per opportunity.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="bus_participant">
    <xs:annotation><xs:documentation>A device connected to a shared bus. Identifies the component, port, bus address, and role on the bus. Multiple participants share the same physical medium and see all traffic simultaneously.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="protocol" type="xs:string" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Higher-layer protocol(s) this participant uses on the bus (e.g., "DroneCAN", "Modbus-RTU", "CANopen"). Multiple entries for multi-protocol devices.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="device" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Component name of the participant device. Required. Must match a comp name in the HCDF document.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="port" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Port name on the participant device connected to this bus. Required.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="position" type="xs:unsignedInt">
      <xs:annotation><xs:documentation>Physical position of this participant on the bus (0-based index). Defines ordering for daisy-chain and star topologies. Optional for multidrop.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="id" type="xs:string">
      <xs:annotation><xs:documentation>Bus-level device identifier (e.g., CAN node ID, I2C 7-bit address in hex "0x50", Modbus slave address). Format depends on bus type.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="address" type="xs:string">
      <xs:annotation><xs:documentation>Alternative address format for protocols that use addressing differently from id (e.g., IP address on 10BASE-T1S bus). Use id for bus-native addressing, address for higher-layer addressing.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="role" type="BusParticipantRole">
      <xs:annotation><xs:documentation>Functional role on the bus (controller, target, source, sink). Determines communication patterns. Optional.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="terminator" type="xs:boolean">
      <xs:annotation><xs:documentation>Whether this participant provides bus termination resistance. Set true for endpoints of CAN buses and other buses requiring termination. Optional; default: false.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="cs" type="xs:unsignedInt">
      <xs:annotation><xs:documentation>SPI chip-select line number for SPI bus participants. Identifies which CS pin the SPI controller uses to select this device. Only applicable for SPI buses.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="plca-id" type="xs:unsignedInt">
      <xs:annotation><xs:documentation>PLCA node ID for 10BASE-T1S participants. Determines the transmit opportunity slot in the PLCA cycle. Range 0-254. Only applicable for Ethernet buses with PLCA.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="bus">
    <xs:annotation><xs:documentation>Shared medium network where all participants are electrically connected and see all traffic simultaneously. No per-hop forwarding — latency is the same for all participants. Use for CAN, I2C, SPI, UART (multi-drop), 10BASE-T1S, servo buses (STS/Dynamixel), and power distribution.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="description" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Human-readable description of the bus purpose (e.g., "CAN bus for motor controllers", "I2C sensor bus").</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="bitrate" type="xs:unsignedLong" minOccurs="0">
        <xs:annotation><xs:documentation>Raw bit rate in bits per second (e.g., 500000 for CAN 500 kbit/s, 1000000 for CAN-FD 1 Mbit/s data phase). Alternative to speed/baud for bus types where bitrate is the standard specification.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="speed" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Bus speed with explicit unit (e.g., 10 with unit="Mbps" for 10BASE-T1S). Alternative to bitrate.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="baud" type="measured_value" minOccurs="0">
        <xs:annotation><xs:documentation>Baud rate for UART buses (e.g., 115200 with unit="Bd"). Alternative to bitrate/speed.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="standard" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Bus standard (e.g., "10base-t1s", "CAN-2.0B", "CAN-FD", "STS", "Dynamixel-2.0").</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="protocol" type="xs:string" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Higher-layer protocol(s) used on this bus (e.g., "DroneCAN", "CANopen", "Modbus-RTU").</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="voltage" type="xs:double" minOccurs="0">
        <xs:annotation><xs:documentation>Bus voltage level in volts (e.g., 3.3 for I2C, 5.0 for CAN). Used for level-shifter planning and power budget.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="plca" type="plca_config" minOccurs="0">
        <xs:annotation><xs:documentation>PLCA configuration for 10BASE-T1S Ethernet buses. Only applicable when type="ethernet" and standard="10base-t1s".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="participant" type="bus_participant" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Devices connected to this bus. Each participant identifies its component, port, address, and role.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Unique name for this bus within the network (e.g., "can_motors", "i2c_sensors", "spi_imus"). Required.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="type" type="BusType" use="required">
      <xs:annotation><xs:documentation>Bus protocol type. Required. Determines valid participant roles, addressing, and speed parameters.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="topology" type="BusTopology">
      <xs:annotation><xs:documentation>Physical wiring topology (daisy-chain, star, or multidrop). Optional; defaults depend on bus type (CAN is typically multidrop, SPI is typically star).</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- ===== Topology: Chains ===== -->

  <xs:complexType name="ethercat_identity">
    <xs:annotation><xs:documentation>EtherCAT slave device identity from the ESI (EtherCAT Slave Information) file. Used to match the physical device to its configuration during startup.</xs:documentation></xs:annotation>
    <xs:attribute name="vendor" type="xs:string">
      <xs:annotation><xs:documentation>EtherCAT vendor ID (hex string, e.g., "0x00000002" for Beckhoff). Matches the ESI VendorId field.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="product" type="xs:string">
      <xs:annotation><xs:documentation>EtherCAT product code (hex string). Matches the ESI ProductCode field.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="revision" type="xs:string">
      <xs:annotation><xs:documentation>EtherCAT revision number (hex string). Matches the ESI RevisionNo field for firmware compatibility.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="dc_hop">
    <xs:annotation><xs:documentation>EtherCAT Distributed Clock configuration for a single hop (slave device). Defines the synchronization mode and timing parameters for this slave's local clock.</xs:documentation></xs:annotation>
    <xs:attribute name="mode" type="DcMode">
      <xs:annotation><xs:documentation>DC synchronization mode. free-run: no sync. sync0: synchronized to SYNC0 pulse. sync0-sync1: dual-sync for multi-rate processing.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="cycle-time-us" type="xs:unsignedInt">
      <xs:annotation><xs:documentation>SYNC0 cycle time in microseconds. Determines the slave's real-time processing period.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="shift-time-ns" type="xs:int" default="0">
      <xs:annotation><xs:documentation>SYNC0 phase shift in nanoseconds relative to the DC reference clock. Used to stagger processing across slaves to avoid simultaneous current draw. Default: 0.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="dc_chain">
    <xs:annotation><xs:documentation>EtherCAT Distributed Clock configuration at the chain level. Identifies the reference clock source for the entire EtherCAT segment.</xs:documentation></xs:annotation>
    <xs:attribute name="reference-clock" type="xs:string">
      <xs:annotation><xs:documentation>Component name of the device that serves as the DC reference clock for this chain. Typically the first slave after the master. If omitted, the EtherCAT master auto-selects.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="spur">
    <xs:annotation><xs:documentation>Spur connection from a chain hop to a device not in the main chain path. Represents a branch connection where a chain hop's switch port bridges to an external device (e.g., a sensor or actuator hanging off a chain node via an additional Ethernet port).</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="description" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Human-readable description of the spur connection purpose.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="vlan" type="vlan" minOccurs="0">
        <xs:annotation><xs:documentation>VLAN tag for traffic on this spur link.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="device" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Component name of the device connected via this spur. Required.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="port" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Port name on the spur device that connects to the chain hop. Required.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="via" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Port name on the chain hop device that connects to the spur device. Required. This port must be on the hop device (not in the main chain path).</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="tunnel">
    <xs:annotation><xs:documentation>Tunnel configuration for carrying one chain's traffic encapsulated over another chain or link. Used for EtherCAT-over-TSN (IEEE 1722 encapsulation) or EtherCAT-over-EtherCAT (ETG.1700) scenarios.</xs:documentation></xs:annotation>
    <xs:attribute name="chain" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Name of the outer/transport chain that carries the encapsulated traffic. Required.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="hop" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Device name of the hop on the outer chain where the tunnel ingress/egress occurs. Required.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="protocol" type="TunnelProtocol">
      <xs:annotation><xs:documentation>Encapsulation protocol used for tunneling (etg-1700, ieee-1722, raw). Optional; defaults to the most appropriate protocol for the chain types involved.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="hop">
    <xs:annotation><xs:documentation>A device in a daisy-chain that actively forwards frames to the next device. Each hop represents one store-and-forward bridge (switched mode) or one process-on-the-fly node (pass-through mode). Hop order in the XML defines the physical chain topology from root to tail.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="description" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Human-readable description of this hop's role in the chain.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="dc" type="dc_hop" minOccurs="0">
        <xs:annotation><xs:documentation>EtherCAT Distributed Clock configuration for this hop. Only applicable to EtherCAT chains (type="ethercat").</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="identity" type="ethercat_identity" minOccurs="0">
        <xs:annotation><xs:documentation>EtherCAT slave identity (vendor, product, revision) from the ESI file. Only applicable to EtherCAT chains.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="spur" type="spur" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Branch connections from this hop to devices not in the main chain path.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="device" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Component name of the device at this chain position. Required. Must match a comp name in the HCDF document.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="port" type="xs:string">
      <xs:annotation><xs:documentation>Port name used for the chain connection when the device has a single chain port. Mutually exclusive with port-primary/port-secondary. For simple line topologies.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="port-primary" type="xs:string">
      <xs:annotation><xs:documentation>Primary chain port name (upstream, toward root). Used for ring topologies or devices with separate ingress/egress ports. Mutually exclusive with port.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="port-secondary" type="xs:string">
      <xs:annotation><xs:documentation>Secondary chain port name (downstream, toward tail). Used for ring topologies. Mutually exclusive with port.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="ingress" type="xs:string">
      <xs:annotation><xs:documentation>Ingress port name for devices with asymmetric chain connectivity. Alternative to port-primary for non-ring topologies where ingress and egress are distinct.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="egress" type="xs:string">
      <xs:annotation><xs:documentation>Egress port name for devices with asymmetric chain connectivity. Alternative to port-secondary for non-ring topologies.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="role" type="HopRole">
      <xs:annotation><xs:documentation>Role in the chain (root, master, tail). root: chain controller / first hop. master: intermediate forwarding hop. tail: last hop. Optional; inferred from position if omitted.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="alias" type="xs:string">
      <xs:annotation><xs:documentation>EtherCAT configured station alias. Alternative addressing that persists across topology changes. Only applicable to EtherCAT chains.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="position" type="xs:unsignedInt">
      <xs:annotation><xs:documentation>Explicit 0-based position index in the chain. If omitted, position is determined by XML element order. Useful when XML order does not match physical chain order.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="fmmu-offset" type="xs:unsignedInt">
      <xs:annotation><xs:documentation>EtherCAT FMMU (Fieldbus Memory Management Unit) logical address offset in bytes. Defines where this slave's process data is mapped in the logical address space. Semantic rule: FMMU offset+size ranges must not overlap across hops.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="fmmu-size" type="xs:unsignedInt">
      <xs:annotation><xs:documentation>EtherCAT FMMU mapping size in bytes. Amount of process data (PDOs) mapped for this slave.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="processing-delay-ns" type="xs:unsignedInt">
      <xs:annotation><xs:documentation>Processing delay through this hop's switching fabric in nanoseconds. Different switch chips have different forwarding latencies — an NXP SJA1110 may be 3000ns while a simple 2-port bridge MCU may be 1000ns. When specified, the agent uses this instead of a default assumption for per-hop latency computation. If omitted, the agent uses a conservative default based on link speed.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="chain">
    <xs:annotation><xs:documentation>Bridged daisy-chain network where each device actively forwards frames to the next hop. Two modes: switched (store-and-forward, e.g., TSN Ethernet with per-hop Qbv scheduling) and pass-through (process-on-the-fly, e.g., EtherCAT where each slave processes frames in hardware as they pass). Hop order defines the physical chain topology. Latency accumulates per hop.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="description" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Human-readable description of the chain's purpose (e.g., "left arm 802.3dm chain", "EtherCAT servo chain").</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="vlan" type="vlan" minOccurs="0">
        <xs:annotation><xs:documentation>VLAN tag for all traffic on this chain. Isolates chain traffic from other network traffic.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="macsec" type="macsec_policy" minOccurs="0">
        <xs:annotation><xs:documentation>Per-chain MACsec policy override. If omitted, the network-wide macsec default applies.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="cycle-time-us" type="xs:unsignedInt" minOccurs="0">
        <xs:annotation><xs:documentation>Chain cycle time in microseconds. For switched chains, this defines the Qbv schedule period applied to all hops. For EtherCAT, this is the bus cycle time.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="dc" type="dc_chain" minOccurs="0">
        <xs:annotation><xs:documentation>EtherCAT Distributed Clock chain-level configuration. Only applicable when type="ethercat".</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="tunnel" type="tunnel" minOccurs="0">
        <xs:annotation><xs:documentation>Tunnel configuration when this chain's traffic is encapsulated over another chain or link.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="hop" type="hop" minOccurs="1" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Ordered list of devices in the chain. At least one hop required. XML element order defines the physical chain topology from root (first) to tail (last).</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Unique name for this chain within the network (e.g., "left_arm_chain", "ecat_servos"). Required.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="type" type="ChainProtocol" use="required">
      <xs:annotation><xs:documentation>Chain protocol/PHY standard. Required. Determines valid modes and hop configurations.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="mode" type="ChainMode" default="switched">
      <xs:annotation><xs:documentation>Forwarding mode. Default: "switched" (store-and-forward). Use "pass-through" for EtherCAT and similar protocols where frames are processed in-flight.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="topology" type="ChainTopology" default="line">
      <xs:annotation><xs:documentation>Physical chain topology. Default: "line" (open-ended). Use "ring" when the tail connects back to the root for redundancy.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- ===== Configuration: gPTP, Schedules, MACsec, Streams ===== -->

  <xs:complexType name="gptp_clock">
    <xs:annotation><xs:documentation>gPTP clock instance participating in the IEEE 802.1AS time domain. Each clock represents a device's gPTP-capable port and its grandmaster election parameters.</xs:documentation></xs:annotation>
    <xs:attribute name="device" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Component name of the device hosting this gPTP clock. Required.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="port" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Port name on the device that participates in gPTP. Required. Must be a port with hw-timestamping capability.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="gm-capable" type="xs:boolean" use="required">
      <xs:annotation><xs:documentation>Whether this clock can serve as grandmaster. Required. At least one clock in the domain should be gm-capable="true".</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="priority1" type="xs:unsignedInt" default="128">
      <xs:annotation><xs:documentation>BMCA priority1 value (0-255). Lower wins grandmaster election. Default: 128.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="priority2" type="xs:unsignedInt" default="128">
      <xs:annotation><xs:documentation>BMCA priority2 value (0-255). Tiebreaker after priority1 and clock quality. Default: 128.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="clock-class" type="xs:unsignedInt" default="248">
      <xs:annotation><xs:documentation>IEEE 1588 clock class indicating accuracy category (6=GPS-locked, 248=default, etc.). Default: 248.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="clock-accuracy" type="xs:string" default="0xFE">
      <xs:annotation><xs:documentation>IEEE 1588 clock accuracy code as hex string. 0x20=25ns, 0x21=100ns, 0xFE=unknown. Default: "0xFE".</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="gptp_port_defaults">
    <xs:annotation><xs:documentation>Default gPTP timing parameters applied to all ports in the domain unless overridden per-port. These values control sync message rates, path delay measurements, and announce timeout.</xs:documentation></xs:annotation>
    <xs:attribute name="log-sync-interval" type="xs:int" default="-3">
      <xs:annotation><xs:documentation>Log base-2 of the Sync message interval in seconds. -3 = 125 ms (8 messages/sec), -4 = 62.5 ms. Default: -3.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="log-announce-interval" type="xs:int" default="0">
      <xs:annotation><xs:documentation>Log base-2 of the Announce message interval in seconds. 0 = 1 second. Default: 0.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="log-pdelay-req-interval" type="xs:int" default="0">
      <xs:annotation><xs:documentation>Log base-2 of the Pdelay_Req message interval in seconds for peer delay measurement. 0 = 1 second. Default: 0.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="announce-receipt-timeout" type="xs:unsignedInt" default="3">
      <xs:annotation><xs:documentation>Number of Announce intervals without receipt before declaring the GM lost. Default: 3.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="neighbor-prop-delay-thresh-ns" type="xs:unsignedInt" default="800">
      <xs:annotation><xs:documentation>Maximum acceptable neighbor propagation delay in nanoseconds. Links exceeding this threshold are considered not AS-capable. Default: 800 ns.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="gptp">
    <xs:annotation><xs:documentation>IEEE 802.1AS generalized Precision Time Protocol configuration. Defines the clock domain, grandmaster election priorities, and per-port timing parameters. All TSN scheduling depends on gPTP time synchronization.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="clock" type="gptp_clock" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>gPTP clock instances participating in this time domain. One per device-port combination.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="port-defaults" type="gptp_port_defaults" minOccurs="0">
        <xs:annotation><xs:documentation>Default timing parameters for all gPTP ports in this domain.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="domain" type="xs:unsignedInt" use="required">
      <xs:annotation><xs:documentation>gPTP domain number (0-127). Required. Devices in the same domain synchronize clocks. Multiple domains allow independent time references (e.g., domain 0 for arm TSN, domain 1 for base).</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="traffic_class">
    <xs:annotation><xs:documentation>Mapping between a traffic class number, a PCP value, and its QoS properties. Defines how frames are classified into priority queues for Qbv scheduling and CBS shaping.</xs:documentation></xs:annotation>
    <xs:attribute name="tc" type="xs:unsignedInt" use="required">
      <xs:annotation><xs:documentation>Traffic class number (0-7). Required. Maps to hardware transmit queues.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="pcp" type="xs:unsignedInt" use="required">
      <xs:annotation><xs:documentation>Priority Code Point (0-7) that maps to this traffic class. Required. Set in the VLAN tag of transmitted frames.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="name" type="xs:string">
      <xs:annotation><xs:documentation>Human-readable name for this traffic class (e.g., "control", "video", "best-effort"). Optional.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="description" type="xs:string">
      <xs:annotation><xs:documentation>Longer description of the traffic class purpose and contents. Optional.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="preemption" type="PreemptionClass">
      <xs:annotation><xs:documentation>IEEE 802.1Qbu preemption class (express or preemptable). express: cannot be interrupted. preemptable: can be interrupted by express traffic. Optional; default behavior is switch-specific.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="traffic_classes">
    <xs:annotation><xs:documentation>Traffic class definitions for the network. Maps PCP values to traffic class numbers and optionally assigns preemption behavior. Used by Qbv schedules and CBS shapers to determine queue assignments.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="class" type="traffic_class" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Individual traffic class definition. One per TC number used in the network.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="count" type="xs:unsignedInt" use="required">
      <xs:annotation><xs:documentation>Total number of traffic classes in use (1-8). Required. Must match the number of class child elements.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="gate">
    <xs:annotation><xs:documentation>A single entry in a Qbv gate control list. Specifies which traffic classes can transmit and for how long during one segment of the repeating schedule cycle.</xs:documentation></xs:annotation>
    <xs:attribute name="tc-mask" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Bitmask of traffic classes allowed to transmit during this gate interval (e.g., "10000000" opens only TC7, "11111111" opens all TCs). Required. 8-character binary string, one bit per TC (TC7 at left, TC0 at right).</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="duration-us" type="xs:unsignedInt" use="required">
      <xs:annotation><xs:documentation>Duration of this gate interval in microseconds. Required. Semantic rule: all gate durations in a schedule must sum to the schedule's cycle-time-us.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="schedule">
    <xs:annotation><xs:documentation>IEEE 802.1Qbv Time-Aware Shaper gate control list template. Defines a repeating cycle of gate states that open/close transmission gates per traffic class. Each gate entry specifies which traffic classes can transmit and for how long. Semantic rule: gate durations must sum to cycle-time-us.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="gate" type="gate" minOccurs="1" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Ordered list of gate control entries. At least one required. Executed cyclically in XML order.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Unique name for this schedule template (e.g., "arm_1ms_schedule", "base_schedule"). Required. Referenced by schedule-assignment elements.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="cycle-time-us" type="xs:unsignedInt" use="required">
      <xs:annotation><xs:documentation>Total cycle duration in microseconds. Required. All gate durations must sum to this value. Typical values: 250 (4 kHz), 500 (2 kHz), 1000 (1 kHz).</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="schedule_assign">
    <xs:annotation><xs:documentation>Assignment of a named schedule template to specific ports and/or chains. Binds a Qbv gate control list to the hardware ports that should execute it.</xs:documentation></xs:annotation>
    <xs:attribute name="schedule" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Name of the schedule template to apply. Required. Must match a schedule name defined in this network.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="ports" type="xs:string">
      <xs:annotation><xs:documentation>Space-separated list of dotted port references ("comp.port") to apply this schedule to. Optional.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="chains" type="xs:string">
      <xs:annotation><xs:documentation>Space-separated list of chain names to apply this schedule to (all hops in the chain). Optional.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="schedule_assignment">
    <xs:annotation><xs:documentation>Container for all schedule-to-port/chain assignments in the network. Groups schedule_assign entries that bind Qbv templates to physical ports.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="assign" type="schedule_assign" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Individual schedule assignment binding a template to ports and/or chains.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="stream_profile_ref">
    <xs:annotation><xs:documentation>Reference to an external stream profile definition file (.streams.xml). Stream profiles define individual TSN streams (talker, listener, bandwidth, latency requirements) separately from the HCDF topology to allow independent versioning and reuse across robots.</xs:documentation></xs:annotation>
    <xs:attribute name="uri" type="xs:anyURI" use="required">
      <xs:annotation><xs:documentation>URI of the stream profile file (relative to the HCDF document or absolute). Required.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="sha" type="xs:string">
      <xs:annotation><xs:documentation>SHA-256 hash of the referenced stream profile file for content integrity verification.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="active" type="xs:boolean" default="true">
      <xs:annotation><xs:documentation>Whether this stream profile is currently active. Default: true. Set false to define but not activate a profile (e.g., for A/B switching).</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="key_store">
    <xs:annotation><xs:documentation>Reference to the credential storage backend for MACsec key material. Points the runtime MACsec daemon to the appropriate key source.</xs:documentation></xs:annotation>
    <xs:attribute name="type" type="KeyStoreType" use="required">
      <xs:annotation><xs:documentation>Credential storage type (secure-element, hsm, tpm, file, runtime). Required.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="ref" type="xs:string">
      <xs:annotation><xs:documentation>Implementation-specific reference to the key material (e.g., HSM slot ID, TPM handle, file path, or SE key index). Opaque string resolved by the runtime.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- Network-wide MACsec: single default policy. Individual links/chains can override. -->
  <xs:complexType name="macsec_config">
    <xs:annotation><xs:documentation>IEEE 802.1AE MACsec network-wide default security policy. Individual links and chains can override. No actual keys — only policy intent. Keys are provisioned at runtime via the key-store reference.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="key-store" type="key_store" minOccurs="0">
        <xs:annotation><xs:documentation>Credential storage backend for this network's MACsec keys.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="policy" type="MacsecPolicy" use="required">
      <xs:annotation><xs:documentation>Default MACsec enforcement policy for all links and chains in this network. Required. Individual links/chains can override with their own macsec element.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="cipher" type="MacsecCipher" default="gcm-aes-128">
      <xs:annotation><xs:documentation>Default cipher suite. Default: gcm-aes-128. Can be overridden per link/chain.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="key-agreement" type="KeyAgreement" default="psk">
      <xs:annotation><xs:documentation>Default key agreement protocol. Default: psk. Can be overridden per link/chain.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="rekey-interval-sec" type="xs:unsignedInt">
      <xs:annotation><xs:documentation>Automatic rekeying interval in seconds. Optional. When set, MACsec associations are rekeyed periodically to limit exposure of compromised keys.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- ===== Network: unified connectivity + configuration ===== -->

  <!-- ===== Topology: Mesh ===== -->

  <xs:simpleType name="MeshRole">
    <xs:annotation><xs:documentation>Role of a device in a wireless mesh network.</xs:documentation></xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="coordinator"/>
      <xs:enumeration value="border-router"/>
      <xs:enumeration value="router"/>
      <xs:enumeration value="end-device"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:complexType name="mesh_node">
    <xs:annotation><xs:documentation>A participant in a wireless mesh network. Unlike bus participants (shared medium) or chain hops (ordered forwarding), mesh nodes self-organize their routing topology. The mesh protocol handles path discovery, multi-hop forwarding, and self-healing.</xs:documentation></xs:annotation>
    <xs:attribute name="device" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Device (component) name that participates in this mesh. Must reference a comp defined in the HCDF.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="antenna" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Antenna name on the device used for mesh communication. Must reference an antenna defined on the referenced comp.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="role" type="MeshRole">
      <xs:annotation><xs:documentation>Role in the mesh: coordinator (forms and manages the network), border-router (bridges mesh to external network, e.g., Thread border router to Ethernet), router (relays traffic for other nodes), end-device (leaf node, does not relay). Default behavior is protocol-dependent.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="id" type="xs:string">
      <xs:annotation><xs:documentation>Node identifier within the mesh (e.g., Thread short address, BLE mesh unicast address, UWB node ID). Format is protocol-dependent.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="wireless_mesh">
    <xs:annotation><xs:documentation>Wireless mesh network where nodes self-organize routing topology. Unlike buses (shared medium, no routing) and chains (fixed forwarding order), mesh networks discover paths dynamically and can self-heal when nodes join or leave. Use for Thread/802.15.4 sensor meshes, BLE mesh sensor arrays, UWB positioning networks, and WiFi mesh (802.11s). The HCDF declares mesh membership and protocol — the routing protocol handles topology autonomously at runtime.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="description" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Human-readable description of the mesh network's purpose (e.g., "tactile skin sensors on left hand", "UWB positioning anchors").</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="node" type="mesh_node" minOccurs="1" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>A device participating in this mesh. At least one node should have role="coordinator" or role="border-router".</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Unique name for this mesh network (e.g., "hand-tactile-mesh", "uwb-anchors").</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="standard" type="xs:string" use="required">
      <xs:annotation><xs:documentation>PHY/MAC standard: 802.15.4 (Thread/Zigbee), bluetooth (BLE mesh), 802.11s (WiFi mesh), uwb, lora.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="protocol" type="xs:string">
      <xs:annotation><xs:documentation>Higher-layer mesh routing protocol: Thread, Zigbee, BLE-mesh, OpenThread, 802.11s, LoRa-mesh. The protocol determines how nodes discover each other, form routes, and self-heal.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="channel" type="xs:string">
      <xs:annotation><xs:documentation>RF channel or frequency band for the mesh (e.g., "15" for 802.15.4 channel 15, "2.4GHz"). Protocol-dependent.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="pan-id" type="xs:string">
      <xs:annotation><xs:documentation>Personal Area Network ID for 802.15.4-based meshes (Thread, Zigbee). 16-bit hex value (e.g., "0x1234"). Not applicable for BLE mesh or WiFi mesh.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="network-key-ref" type="xs:string">
      <xs:annotation><xs:documentation>Reference to the mesh network encryption key in an external key store. No actual keys in HCDF — only a reference for the agent to provision at runtime. Thread uses a 128-bit network key; BLE mesh uses NetKey/AppKey.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- ===== Network: unified container ===== -->

  <xs:complexType name="network">
    <xs:annotation><xs:documentation>Unified network description grouping physical topology (links, buses, chains, meshes) and network configuration (gPTP clock sync, TSN traffic classes, Qbv schedules, MACsec security, EEE policy, stream profiles). A robot can have multiple networks for independent domains (e.g., separate arm and base networks, a Thread sensor mesh).</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="description" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Human-readable description of the network's purpose and scope (e.g., "main TSN backbone", "left arm 802.3dm chain network").</xs:documentation></xs:annotation>
      </xs:element>
      <!-- Topology -->
      <xs:element name="link" type="link" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Point-to-point link connections (wired or wireless) in this network.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="bus" type="bus" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Shared-medium bus segments in this network.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="chain" type="chain" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Bridged daisy-chain segments in this network.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="mesh" type="wireless_mesh" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Wireless mesh networks (Thread, BLE mesh, UWB, WiFi mesh) in this network.</xs:documentation></xs:annotation>
      </xs:element>
      <!-- Configuration -->
      <xs:element name="gptp" type="gptp" minOccurs="0">
        <xs:annotation><xs:documentation>IEEE 802.1AS gPTP time synchronization configuration for this network.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="traffic-classes" type="traffic_classes" minOccurs="0">
        <xs:annotation><xs:documentation>Traffic class definitions mapping PCP values to queue priorities.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="schedule" type="schedule" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>IEEE 802.1Qbv Time-Aware Shaper schedule templates for this network.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="schedule-assignment" type="schedule_assignment" minOccurs="0">
        <xs:annotation><xs:documentation>Bindings of schedule templates to ports and chains.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="stream-profile" type="stream_profile_ref" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>References to external stream profile files defining TSN stream requirements.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="macsec" type="macsec_config" minOccurs="0">
        <xs:annotation><xs:documentation>Network-wide IEEE 802.1AE MACsec security policy and key store configuration.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="eee-policy" type="EeePolicyValue" minOccurs="0">
        <xs:annotation><xs:documentation>Network-wide IEEE 802.3az Energy Efficient Ethernet policy. "enabled" allows Low Power Idle; "disabled" keeps ports always active. Typically disabled for TSN networks.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Unique name for this network (e.g., "backbone", "arm_network", "sensor_bus_network"). Required.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- COMP, NETWORK-INTERNAL, SOFTWARE, DISCOVERY, EXTENSION, ROOT    -->
  <!-- ================================================================ -->

  <!-- Switch: a switching fabric that bridges ports together.
       Ports inside <switch> are bridged by the fabric.
       Ports directly on <comp> are independent (not bridged).
       A bridge is just a switch with no chip attribute. -->
  <xs:complexType name="switch_tsn">
    <xs:annotation><xs:documentation>TSN capabilities of a switch fabric (as opposed to per-port capabilities). Declares which TSN sub-standards the switch ASIC supports globally across all its bridged ports.</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="qbv" type="tsn_qbv_capability" minOccurs="0">
        <xs:annotation><xs:documentation>IEEE 802.1Qbv Time-Aware Shaper capability at the switch level.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="cbs" type="tsn_cbs_capability" minOccurs="0">
        <xs:annotation><xs:documentation>IEEE 802.1Qav Credit-Based Shaper capability at the switch level.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="psfp" type="tsn_psfp_capability" minOccurs="0">
        <xs:annotation><xs:documentation>IEEE 802.1Qci Per-Stream Filtering and Policing capability at the switch level.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="frer" type="tsn_frer_capability" minOccurs="0">
        <xs:annotation><xs:documentation>IEEE 802.1CB Frame Replication and Elimination for Reliability capability at the switch level.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="preemption" type="tsn_preemption_capability" minOccurs="0">
        <xs:annotation><xs:documentation>IEEE 802.1Qbu/802.3br frame preemption capability at the switch level.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="switch_macsec">
    <xs:annotation><xs:documentation>MACsec hardware capabilities of a switch fabric. Lists cipher suites supported by the switch ASIC's MACsec engine for all bridged ports.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="cipher" type="MacsecCipher" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>A MACsec cipher suite supported by the switch ASIC.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="switch">
    <xs:annotation><xs:documentation>Ethernet switching fabric that bridges ports together. Ports inside switch are connected by the switching ASIC and can forward frames between each other. Ports directly on comp (outside switch) are independent. The chip attribute identifies the switch IC (e.g., sja1110, s32n79-integrated). Omit chip for software bridges.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="port" type="port" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Ports bridged by this switch fabric. These ports can forward frames to each other through the switch ASIC.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="tsn" type="switch_tsn" minOccurs="0">
        <xs:annotation><xs:documentation>TSN capabilities of the switch ASIC (Qbv, CBS, PSFP, FRER, preemption).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="macsec" type="switch_macsec" minOccurs="0">
        <xs:annotation><xs:documentation>MACsec hardware cipher suites supported by the switch ASIC.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="chip" type="xs:string">
      <xs:annotation><xs:documentation>Switch ASIC identifier (e.g., "sja1110", "mv88e6393x", "s32n79-integrated"). Omit for software bridges (Linux bridge, OVS). Optional.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="software">
    <xs:annotation><xs:documentation>Firmware or software identity for a component. Used for firmware manifest tracking, version management, and over-the-air update planning.</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="version" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Firmware or software version string (e.g., "1.2.3", "v2024.03-rc1"). Semantic versioning recommended.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="hash" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>SHA-256 hash of the firmware binary for integrity verification and update tracking.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="firmware-manifest-uri" type="xs:anyURI" minOccurs="0">
        <xs:annotation><xs:documentation>URI of the firmware manifest file describing the full firmware package contents, dependencies, and update instructions.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="params" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Runtime configuration parameters string passed to the firmware at boot (e.g., DTS overlay name, boot arguments).</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
    <xs:attribute name="name" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Firmware or software package name (e.g., "zephyr-flight-controller", "linux-jetson-orin"). Required.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="discovered">
    <xs:annotation><xs:documentation>Runtime discovery state for a component. Populated by device discovery agents (mDNS, LLDP, EtherCAT scan) at runtime. Not typically authored by hand — updated automatically by HCDF tooling after network scanning.</xs:documentation></xs:annotation>
    <xs:all>
      <xs:element name="ip" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Discovered IP address of the component (e.g., "10.0.1.42"). Populated at runtime.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="port" type="xs:unsignedInt" minOccurs="0">
        <xs:annotation><xs:documentation>Discovered service port number (e.g., 8080 for a web interface, 7400 for DDS). Populated at runtime.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="last-seen" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>ISO 8601 timestamp of when the device was last seen online (e.g., "2026-04-05T10:30:00Z"). Populated at runtime by discovery agents.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="extension">
    <xs:annotation><xs:documentation>Vendor or domain-specific extension container. Allows embedding arbitrary XML content from external domains (e.g., simulation parameters, vendor-specific configurations, CI/CD metadata) without modifying the HCDF core schema. Content is processed with lax validation.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:any minOccurs="0" maxOccurs="unbounded" processContents="lax"/>
    </xs:sequence>
    <xs:attribute name="domain" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Namespace or domain identifier for the extension content (e.g., "gazebo", "isaac-sim", "vendor:mycompany", "ci:github-actions"). Required.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="version" type="xs:string">
      <xs:annotation><xs:documentation>Version of the extension schema for forward compatibility. Optional.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="include">
    <xs:annotation><xs:documentation>Include reference for model composition. Imports another HCDF file's components, joints, and networks into this document. Used to build complex robots from reusable sub-assemblies (e.g., arm module, leg module, sensor head). The included model's components are merged into this document with optional name prefix and pose offset.</xs:documentation></xs:annotation>
    <xs:attribute name="uri" type="xs:anyURI" use="required">
      <xs:annotation><xs:documentation>URI of the HCDF file to include (relative to this document or absolute). Required.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="sha" type="xs:string">
      <xs:annotation><xs:documentation>SHA-256 hash of the included file for content integrity verification. Optional but recommended for reproducible builds.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="name" type="xs:string">
      <xs:annotation><xs:documentation>Name prefix for all elements from the included file. Prevents name collisions when including the same module multiple times (e.g., "left_arm", "right_arm"). Optional.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="pose" type="xs:string">
      <xs:annotation><xs:documentation>Pose offset applied to all included components as "x y z roll pitch yaw" (meters and radians) relative to the including document's world frame. Optional; default: no offset.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- Component: rigid body / assembly.
       Ports inside <switch> are bridged by the switching fabric.
       Ports directly on <comp> are independent (not bridged).
       A device can have at most one switch and any number of independent ports. -->
  <xs:complexType name="comp">
    <xs:annotation><xs:documentation>A component representing a rigid body or hardware assembly. Contains physical properties (inertial, visual, collision), hardware interfaces (ports, antennas, sensors, motors), an optional switch (bridging fabric), firmware identity, and runtime discovery state. Equivalent to URDF's link element but extended with networking and cyber infrastructure.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="description" type="xs:string" minOccurs="0" maxOccurs="1">
        <xs:annotation><xs:documentation>Human-readable description of the component (e.g., "NVIDIA Jetson AGX Orin compute module", "shoulder actuator assembly").</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="board" type="xs:string" minOccurs="0" maxOccurs="1">
        <xs:annotation><xs:documentation>Board or hardware platform identifier (e.g., "jetson-agx-orin-64gb", "nxp-s32n79-evb", "custom-motor-driver-v3"). Used for BOM generation and hardware matching.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="operating-temp" type="range_value" minOccurs="0" maxOccurs="1">
        <xs:annotation><xs:documentation>Operating temperature range of this component. Use min and max attributes for the rated limits. Unit: "degC" (default). Example: min="-40" max="85" for automotive grade, min="0" max="70" for commercial grade, min="-40" max="125" for mil-spec. An agent uses this to validate that all components in a system can operate in the target environment. If the robot operates outdoors in winter (-20 degC), every component's operating-temp range must include that temperature. Components without operating-temp are assumed to have no specific constraint (or the constraint is unknown).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="inertial" type="inertial_properties" minOccurs="0" maxOccurs="1">
        <xs:annotation><xs:documentation>Inertial properties (mass, center of mass, inertia tensor) for dynamics simulation.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="visual" type="visual" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Visual representation(s) for 3D rendering. Multiple visuals per component for multi-part models.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="collision" type="collision" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Collision geometry for physics simulation. Multiple collision shapes per component for complex bounds.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="frame" type="frame" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Named coordinate frames attached to this component for sensor mounts, tool points, etc.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="switch" type="switch" minOccurs="0" maxOccurs="1">
        <xs:annotation><xs:documentation>Ethernet switch fabric on this component. At most one per component. Ports inside the switch are bridged; ports outside are independent.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="port" type="port" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Independent (non-bridged) ports on this component. Not connected through any switch fabric. Used for point-to-point connections and bus interfaces.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="antenna" type="antenna" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Wireless antennas on this component (WiFi, BLE, GNSS, UWB, etc.).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="sensor" type="sensor" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Sensor group(s) on this component. Each sensor element groups related sub-sensors (IMU, camera, etc.).</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="motor" type="motor" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Motor(s) or actuator(s) on this component. Connected to joints via transmission elements.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="hmi" type="hmi_element" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Human-machine interface elements (displays, speakers, LEDs, buttons) on this component.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="surface" type="surface_element" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Dynamic surfaces (aerofoils, control surfaces, propellers, wheels, tracks) on this component.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="power-source" type="power_source" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Energy storage (batteries, fuel tanks) on this component.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="software" type="software" minOccurs="0" maxOccurs="1">
        <xs:annotation><xs:documentation>Firmware or software identity running on this component. At most one per component.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="discovered" type="discovered" minOccurs="0" maxOccurs="1">
        <xs:annotation><xs:documentation>Runtime discovery state (IP, port, last-seen). Populated by discovery agents, not authored by hand.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="extension" type="extension" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Vendor or domain-specific extension data for this component.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Unique name for this component (e.g., "spine_soc", "left_shoulder", "wheel_fl_motor_driver"). Required. Used in joint parent/child references, port paths, and chain hop references.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="role" type="CompRole">
      <xs:annotation><xs:documentation>Functional role (sensor, compute, actuator, parent). Optional. Aids tooling in categorizing components for network planning and visualization.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="hwid" type="xs:string">
      <xs:annotation><xs:documentation>Hardware identifier for matching physical devices during discovery (e.g., serial number, MAC address prefix, or part number). Optional. Used by discovery agents to map physical hardware to HCDF components.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="struct-type" type="xs:string">
      <xs:annotation><xs:documentation>Structural classification of this component: fuselage, wing, boom, mast, hull, chassis, frame, arm, leg, tail, nacelle, pod. Optional — provides semantic context for the component's role in the robot's body architecture. Used by agents for high-level reasoning about robot morphology.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="ip-rating" type="xs:string">
      <xs:annotation><xs:documentation>Ingress Protection rating per IEC 60529 (e.g., "IP67", "IP68", "IP54") or NEMA enclosure type (e.g., "NEMA-4X", "NEMA-6P"). The two-digit IP code indicates protection against solids (first digit, 0-6) and liquids (second digit, 0-9K): IP54 = dust-protected + splash-proof. IP65 = dust-tight + water jets. IP67 = dust-tight + temporary immersion (1m, 30min). IP68 = dust-tight + continuous immersion (depth/duration defined by manufacturer). IP69K = dust-tight + high-pressure steam cleaning. An agent uses this to validate that all components meet the environmental requirements for the target deployment (outdoor, underwater, washdown). Components without ip-rating are assumed to have no specific protection (or the rating is unknown). Optional; free-form string to support both IP and NEMA systems.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- KINEMATIC STATES, GROUPS, COLLISION DISABLE                      -->
  <!-- ================================================================ -->

  <xs:complexType name="joint_position">
    <xs:annotation><xs:documentation>A single joint position value within a named kinematic state. References a joint by name and provides its position in radians (revolute/continuous) or meters (prismatic).</xs:documentation></xs:annotation>
    <xs:attribute name="joint" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Name of the joint this position applies to. Must reference an existing joint.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="value" type="xs:double" use="required">
      <xs:annotation><xs:documentation>Joint position value in radians (revolute, continuous) or meters (prismatic).</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="kinematic_state">
    <xs:annotation><xs:documentation>Named kinematic state (pose/keyframe) defining a joint configuration. Examples: "home" (standard ready position), "transport" (compact for shipping), "calibration" (known reference for sensor alignment). An AI agent can reference states by name instead of specifying individual joint angles. One state can be marked as default.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="description" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Human-readable description of this state's purpose.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="joint-position" type="joint_position" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>Position of a joint in this state. One per joint that differs from zero/default.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Unique name for this state (e.g., "home", "transport", "calibration", "pre-grasp").</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="default" type="xs:boolean" default="false">
      <xs:annotation><xs:documentation>If true, this is the default state used for visualization, collision checking, and as the starting configuration. At most one state should be default.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="group_joint_ref">
    <xs:annotation><xs:documentation>Reference to a joint within a group.</xs:documentation></xs:annotation>
    <xs:attribute name="ref" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Name of the joint to include in this group.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="group_ref">
    <xs:annotation><xs:documentation>Reference to another group (for nested/composite groups).</xs:documentation></xs:annotation>
    <xs:attribute name="ref" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Name of the group to include as a sub-group.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="joint_group">
    <xs:annotation><xs:documentation>Named collection of joints that can be planned and controlled as a unit. Groups enable efficient motion planning (plan for 7 arm joints, not 30+ total), task decomposition ("use left_arm to pick up cup"), and cross-embodiment transfer (different robots both define a "manipulation" group). Groups can contain other groups for hierarchical composition. Equivalent to SRDF joint groups.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="description" type="xs:string" minOccurs="0">
        <xs:annotation><xs:documentation>Human-readable description of this group's purpose.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="joint" type="group_joint_ref" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>A joint included in this group.</xs:documentation></xs:annotation>
      </xs:element>
      <xs:element name="group" type="group_ref" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>A sub-group included in this group (hierarchical composition).</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Unique name for this group (e.g., "left_arm", "right_hand", "locomotion", "head").</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="type" type="xs:string">
      <xs:annotation><xs:documentation>Group purpose type: "end-effector" (gripper/hand), "kinematic-chain" (arm/leg), "locomotion" (wheels/legs). Optional.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="tip-comp" type="xs:string">
      <xs:annotation><xs:documentation>For end-effector groups: the component at the tip of the kinematic chain (e.g., the hand palm link). Used for forward kinematics to the end-effector.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="tip-frame" type="xs:string">
      <xs:annotation><xs:documentation>For end-effector groups: the TCP (Tool Center Point) frame at the tip. References a frame name on the tip-comp.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="collision_pair">
    <xs:annotation><xs:documentation>A pair of components to skip for self-collision checking. Adjacent links, links on opposite sides of the robot, and always-in-contact pairs are common candidates.</xs:documentation></xs:annotation>
    <xs:attribute name="comp1" type="xs:string" use="required">
      <xs:annotation><xs:documentation>First component name.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="comp2" type="xs:string" use="required">
      <xs:annotation><xs:documentation>Second component name.</xs:documentation></xs:annotation>
    </xs:attribute>
    <xs:attribute name="reason" type="xs:string">
      <xs:annotation><xs:documentation>Why this pair is disabled: "adjacent" (share a joint), "unreachable" (physically can't collide), "mounted" (always in contact by design). Optional documentation.</xs:documentation></xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="self_collision_disable">
    <xs:annotation><xs:documentation>List of component pairs to skip for self-collision checking. Dramatically improves motion planning performance — typically 80%+ of all link pairs can be skipped. Equivalent to SRDF disable_collisions.</xs:documentation></xs:annotation>
    <xs:sequence>
      <xs:element name="pair" type="collision_pair" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation><xs:documentation>A pair of components to disable collision checking between.</xs:documentation></xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- ROOT ELEMENT                                                     -->
  <!-- ================================================================ -->

  <xs:element name="hcdf">
    <xs:complexType>
      <xs:annotation><xs:documentation>Root element of an HCDF cyber-physical robot description. Every HCDF file is a self-describing module: standalone robot descriptions and reusable sub-assemblies (arms, sensor heads, wheel modules) all use the same root element with the same metadata. When files are composed via include, each file retains its own name, author, and license, allowing tooling to trace provenance per sub-assembly and generate accurate bills of materials. Contains metadata, components (rigid bodies), joints (kinematic connections), joint groups, named kinematic states, self-collision configuration, networks (connectivity + TSN), transmissions (motor-to-joint), materials, and model composition includes.</xs:documentation></xs:annotation>
      <xs:sequence>
        <!-- Metadata: document-level information about this HCDF file -->
        <xs:element name="description" type="xs:string" minOccurs="0" maxOccurs="1">
          <xs:annotation><xs:documentation>Human-readable description of what this HCDF file describes. For a top-level robot: the robot's purpose and key characteristics (e.g., "CogniPilot humanoid mobile base research platform with dual 7-DOF arms and TSN backbone"). For a reusable sub-assembly: the module's function and interface (e.g., "7-DOF manipulator arm with HEBI X8-series SEA actuators, 802.3dm daisy-chain, and force/torque sensing at wrist"). Helps humans and AI agents understand the file's contents without parsing the full document.</xs:documentation></xs:annotation>
        </xs:element>
        <xs:element name="author" type="xs:string" minOccurs="0" maxOccurs="1">
          <xs:annotation><xs:documentation>Author or organization that created this HCDF file (e.g., "CogniPilot Foundation", "HEBI Robotics", "Jane Doe"). For composed systems, each included file retains its own author, allowing BOM tools to trace which vendor or team provided each sub-assembly. Optional.</xs:documentation></xs:annotation>
        </xs:element>
        <xs:element name="license" type="xs:string" minOccurs="0" maxOccurs="1">
          <xs:annotation><xs:documentation>License governing use of this HCDF file and the design it describes. Use SPDX license identifiers when possible (e.g., "Apache-2.0", "BSD-3-Clause", "MIT", "CERN-OHL-S-2.0" for open hardware, "LicenseRef-Proprietary" for closed designs). For composed systems, each included file can carry a different license, enabling mixed open-source and proprietary sub-assemblies. Optional.</xs:documentation></xs:annotation>
        </xs:element>
        <xs:element name="url" type="xs:anyURI" minOccurs="0" maxOccurs="1">
          <xs:annotation><xs:documentation>Canonical URL for this HCDF file's project, documentation, or source repository (e.g., "https://github.com/CogniPilot/hcdformat"). Provides a stable reference for humans and tooling to find updates, issues, and related resources. Optional.</xs:documentation></xs:annotation>
        </xs:element>
        <!-- Structure -->
        <xs:element name="comp" type="comp" minOccurs="0" maxOccurs="unbounded">
          <xs:annotation><xs:documentation>Component definitions (rigid bodies / hardware assemblies).</xs:documentation></xs:annotation>
        </xs:element>
        <xs:element name="joint" type="joint" minOccurs="0" maxOccurs="unbounded">
          <xs:annotation><xs:documentation>Kinematic joint connections between components.</xs:documentation></xs:annotation>
        </xs:element>
        <xs:element name="group" type="joint_group" minOccurs="0" maxOccurs="unbounded">
          <xs:annotation><xs:documentation>Named joint groups for planning and control (e.g., left_arm, locomotion).</xs:documentation></xs:annotation>
        </xs:element>
        <xs:element name="state" type="kinematic_state" minOccurs="0" maxOccurs="unbounded">
          <xs:annotation><xs:documentation>Named kinematic states / poses (e.g., home, transport).</xs:documentation></xs:annotation>
        </xs:element>
        <xs:element name="self-collision-disable" type="self_collision_disable" minOccurs="0" maxOccurs="1">
          <xs:annotation><xs:documentation>Component pairs to skip for self-collision checking.</xs:documentation></xs:annotation>
        </xs:element>
        <xs:element name="network" type="network" minOccurs="0" maxOccurs="unbounded">
          <xs:annotation><xs:documentation>Network definitions containing topology (links, buses, chains, meshes) and configuration (gPTP, TSN schedules, MACsec).</xs:documentation></xs:annotation>
        </xs:element>
        <xs:element name="transmission" type="transmission" minOccurs="0" maxOccurs="unbounded">
          <xs:annotation><xs:documentation>Motor-to-joint mechanical power transmissions.</xs:documentation></xs:annotation>
        </xs:element>
        <xs:element name="material" type="material_global" minOccurs="0" maxOccurs="unbounded">
          <xs:annotation><xs:documentation>Global material definitions (color, surface friction, restitution).</xs:documentation></xs:annotation>
        </xs:element>
        <xs:element name="include" type="include" minOccurs="0" maxOccurs="unbounded">
          <xs:annotation><xs:documentation>External HCDF file includes for model composition.</xs:documentation></xs:annotation>
        </xs:element>
      </xs:sequence>
      <xs:attribute name="name" type="xs:string" use="required">
        <xs:annotation><xs:documentation>Name of the robot, platform, or sub-assembly described by this file. Required. For top-level robot descriptions, this is the robot's model name (e.g., "cogni-humanoid-v2", "quadrotor-x500"). For reusable sub-assemblies, this is the module name (e.g., "7dof-arm", "stereo-head-v2", "hebi-x8-9"). When a file is imported via include, the include's name attribute provides the instance name (e.g., "left_arm"), while this attribute provides the module identity. Use lowercase-with-hyphens by convention.</xs:documentation></xs:annotation>
      </xs:attribute>
      <xs:attribute name="version" type="xs:string" default="1.0">
        <xs:annotation><xs:documentation>HCDF schema version this file conforms to. Current: 1.0. Parsers should accept documents with the same MAJOR version and ignore unknown elements for forward compatibility.</xs:documentation></xs:annotation>
      </xs:attribute>
      <xs:attribute name="body-frame" type="BodyFrame">
        <xs:annotation><xs:documentation>Body-frame axis convention for all pose values in this file. FLU (X-forward, Y-left, Z-up): common in ground robotics and humanoid platforms. FRD (X-forward, Y-right, Z-down): common in aerospace and flight controllers. All xyz and rpy values in this document are expressed in the specified body-frame convention. Optional; when omitted, consumers should not assume a default and must either infer from context or require explicit specification. Semantic rule: all files in an include chain must use the same body-frame.</xs:documentation></xs:annotation>
      </xs:attribute>
      <xs:attribute name="world-frame" type="WorldFrame">
        <xs:annotation><xs:documentation>World-frame (navigation/map frame) axis convention for global coordinates. ENU (X-east, Y-north, Z-up): common in GIS, surveying, and ground robotics. NED (X-north, Y-east, Z-down): common in aerospace, marine navigation, and flight controllers. Determines how global poses, waypoints, and map-relative coordinates are interpreted. Independent of body-frame. Optional; when omitted, consumers should not assume a default. Semantic rule: all files in an include chain must use the same world-frame.</xs:documentation></xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>

</xs:schema>
