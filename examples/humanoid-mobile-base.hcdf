<?xml version="1.0"?>
<!--
  HCDF 1.0 Humanoid Mobile Base
  19-device system: S32N79 + E810 + AGX Thor, dual 802.3dm arms (MCN1-4 + camera),
  S32J100 base zone controller, i.MX95 head, SPAD lidars, Cubtek radar,
  ZLAC8015D wheel drive (1722+CAN), MR-BMS771.

  5 separate networks: backbone, left-arm, right-arm, base, power
-->
<hcdf version="1.0" name="cogni-humanoid-mobile-base" body-frame="FLU" world-frame="ENU">
  <description>CogniPilot humanoid mobile base: S32N79 + E810 spine, AGX Thor compute, dual 802.3dm 7-DOF arms, S32J100 base zone, i.MX95 head, TSN backbone with MACsec</description>
  <author>CogniPilot Foundation</author>
  <license>Apache-2.0</license>
  <url>https://github.com/CogniPilot/hcdformat</url>

  <!-- ================================================================ -->
  <!-- COMPONENTS                                                       -->
  <!-- ================================================================ -->

  <!-- AGX Thor: perception, planning, ML inference -->
  <comp name="agx-thor" role="compute">
    <description>NVIDIA AGX Thor SoC — perception, planning, ML inference. 2x 25G MGBE uplinks to S32N79.</description>
    <board>nvidia-agx-thor</board>
    <inertial>
      <mass>1.5</mass>
      <com>0 0 0</com>
    </inertial>
    <port name="mgbe0" iface="eth0" type="ethernet">
      <capabilities>
        <speed unit="Mbps">25000</speed>
        <standard>25GBASE-SR</standard>
        <tsn>
          <gptp hw-timestamping="true" gm-capable="false"/>
          <qbv traffic-classes="8" hw-queues="8" max-gcl-entries="256"/>
          <preemption min-fragment-size="64"/>
        </tsn>
        <connector>SFP28</connector>
      </capabilities>
    </port>
    <port name="mgbe1" iface="eth1" type="ethernet">
      <capabilities>
        <speed unit="Mbps">25000</speed>
        <standard>25GBASE-SR</standard>
        <tsn>
          <gptp hw-timestamping="true" gm-capable="false"/>
          <qbv traffic-classes="8" hw-queues="8" max-gcl-entries="256"/>
          <preemption min-fragment-size="64"/>
        </tsn>
        <connector>SFP28</connector>
      </capabilities>
    </port>
    <port name="pwr_in" type="POWER">
      <capabilities>
        <voltage unit="V" min="20" max="29.2">24</voltage>
        <current unit="A" max="12.5">10</current>
        <power unit="W" max="300">200</power>
        <typical-power unit="W">150</typical-power>
      </capabilities>
    </port>
  </comp>

  <!-- S32N79: central motion control + CNC agent + integrated TSN switch + E810 PCIe -->
  <comp name="s32n79" role="compute">
    <description>NXP S32N79 — central motion control, CNC agent, integrated TSN switch. Intel E810 on PCIe for 25G uplink to AGX Thor.</description>
    <board>nxp-s32n79-evb</board>
    <inertial>
      <mass>0.8</mass>
      <com>0 0 0</com>
    </inertial>

    <!-- Integrated TSN switch fabric: XFI + QXGMII ports are bridged -->
    <switch chip="s32n79-integrated">
      <port name="xfi_left" iface="swp0" type="ethernet">
        <capabilities>
          <speed-tx unit="Mbps">100</speed-tx>
          <speed-rx unit="Mbps">10000</speed-rx>
          <standard>802.3dm</standard>
          <phy role="master"/>
          <tsn>
            <gptp hw-timestamping="true" gm-capable="true"/>
            <qbv traffic-classes="8" hw-queues="8" max-gcl-entries="512"/>
            <cbs/>
            <preemption min-fragment-size="64"/>
            <psfp max-filters="256" max-gates="256" max-meters="128"/>
            <frer seq-encoding="r-tag"/>
          </tsn>
          <macsec><cipher>gcm-aes-128</cipher></macsec>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="xfi_right" iface="swp1" type="ethernet">
        <capabilities>
          <speed-tx unit="Mbps">100</speed-tx>
          <speed-rx unit="Mbps">10000</speed-rx>
          <standard>802.3dm</standard>
          <phy role="master"/>
          <tsn>
            <gptp hw-timestamping="true" gm-capable="true"/>
            <qbv traffic-classes="8" hw-queues="8" max-gcl-entries="512"/>
            <cbs/>
            <preemption min-fragment-size="64"/>
            <psfp max-filters="256" max-gates="256" max-meters="128"/>
            <frer seq-encoding="r-tag"/>
          </tsn>
          <macsec><cipher>gcm-aes-128</cipher></macsec>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="qxgmii_p0" iface="swp2" type="ethernet">
        <capabilities>
          <speed unit="Mbps">2500</speed>
          <standard>2.5GBASE-T1</standard>
          <tsn>
            <gptp hw-timestamping="true" gm-capable="true"/>
            <qbv traffic-classes="8" hw-queues="8" max-gcl-entries="256"/>
            <cbs/>
            <preemption min-fragment-size="64"/>
            <psfp max-filters="128" max-gates="128" max-meters="64"/>
          </tsn>
          <macsec><cipher>gcm-aes-128</cipher></macsec>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="qxgmii_p1" iface="swp3" type="ethernet">
        <capabilities>
          <speed unit="Mbps">2500</speed>
          <standard>2.5GBASE-T1</standard>
          <tsn><gptp hw-timestamping="true" gm-capable="true"/></tsn>
          <macsec><cipher>gcm-aes-128</cipher></macsec>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="qxgmii_p2" iface="swp4" type="ethernet">
        <capabilities>
          <speed unit="Mbps">2500</speed>
          <standard>2.5GBASE-T1</standard>
          <tsn><gptp hw-timestamping="true" gm-capable="true"/></tsn>
          <macsec><cipher>gcm-aes-128</cipher></macsec>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="qxgmii_p3" iface="swp5" type="ethernet">
        <capabilities>
          <speed unit="Mbps">2500</speed>
          <standard>2.5GBASE-T1</standard>
          <tsn><gptp hw-timestamping="true" gm-capable="true"/></tsn>
          <macsec><cipher>gcm-aes-128</cipher></macsec>
          <eee supported="true"/>
        </capabilities>
      </port>
      <tsn>
        <qbv max-gcl-entries="2048"/>
        <cbs/>
        <psfp max-filters="1024" max-gates="1024"/>
        <frer seq-encoding="r-tag"/>
        <preemption min-fragment-size="64"/>
      </tsn>
      <macsec>
        <cipher>gcm-aes-128</cipher>
        <cipher>gcm-aes-256</cipher>
      </macsec>
    </switch>

    <!-- E810 25G uplinks — independent ports (NOT on the integrated switch) -->
    <port name="e810_p0" iface="enp1s0f0" type="ethernet">
      <capabilities>
        <speed unit="Mbps">25000</speed>
        <standard>25GBASE-SR</standard>
        <tsn>
          <gptp hw-timestamping="true" gm-capable="true"/>
          <qbv traffic-classes="8" hw-queues="8" max-gcl-entries="512"/>
          <cbs/>
          <preemption min-fragment-size="64"/>
        </tsn>
        <macsec><cipher>gcm-aes-256</cipher></macsec>
        <connector>SFP28</connector>
      </capabilities>
    </port>
    <port name="e810_p1" iface="enp1s0f1" type="ethernet">
      <capabilities>
        <speed unit="Mbps">25000</speed>
        <standard>25GBASE-SR</standard>
        <tsn>
          <gptp hw-timestamping="true" gm-capable="true"/>
          <qbv traffic-classes="8" hw-queues="8" max-gcl-entries="512"/>
          <cbs/>
          <preemption min-fragment-size="64"/>
        </tsn>
        <macsec><cipher>gcm-aes-256</cipher></macsec>
        <connector>SFP28</connector>
      </capabilities>
    </port>
    <port name="pwr_in" type="POWER">
      <capabilities>
        <voltage unit="V" min="20" max="29.2">24</voltage>
        <current unit="A" max="3">2</current>
        <power unit="W" max="72">48</power>
        <typical-power unit="W">35</typical-power>
      </capabilities>
    </port>
  </comp>

  <!-- S32J100: base zone controller — bridges Ethernet to CAN-FD + peripherals -->
  <comp name="s32j100" role="compute">
    <description>NXP S32J100 — base zone controller. Bridges Ethernet to CAN-FD (wheels, BMS) and base peripherals (lidars, radar, head). Decapsulates 1722+CAN from S32N79.</description>
    <board>nxp-s32j100-rdb</board>
    <inertial>
      <mass>0.3</mass>
      <com>0 0 0</com>
    </inertial>

    <switch chip="s32j100-integrated">
      <port name="eth_up0" iface="swp0" type="ethernet">
        <capabilities>
          <speed unit="Mbps">2500</speed>
          <standard>2.5GBASE-T1</standard>
          <tsn>
            <gptp hw-timestamping="true" gm-capable="false"/>
            <qbv traffic-classes="8" hw-queues="8" max-gcl-entries="128"/>
            <preemption min-fragment-size="64"/>
          </tsn>
          <macsec><cipher>gcm-aes-128</cipher></macsec>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="eth_up1" iface="swp1" type="ethernet">
        <capabilities>
          <speed unit="Mbps">2500</speed>
          <standard>2.5GBASE-T1</standard>
          <macsec><cipher>gcm-aes-128</cipher></macsec>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="eth_up2" iface="swp2" type="ethernet">
        <capabilities>
          <speed unit="Mbps">2500</speed>
          <standard>2.5GBASE-T1</standard>
          <macsec><cipher>gcm-aes-128</cipher></macsec>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="eth_up3" iface="swp3" type="ethernet">
        <capabilities>
          <speed unit="Mbps">2500</speed>
          <standard>2.5GBASE-T1</standard>
          <macsec><cipher>gcm-aes-128</cipher></macsec>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="eth_head" iface="swp4" type="ethernet">
        <capabilities>
          <speed unit="Mbps">1000</speed>
          <standard>1000BASE-T1</standard>
          <phy role="master"/>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="eth_lidar_front" iface="swp5" type="ethernet">
        <capabilities>
          <speed unit="Mbps">1000</speed>
          <standard>1000BASE-T1</standard>
          <phy role="master"/>
        </capabilities>
      </port>
      <port name="eth_lidar_rear" iface="swp6" type="ethernet">
        <capabilities>
          <speed unit="Mbps">1000</speed>
          <standard>1000BASE-T1</standard>
          <phy role="master"/>
        </capabilities>
      </port>
      <port name="eth_radar" iface="swp7" type="ethernet">
        <capabilities>
          <speed unit="Mbps">1000</speed>
          <standard>1000BASE-T1</standard>
          <phy role="master"/>
        </capabilities>
      </port>
    </switch>

    <port name="can0" iface="can0" type="CAN">
      <capabilities>
        <bitrate unit="bps">5000000</bitrate>
        <protocol>CAN-FD</protocol>
      </capabilities>
    </port>
    <port name="pwr_in" type="POWER">
      <capabilities>
        <voltage unit="V" min="20" max="29.2">24</voltage>
        <current unit="A" max="1.5">1</current>
        <power unit="W" max="36">24</power>
        <typical-power unit="W">18</typical-power>
      </capabilities>
    </port>
  </comp>

  <!-- i.MX95 head: display + microphones -->
  <comp name="head" role="compute">
    <description>i.MX95 head unit — display, microphones, user interaction</description>
    <board>nxp-imx95-evk</board>
    <inertial>
      <mass>0.6</mass>
      <com>0 0 0</com>
    </inertial>
    <port name="eth0" iface="eth0" type="ethernet">
      <capabilities>
        <speed unit="Mbps">1000</speed>
        <standard>1000BASE-T1</standard>
        <phy role="slave"/>
        <eee supported="true"/>
      </capabilities>
    </port>
    <port name="pwr_in" type="POWER">
      <capabilities>
        <voltage unit="V" min="20" max="29.2">24</voltage>
        <current unit="A" max="1">0.5</current>
        <power unit="W" max="24">12</power>
        <typical-power unit="W">8</typical-power>
      </capabilities>
    </port>
    <sensor name="mic_array">
      <force type="pressure">
        <range unit="dB">120</range>
      </force>
    </sensor>
  </comp>

  <!-- NXP SPAD front base lidar -->
  <comp name="lidar-front" role="sensor">
    <description>NXP SPAD front base lidar — solid-state, 200m range</description>
    <inertial>
      <mass>0.4</mass>
      <com>0 0 0</com>
    </inertial>
    <port name="eth0" iface="eth0" type="ethernet">
      <capabilities>
        <speed unit="Mbps">1000</speed>
        <standard>1000BASE-T1</standard>
        <phy role="slave"/>
      </capabilities>
    </port>
    <port name="pwr_in" type="POWER">
      <capabilities>
        <voltage unit="V" min="20" max="29.2">24</voltage>
        <current unit="A" max="1">0.6</current>
        <power unit="W" max="24">15</power>
        <typical-power unit="W">12</typical-power>
      </capabilities>
    </port>
    <sensor name="lidar_front_sensor" update-rate="20">
      <optical type="lidar">
        <fov name="scan" color="#00ff00">
          <geometry>
            <frustum shape="pyramidal">
              <near>0.5</near>
              <far>200.0</far>
              <hfov>2.094</hfov>
              <vfov>0.436</vfov>
            </frustum>
          </geometry>
        </fov>
        <data-output>
          <bandwidth unit="Mbps">400</bandwidth>
        </data-output>
        <lidar-params>
          <scan-type>solid-state</scan-type>
          <channels>64</channels>
          <points-per-second>600000</points-per-second>
          <scan-rate unit="Hz">20</scan-rate>
          <returns>dual</returns>
          <wavelength unit="nm">905</wavelength>
          <horizontal-fov unit="deg">120</horizontal-fov>
          <vertical-fov unit="deg" min="-12.5" max="12.5">25</vertical-fov>
        </lidar-params>
      </optical>
    </sensor>
  </comp>

  <!-- NXP SPAD rear base lidar -->
  <comp name="lidar-rear" role="sensor">
    <description>NXP SPAD rear base lidar — solid-state, 200m range</description>
    <inertial>
      <mass>0.4</mass>
      <com>0 0 0</com>
    </inertial>
    <port name="eth0" iface="eth0" type="ethernet">
      <capabilities>
        <speed unit="Mbps">1000</speed>
        <standard>1000BASE-T1</standard>
        <phy role="slave"/>
      </capabilities>
    </port>
    <port name="pwr_in" type="POWER">
      <capabilities>
        <voltage unit="V" min="20" max="29.2">24</voltage>
        <current unit="A" max="1">0.6</current>
        <power unit="W" max="24">15</power>
        <typical-power unit="W">12</typical-power>
      </capabilities>
    </port>
    <sensor name="lidar_rear_sensor" update-rate="20">
      <optical type="lidar">
        <fov name="scan" color="#00ff00">
          <geometry>
            <frustum shape="pyramidal">
              <near>0.5</near>
              <far>200.0</far>
              <hfov>2.094</hfov>
              <vfov>0.436</vfov>
            </frustum>
          </geometry>
        </fov>
        <data-output>
          <bandwidth unit="Mbps">400</bandwidth>
        </data-output>
        <lidar-params>
          <scan-type>solid-state</scan-type>
          <channels>64</channels>
          <points-per-second>600000</points-per-second>
          <scan-rate unit="Hz">20</scan-rate>
          <returns>dual</returns>
          <wavelength unit="nm">905</wavelength>
          <horizontal-fov unit="deg">120</horizontal-fov>
          <vertical-fov unit="deg" min="-12.5" max="12.5">25</vertical-fov>
        </lidar-params>
      </optical>
    </sensor>
  </comp>

  <!-- Cubtek 4D imaging radar -->
  <comp name="radar-4d" role="sensor">
    <description>Cubtek 4D imaging radar — 77GHz FMCW, 120-degree FOV</description>
    <inertial>
      <mass>0.3</mass>
      <com>0 0 0</com>
    </inertial>
    <port name="eth0" iface="eth0" type="ethernet">
      <capabilities>
        <speed unit="Mbps">1000</speed>
        <standard>1000BASE-T1</standard>
        <phy role="slave"/>
      </capabilities>
    </port>
    <port name="pwr_in" type="POWER">
      <capabilities>
        <voltage unit="V" min="20" max="29.2">24</voltage>
        <current unit="A" max="0.8">0.5</current>
        <power unit="W" max="20">12</power>
        <typical-power unit="W">10</typical-power>
      </capabilities>
    </port>
    <sensor name="radar_4d_sensor" update-rate="20">
      <rf type="radar">
        <range unit="m">200</range>
        <data-output>
          <bandwidth unit="Mbps">100</bandwidth>
        </data-output>
        <radar-params>
          <frequency unit="GHz">77</frequency>
          <modulation>fmcw</modulation>
          <azimuth-fov unit="deg">120</azimuth-fov>
          <elevation-fov unit="deg">30</elevation-fov>
          <azimuth-resolution unit="deg">1.0</azimuth-resolution>
          <elevation-resolution unit="deg">2.0</elevation-resolution>
          <range-resolution unit="m">0.1</range-resolution>
          <velocity-range unit="m/s" min="-60" max="60">60</velocity-range>
          <velocity-resolution unit="m/s">0.1</velocity-resolution>
          <max-detections>512</max-detections>
          <mimo>3tx4rx</mimo>
        </radar-params>
      </rf>
    </sensor>
  </comp>

  <!-- ZLAC8015D: dual-channel servo controller (separate from hub motors) -->
  <comp name="zlac8015d" role="actuator">
    <description>ZLTECH ZLAC8015D v4.0 dual-channel servo controller. Drives 2x ZLLG65ASM250-L hub motors via SIGNAL connectors. CANopen on CAN-FD bus.</description>
    <inertial>
      <mass>0.8</mass>
      <com>0 0 0</com>
    </inertial>
    <port name="can0" iface="can0" type="CAN">
      <capabilities>
        <bitrate unit="bps">1000000</bitrate>
        <protocol>CANopen</protocol>
      </capabilities>
    </port>
    <port name="sig_left" type="SIGNAL">
      <capabilities><connector>12-pin: encoder-AB, hall-UVW, NTC thermistor</connector></capabilities>
    </port>
    <port name="sig_right" type="SIGNAL">
      <capabilities><connector>12-pin: encoder-AB, hall-UVW, NTC thermistor</connector></capabilities>
    </port>
    <port name="phase_left" type="SIGNAL">
      <capabilities><connector>3-pin: BLDC phase U/V/W</connector></capabilities>
    </port>
    <port name="phase_right" type="SIGNAL">
      <capabilities><connector>3-pin: BLDC phase U/V/W</connector></capabilities>
    </port>
    <port name="pwr_in" type="POWER">
      <capabilities>
        <voltage unit="V" min="20" max="29.2">24</voltage>
        <current unit="A" max="40">10</current>
        <power unit="W" max="960">240</power>
        <typical-power unit="W">70</typical-power>
      </capabilities>
    </port>
  </comp>

  <!-- Left hub motor: ZLLG65ASM250-L -->
  <comp name="wheel-left" role="actuator">
    <description>ZLLG65ASM250-L 24V BLDC hub motor (left). 170mm diameter, 2.92 kg, 250W rated.</description>
    <inertial>
      <mass>2.92</mass>
      <com>0 0 0</com>
    </inertial>
    <port name="sig0" type="SIGNAL">
      <capabilities><connector>12-pin: encoder-AB, hall-UVW, NTC thermistor</connector></capabilities>
    </port>
    <port name="phase0" type="SIGNAL">
      <capabilities><connector>3-pin: BLDC phase U/V/W</connector></capabilities>
    </port>
    <port name="pwr_in" type="POWER">
      <capabilities>
        <voltage unit="V" min="20" max="29.2">24</voltage>
        <current unit="A" max="19">6.5</current>
        <power unit="W" max="456">156</power>
      </capabilities>
    </port>
    <sensor name="encoder_left">
      <encoder type="incremental" principle="magnetic">
        <resolution unit="counts">4096</resolution>
      </encoder>
    </sensor>
    <sensor name="hall_left">
      <em type="mag">
        <range unit="mT">100</range>
      </em>
    </sensor>
    <sensor name="temp_left">
      <temperature type="thermistor">
        <range unit="degC">150</range>
      </temperature>
    </sensor>
    <motor name="left_wheel_motor" type="bldc" encoder="encoder_left" hall="hall_left" thermistor="temp_left">
      <voltage unit="V" nominal="24" max="28"/>
      <current unit="A" continuous="6.5" peak="19"/>
      <resistance unit="ohm">0.5</resistance>
      <torque-constant unit="Nm/A">0.29</torque-constant>
      <velocity-constant unit="V/RPM">0.109</velocity-constant>
      <max-speed unit="rpm">260</max-speed>
      <stall-torque unit="Nm">19.76</stall-torque>
      <no-load-speed unit="rpm">257.9</no-load-speed>
      <no-load-current unit="A">0.974</no-load-current>
      <max-power-out unit="W">158.8</max-power-out>
      <max-efficiency unit="percent">68.4</max-efficiency>
      <control-modes>
        <mode>velocity</mode>
        <mode>position</mode>
        <mode>torque</mode>
      </control-modes>
    </motor>
    <surface name="left-wheel">
      <wheel type="driven">
        <radius unit="m">0.085</radius>
        <width unit="m">0.041</width>
        <friction static="0.9" dynamic="0.7"/>
      </wheel>
    </surface>
  </comp>

  <!-- Right hub motor: ZLLG65ASM250-L -->
  <comp name="wheel-right" role="actuator">
    <description>ZLLG65ASM250-L 24V BLDC hub motor (right). 170mm diameter, 2.92 kg, 250W rated.</description>
    <inertial>
      <mass>2.92</mass>
      <com>0 0 0</com>
    </inertial>
    <port name="sig0" type="SIGNAL">
      <capabilities><connector>12-pin: encoder-AB, hall-UVW, NTC thermistor</connector></capabilities>
    </port>
    <port name="phase0" type="SIGNAL">
      <capabilities><connector>3-pin: BLDC phase U/V/W</connector></capabilities>
    </port>
    <port name="pwr_in" type="POWER">
      <capabilities>
        <voltage unit="V" min="20" max="29.2">24</voltage>
        <current unit="A" max="19">6.5</current>
        <power unit="W" max="456">156</power>
      </capabilities>
    </port>
    <sensor name="encoder_right">
      <encoder type="incremental" principle="magnetic">
        <resolution unit="counts">4096</resolution>
      </encoder>
    </sensor>
    <sensor name="hall_right">
      <em type="mag">
        <range unit="mT">100</range>
      </em>
    </sensor>
    <sensor name="temp_right">
      <temperature type="thermistor">
        <range unit="degC">150</range>
      </temperature>
    </sensor>
    <motor name="right_wheel_motor" type="bldc" encoder="encoder_right" hall="hall_right" thermistor="temp_right">
      <voltage unit="V" nominal="24" max="28"/>
      <current unit="A" continuous="6.5" peak="19"/>
      <resistance unit="ohm">0.5</resistance>
      <torque-constant unit="Nm/A">0.29</torque-constant>
      <velocity-constant unit="V/RPM">0.109</velocity-constant>
      <max-speed unit="rpm">260</max-speed>
      <stall-torque unit="Nm">19.76</stall-torque>
      <no-load-speed unit="rpm">257.9</no-load-speed>
      <no-load-current unit="A">0.974</no-load-current>
      <max-power-out unit="W">158.8</max-power-out>
      <max-efficiency unit="percent">68.4</max-efficiency>
      <control-modes>
        <mode>velocity</mode>
        <mode>position</mode>
        <mode>torque</mode>
      </control-modes>
    </motor>
    <surface name="right-wheel">
      <wheel type="driven">
        <radius unit="m">0.085</radius>
        <width unit="m">0.041</width>
        <friction static="0.9" dynamic="0.7"/>
      </wheel>
    </surface>
  </comp>

  <!-- Omni caster front-left -->
  <comp name="caster-fl" role="parent">
    <description>Front-left passive omni caster wheel</description>
    <inertial>
      <mass>0.15</mass>
      <com>0 0 -0.015</com>
    </inertial>
    <surface name="caster">
      <wheel type="omni">
        <radius unit="m">0.025</radius>
        <width unit="m">0.02</width>
        <friction static="0.6" dynamic="0.4"/>
      </wheel>
    </surface>
  </comp>

  <!-- Omni caster front-right -->
  <comp name="caster-fr" role="parent">
    <description>Front-right passive omni caster wheel</description>
    <inertial>
      <mass>0.15</mass>
      <com>0 0 -0.015</com>
    </inertial>
    <surface name="caster">
      <wheel type="omni">
        <radius unit="m">0.025</radius>
        <width unit="m">0.02</width>
        <friction static="0.6" dynamic="0.4"/>
      </wheel>
    </surface>
  </comp>

  <!-- MR-BMS771: 8S LiFePO4 battery management system -->
  <comp name="bms" role="sensor">
    <description>CogniPilot MR-BMS771 — 8S LiFePO4 (~25.6V nominal). CAN-FD. Battery management + power distribution.</description>
    <inertial>
      <mass>3.0</mass>
      <com>0 0 0</com>
    </inertial>
    <port name="can0" iface="can0" type="CAN">
      <capabilities>
        <bitrate unit="bps">5000000</bitrate>
        <protocol>CAN-FD</protocol>
      </capabilities>
    </port>
    <port name="bat_out" type="POWER">
      <capabilities>
        <voltage unit="V" min="20" max="29.2">25.6</voltage>
        <current unit="A" max="36">20</current>
        <power unit="W" max="922">512</power>
      </capabilities>
    </port>
    <power-source name="main_battery">
      <battery>
        <chemistry>LiFePO4</chemistry>
        <cells-series>8</cells-series>
        <nominal-voltage unit="V">25.6</nominal-voltage>
        <capacity unit="Ah">12</capacity>
        <energy unit="Wh">307</energy>
        <max-discharge unit="C">3</max-discharge>
        <min-voltage unit="V">20.0</min-voltage>
        <max-voltage unit="V">29.2</max-voltage>
      </battery>
    </power-source>
  </comp>

  <!-- Chassis (root of kinematic tree) -->
  <comp name="chassis" role="parent" struct-type="chassis">
    <description>Mobile base chassis frame — structural root of kinematic tree</description>
    <inertial>
      <mass>45.0</mass>
      <com>0 0 0.15</com>
      <inertia>1.35 0 0 0.6 0 1.68</inertia>
    </inertial>
    <collision name="chassis_box">
      <geometry><box><size>0.6 0.4 0.3</size></box></geometry>
      <surface>
        <friction static="0.6" dynamic="0.4"/>
        <restitution>0.1</restitution>
      </surface>
    </collision>
  </comp>

  <!-- Torso (connects chassis to arms) -->
  <comp name="torso" struct-type="frame">
    <description>Upper body torso structure — mounts both arm chains</description>
    <inertial>
      <mass>8.0</mass>
      <com>0 0 0.2</com>
      <inertia>0.16 0 0 0.08 0 0.12</inertia>
    </inertial>
    <collision name="torso_box">
      <geometry><box><size>0.35 0.4 0.45</size></box></geometry>
      <surface>
        <friction static="0.5" dynamic="0.3"/>
      </surface>
    </collision>
  </comp>

  <!-- ===== LEFT ARM MCNs ===== -->

  <!-- MCN1-L: Left shoulder — 3 motors, 802.3dm switch bridge -->
  <comp name="mcn1-l" role="actuator">
    <description>Left Motor Control Node 1: Shoulder (3 BLDC motors — yaw, pitch, roll). 802.3dm bridging switch.</description>
    <inertial>
      <mass>1.2</mass>
      <com>0 0 -0.05</com>
    </inertial>
    <collision name="mcn1l_col">
      <geometry><cylinder><radius>0.04</radius><length>0.12</length></cylinder></geometry>
    </collision>

    <switch>
      <port name="eth0" iface="swp0" type="ethernet">
        <capabilities>
          <speed-tx unit="Mbps">10000</speed-tx>
          <speed-rx unit="Mbps">100</speed-rx>
          <standard>802.3dm</standard>
          <phy role="slave"/>
          <tsn>
            <gptp hw-timestamping="true" gm-capable="false"/>
            <qbv traffic-classes="8" hw-queues="8" max-gcl-entries="128"/>
            <preemption min-fragment-size="64"/>
          </tsn>
          <macsec><cipher>gcm-aes-128</cipher></macsec>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="eth1" iface="swp1" type="ethernet">
        <capabilities>
          <speed-tx unit="Mbps">100</speed-tx>
          <speed-rx unit="Mbps">10000</speed-rx>
          <standard>802.3dm</standard>
          <phy role="master"/>
          <tsn>
            <gptp hw-timestamping="true" gm-capable="false"/>
            <qbv traffic-classes="8" hw-queues="8" max-gcl-entries="128"/>
            <preemption min-fragment-size="64"/>
          </tsn>
          <macsec><cipher>gcm-aes-128</cipher></macsec>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="eth2" iface="swp2" type="ethernet">
        <capabilities>
          <speed-tx unit="Mbps">100</speed-tx>
          <speed-rx unit="Mbps">10000</speed-rx>
          <standard>802.3dm</standard>
          <phy role="master"/>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="sgmii0" iface="swp3" type="ethernet">
        <capabilities>
          <speed unit="Mbps">1000</speed>
          <standard>SGMII</standard>
        </capabilities>
      </port>
    </switch>

    <port name="pwr_in" type="POWER">
      <capabilities>
        <voltage unit="V" min="20" max="29.2">24</voltage>
        <current unit="A" max="6">3</current>
        <power unit="W" max="144">72</power>
        <typical-power unit="W">25</typical-power>
      </capabilities>
    </port>

    <sensor name="shoulder_l_encoders">
      <encoder type="incremental" principle="magnetic">
        <resolution unit="counts">4096</resolution>
      </encoder>
      <encoder type="incremental" principle="magnetic">
        <resolution unit="counts">4096</resolution>
      </encoder>
      <encoder type="incremental" principle="magnetic">
        <resolution unit="counts">4096</resolution>
      </encoder>
    </sensor>
    <motor name="shoulder_yaw_motor" type="bldc" encoder="shoulder_l_encoders">
      <torque-constant unit="Nm/A">0.12</torque-constant>
      <max-speed unit="rpm">5000</max-speed>
    </motor>
    <motor name="shoulder_pitch_motor" type="bldc" encoder="shoulder_l_encoders">
      <torque-constant unit="Nm/A">0.15</torque-constant>
      <max-speed unit="rpm">4000</max-speed>
    </motor>
    <motor name="shoulder_roll_motor" type="bldc" encoder="shoulder_l_encoders">
      <torque-constant unit="Nm/A">0.10</torque-constant>
      <max-speed unit="rpm">5000</max-speed>
    </motor>
  </comp>

  <!-- MCN2-L: Left elbow — 1 motor -->
  <comp name="mcn2-l" role="actuator">
    <description>Left Motor Control Node 2: Elbow (1 BLDC motor)</description>
    <inertial>
      <mass>0.8</mass>
      <com>0 0 -0.04</com>
    </inertial>
    <collision name="mcn2l_col">
      <geometry><cylinder><radius>0.035</radius><length>0.1</length></cylinder></geometry>
    </collision>

    <switch>
      <port name="eth0" iface="swp0" type="ethernet">
        <capabilities>
          <speed-tx unit="Mbps">10000</speed-tx>
          <speed-rx unit="Mbps">100</speed-rx>
          <standard>802.3dm</standard>
          <phy role="slave"/>
          <tsn>
            <gptp hw-timestamping="true" gm-capable="false"/>
            <qbv traffic-classes="8" hw-queues="8" max-gcl-entries="128"/>
            <preemption min-fragment-size="64"/>
          </tsn>
          <macsec><cipher>gcm-aes-128</cipher></macsec>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="eth1" iface="swp1" type="ethernet">
        <capabilities>
          <speed-tx unit="Mbps">100</speed-tx>
          <speed-rx unit="Mbps">10000</speed-rx>
          <standard>802.3dm</standard>
          <phy role="master"/>
          <tsn>
            <gptp hw-timestamping="true" gm-capable="false"/>
            <qbv traffic-classes="8" hw-queues="8" max-gcl-entries="128"/>
            <preemption min-fragment-size="64"/>
          </tsn>
          <macsec><cipher>gcm-aes-128</cipher></macsec>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="eth2" iface="swp2" type="ethernet">
        <capabilities>
          <speed-tx unit="Mbps">100</speed-tx>
          <speed-rx unit="Mbps">10000</speed-rx>
          <standard>802.3dm</standard>
          <phy role="master"/>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="sgmii0" iface="swp3" type="ethernet">
        <capabilities>
          <speed unit="Mbps">1000</speed>
          <standard>SGMII</standard>
        </capabilities>
      </port>
    </switch>

    <port name="pwr_in" type="POWER">
      <capabilities>
        <voltage unit="V" min="20" max="29.2">24</voltage>
        <current unit="A" max="4">2</current>
        <power unit="W" max="96">48</power>
        <typical-power unit="W">15</typical-power>
      </capabilities>
    </port>

    <sensor name="elbow_l_encoder">
      <encoder type="incremental" principle="magnetic">
        <resolution unit="counts">4096</resolution>
      </encoder>
    </sensor>
    <motor name="elbow_l_motor" type="bldc" encoder="elbow_l_encoder">
      <torque-constant unit="Nm/A">0.12</torque-constant>
      <max-speed unit="rpm">5000</max-speed>
    </motor>
  </comp>

  <!-- MCN3-L: Left wrist — 2 motors + camera port + TCP frame -->
  <comp name="mcn3-l" role="actuator">
    <description>Left Motor Control Node 3: Wrist (2 BLDC motors — pitch, roll) + camera spur port</description>
    <inertial>
      <mass>0.6</mass>
      <com>0 0 -0.03</com>
    </inertial>
    <collision name="mcn3l_col">
      <geometry><cylinder><radius>0.03</radius><length>0.08</length></cylinder></geometry>
    </collision>

    <frame name="tcp_left" type="tcp">
      <description>Left arm tool center point for end-effector control</description>
      <pose>0 0 -0.12 0 0 0</pose>
    </frame>

    <switch>
      <port name="eth0" iface="swp0" type="ethernet">
        <capabilities>
          <speed-tx unit="Mbps">10000</speed-tx>
          <speed-rx unit="Mbps">100</speed-rx>
          <standard>802.3dm</standard>
          <phy role="slave"/>
          <tsn>
            <gptp hw-timestamping="true" gm-capable="false"/>
            <qbv traffic-classes="8" hw-queues="8" max-gcl-entries="128"/>
            <preemption min-fragment-size="64"/>
          </tsn>
          <macsec><cipher>gcm-aes-128</cipher></macsec>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="eth1" iface="swp1" type="ethernet">
        <capabilities>
          <speed-tx unit="Mbps">100</speed-tx>
          <speed-rx unit="Mbps">1000</speed-rx>
          <standard>802.3dm</standard>
          <phy role="master"/>
          <tsn>
            <gptp hw-timestamping="true" gm-capable="false"/>
            <qbv traffic-classes="8" hw-queues="4" max-gcl-entries="64"/>
            <preemption min-fragment-size="64"/>
          </tsn>
          <macsec><cipher>gcm-aes-128</cipher></macsec>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="eth2" iface="swp2" type="ethernet">
        <capabilities>
          <speed-tx unit="Mbps">100</speed-tx>
          <speed-rx unit="Mbps">10000</speed-rx>
          <standard>802.3dm</standard>
          <phy role="master"/>
          <tsn>
            <gptp hw-timestamping="true" gm-capable="false"/>
            <qbv traffic-classes="8" hw-queues="8" max-gcl-entries="128"/>
          </tsn>
          <eee supported="false"/>
        </capabilities>
      </port>
      <port name="sgmii0" iface="swp3" type="ethernet">
        <capabilities>
          <speed unit="Mbps">1000</speed>
          <standard>SGMII</standard>
        </capabilities>
      </port>
    </switch>

    <port name="pwr_in" type="POWER">
      <capabilities>
        <voltage unit="V" min="20" max="29.2">24</voltage>
        <current unit="A" max="3">1.5</current>
        <power unit="W" max="72">36</power>
        <typical-power unit="W">12</typical-power>
      </capabilities>
    </port>

    <sensor name="wrist_l_encoders">
      <encoder type="incremental" principle="magnetic">
        <resolution unit="counts">4096</resolution>
      </encoder>
      <encoder type="incremental" principle="magnetic">
        <resolution unit="counts">4096</resolution>
      </encoder>
    </sensor>
    <motor name="wrist_pitch_l_motor" type="bldc" encoder="wrist_l_encoders">
      <torque-constant unit="Nm/A">0.08</torque-constant>
      <max-speed unit="rpm">6000</max-speed>
    </motor>
    <motor name="wrist_roll_l_motor" type="bldc" encoder="wrist_l_encoders">
      <torque-constant unit="Nm/A">0.06</torque-constant>
      <max-speed unit="rpm">8000</max-speed>
    </motor>
  </comp>

  <!-- MCN4-L: Left dextrous hand -->
  <comp name="mcn4-l" role="actuator">
    <description>Left Motor Control Node 4: Dextrous hand (many small BLDC motors for finger articulation)</description>
    <inertial>
      <mass>0.4</mass>
      <com>0 0 -0.02</com>
    </inertial>
    <collision name="mcn4l_col">
      <geometry><box><size>0.08 0.06 0.04</size></box></geometry>
    </collision>

    <switch>
      <port name="eth0" iface="swp0" type="ethernet">
        <capabilities>
          <speed-tx unit="Mbps">1000</speed-tx>
          <speed-rx unit="Mbps">100</speed-rx>
          <standard>802.3dm</standard>
          <phy role="slave"/>
          <tsn>
            <gptp hw-timestamping="true" gm-capable="false"/>
            <qbv traffic-classes="8" hw-queues="4" max-gcl-entries="64"/>
            <preemption min-fragment-size="64"/>
          </tsn>
          <macsec><cipher>gcm-aes-128</cipher></macsec>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="eth1" iface="swp1" type="ethernet">
        <capabilities>
          <speed-tx unit="Mbps">100</speed-tx>
          <speed-rx unit="Mbps">1000</speed-rx>
          <standard>802.3dm</standard>
          <phy role="master"/>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="eth2" iface="swp2" type="ethernet">
        <capabilities>
          <speed-tx unit="Mbps">100</speed-tx>
          <speed-rx unit="Mbps">1000</speed-rx>
          <standard>802.3dm</standard>
          <phy role="master"/>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="sgmii0" iface="swp3" type="ethernet">
        <capabilities>
          <speed unit="Mbps">1000</speed>
          <standard>SGMII</standard>
        </capabilities>
      </port>
    </switch>

    <port name="pwr_in" type="POWER">
      <capabilities>
        <voltage unit="V" min="20" max="29.2">24</voltage>
        <current unit="A" max="3">1</current>
        <power unit="W" max="72">24</power>
        <typical-power unit="W">10</typical-power>
      </capabilities>
    </port>
  </comp>

  <!-- Left wrist stereo camera -->
  <comp name="cam-l" role="sensor">
    <description>Left wrist stereo camera — ~7 Gbps raw via 802.3dm upstream to S32N79</description>
    <inertial>
      <mass>0.05</mass>
      <com>0 0 0</com>
    </inertial>
    <port name="eth0" iface="eth0" type="ethernet">
      <capabilities>
        <speed-tx unit="Mbps">10000</speed-tx>
        <speed-rx unit="Mbps">100</speed-rx>
        <standard>802.3dm</standard>
        <phy role="slave"/>
        <tsn><gptp hw-timestamping="true" gm-capable="false"/></tsn>
        <eee supported="false"/>
      </capabilities>
    </port>
    <port name="pwr_in" type="POWER">
      <capabilities>
        <voltage unit="V" min="20" max="29.2">24</voltage>
        <current unit="A" max="0.3">0.2</current>
        <power unit="W" max="7">5</power>
        <typical-power unit="W">4</typical-power>
      </capabilities>
    </port>
    <sensor name="stereo_cam_l" update-rate="30">
      <optical type="camera">
        <fov name="left_eye" color="#44ff44">
          <geometry>
            <frustum shape="pyramidal">
              <near>0.1</near>
              <far>20.0</far>
              <hfov>1.22</hfov>
              <vfov>0.96</vfov>
            </frustum>
          </geometry>
          <intrinsics>
            <width>1920</width>
            <height>1080</height>
            <format>RGB8</format>
            <fx>960</fx>
            <fy>960</fy>
            <cx>960</cx>
            <cy>540</cy>
          </intrinsics>
        </fov>
        <fov name="right_eye" color="#4444ff">
          <pose>-0.06 0 0 0 0 0</pose>
          <geometry>
            <frustum shape="pyramidal">
              <near>0.1</near>
              <far>20.0</far>
              <hfov>1.22</hfov>
              <vfov>0.96</vfov>
            </frustum>
          </geometry>
        </fov>
        <data-output>
          <bandwidth unit="Mbps">7000</bandwidth>
          <frame-size unit="bytes">6220800</frame-size>
        </data-output>
        <camera-params>
          <shutter>global</shutter>
          <hdr>true</hdr>
          <compression>raw</compression>
          <trigger>hardware</trigger>
        </camera-params>
      </optical>
    </sensor>
  </comp>

  <!-- ===== RIGHT ARM MCNs (mirror of left) ===== -->

  <!-- MCN1-R: Right shoulder — 3 motors -->
