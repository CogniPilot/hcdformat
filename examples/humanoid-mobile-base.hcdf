    <sensor name="shoulder_r_encoders">
      <encoder type="incremental" principle="magnetic">
        <resolution unit="counts">4096</resolution>
      </encoder>
      <encoder type="incremental" principle="magnetic">
        <resolution unit="counts">4096</resolution>
      </encoder>
      <encoder type="incremental" principle="magnetic">
        <resolution unit="counts">4096</resolution>
      </encoder>
    </sensor>
    <motor name="shoulder_yaw_r_motor" type="bldc" encoder="shoulder_r_encoders">
      <torque-constant unit="Nm/A">0.12</torque-constant>
      <max-speed unit="rpm">5000</max-speed>
    </motor>
    <motor name="shoulder_pitch_r_motor" type="bldc" encoder="shoulder_r_encoders">
      <torque-constant unit="Nm/A">0.15</torque-constant>
      <max-speed unit="rpm">4000</max-speed>
    </motor>
    <motor name="shoulder_roll_r_motor" type="bldc" encoder="shoulder_r_encoders">
      <torque-constant unit="Nm/A">0.10</torque-constant>
      <max-speed unit="rpm">5000</max-speed>
    </motor>
  </comp>

  <!-- MCN2-R: Right elbow — 1 motor -->
  <comp name="mcn2-r" role="actuator">
    <description>Right Motor Control Node 2: Elbow (1 BLDC motor)</description>
    <inertial>
      <mass>0.8</mass>
      <com>0 0 -0.04</com>
    </inertial>
    <collision name="mcn2r_col">
      <geometry><cylinder><radius>0.035</radius><length>0.1</length></cylinder></geometry>
    </collision>

    <switch>
      <port name="eth0" iface="swp0" type="ethernet">
        <capabilities>
          <speed-tx unit="Mbps">10000</speed-tx>
          <speed-rx unit="Mbps">100</speed-rx>
          <standard>802.3dm</standard>
          <phy role="slave"/>
          <tsn>
            <gptp hw-timestamping="true" gm-capable="false"/>
            <qbv traffic-classes="8" hw-queues="8" max-gcl-entries="128"/>
            <preemption min-fragment-size="64"/>
          </tsn>
          <macsec><cipher>gcm-aes-128</cipher></macsec>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="eth1" iface="swp1" type="ethernet">
        <capabilities>
          <speed-tx unit="Mbps">100</speed-tx>
          <speed-rx unit="Mbps">10000</speed-rx>
          <standard>802.3dm</standard>
          <phy role="master"/>
          <tsn>
            <gptp hw-timestamping="true" gm-capable="false"/>
            <qbv traffic-classes="8" hw-queues="8" max-gcl-entries="128"/>
            <preemption min-fragment-size="64"/>
          </tsn>
          <macsec><cipher>gcm-aes-128</cipher></macsec>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="eth2" iface="swp2" type="ethernet">
        <capabilities>
          <speed-tx unit="Mbps">100</speed-tx>
          <speed-rx unit="Mbps">10000</speed-rx>
          <standard>802.3dm</standard>
          <phy role="master"/>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="sgmii0" iface="swp3" type="ethernet">
        <capabilities>
          <speed unit="Mbps">1000</speed>
          <standard>SGMII</standard>
        </capabilities>
      </port>
    </switch>

    <port name="pwr_in" type="POWER">
      <capabilities>
        <voltage unit="V" min="20" max="29.2">24</voltage>
        <current unit="A" max="4">2</current>
        <power unit="W" max="96">48</power>
        <typical-power unit="W">15</typical-power>
      </capabilities>
    </port>

    <sensor name="elbow_r_encoder">
      <encoder type="incremental" principle="magnetic">
        <resolution unit="counts">4096</resolution>
      </encoder>
    </sensor>
    <motor name="elbow_r_motor" type="bldc" encoder="elbow_r_encoder">
      <torque-constant unit="Nm/A">0.12</torque-constant>
      <max-speed unit="rpm">5000</max-speed>
    </motor>
  </comp>

  <!-- MCN3-R: Right wrist — 2 motors + camera port + TCP frame -->
  <comp name="mcn3-r" role="actuator">
    <description>Right Motor Control Node 3: Wrist (2 BLDC motors — pitch, roll) + camera spur port</description>
    <inertial>
      <mass>0.6</mass>
      <com>0 0 -0.03</com>
    </inertial>
    <collision name="mcn3r_col">
      <geometry><cylinder><radius>0.03</radius><length>0.08</length></cylinder></geometry>
    </collision>

    <frame name="tcp_right" type="tcp">
      <description>Right arm tool center point for end-effector control</description>
      <pose>0 0 -0.12 0 0 0</pose>
    </frame>

    <switch>
      <port name="eth0" iface="swp0" type="ethernet">
        <capabilities>
          <speed-tx unit="Mbps">10000</speed-tx>
          <speed-rx unit="Mbps">100</speed-rx>
          <standard>802.3dm</standard>
          <phy role="slave"/>
          <tsn>
            <gptp hw-timestamping="true" gm-capable="false"/>
            <qbv traffic-classes="8" hw-queues="8" max-gcl-entries="128"/>
            <preemption min-fragment-size="64"/>
          </tsn>
          <macsec><cipher>gcm-aes-128</cipher></macsec>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="eth1" iface="swp1" type="ethernet">
        <capabilities>
          <speed-tx unit="Mbps">100</speed-tx>
          <speed-rx unit="Mbps">1000</speed-rx>
          <standard>802.3dm</standard>
          <phy role="master"/>
          <tsn>
            <gptp hw-timestamping="true" gm-capable="false"/>
            <qbv traffic-classes="8" hw-queues="4" max-gcl-entries="64"/>
            <preemption min-fragment-size="64"/>
          </tsn>
          <macsec><cipher>gcm-aes-128</cipher></macsec>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="eth2" iface="swp2" type="ethernet">
        <capabilities>
          <speed-tx unit="Mbps">100</speed-tx>
          <speed-rx unit="Mbps">10000</speed-rx>
          <standard>802.3dm</standard>
          <phy role="master"/>
          <tsn>
            <gptp hw-timestamping="true" gm-capable="false"/>
            <qbv traffic-classes="8" hw-queues="8" max-gcl-entries="128"/>
          </tsn>
          <eee supported="false"/>
        </capabilities>
      </port>
      <port name="sgmii0" iface="swp3" type="ethernet">
        <capabilities>
          <speed unit="Mbps">1000</speed>
          <standard>SGMII</standard>
        </capabilities>
      </port>
    </switch>

    <port name="pwr_in" type="POWER">
      <capabilities>
        <voltage unit="V" min="20" max="29.2">24</voltage>
        <current unit="A" max="3">1.5</current>
        <power unit="W" max="72">36</power>
        <typical-power unit="W">12</typical-power>
      </capabilities>
    </port>

    <sensor name="wrist_r_encoders">
      <encoder type="incremental" principle="magnetic">
        <resolution unit="counts">4096</resolution>
      </encoder>
      <encoder type="incremental" principle="magnetic">
        <resolution unit="counts">4096</resolution>
      </encoder>
    </sensor>
    <motor name="wrist_pitch_r_motor" type="bldc" encoder="wrist_r_encoders">
      <torque-constant unit="Nm/A">0.08</torque-constant>
      <max-speed unit="rpm">6000</max-speed>
    </motor>
    <motor name="wrist_roll_r_motor" type="bldc" encoder="wrist_r_encoders">
      <torque-constant unit="Nm/A">0.06</torque-constant>
      <max-speed unit="rpm">8000</max-speed>
    </motor>
  </comp>

  <!-- MCN4-R: Right dextrous hand -->
  <comp name="mcn4-r" role="actuator">
    <description>Right Motor Control Node 4: Dextrous hand (many small BLDC motors for finger articulation)</description>
    <inertial>
      <mass>0.4</mass>
      <com>0 0 -0.02</com>
    </inertial>
    <collision name="mcn4r_col">
      <geometry><box><size>0.08 0.06 0.04</size></box></geometry>
    </collision>

    <switch>
      <port name="eth0" iface="swp0" type="ethernet">
        <capabilities>
          <speed-tx unit="Mbps">1000</speed-tx>
          <speed-rx unit="Mbps">100</speed-rx>
          <standard>802.3dm</standard>
          <phy role="slave"/>
          <tsn>
            <gptp hw-timestamping="true" gm-capable="false"/>
            <qbv traffic-classes="8" hw-queues="4" max-gcl-entries="64"/>
            <preemption min-fragment-size="64"/>
          </tsn>
          <macsec><cipher>gcm-aes-128</cipher></macsec>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="eth1" iface="swp1" type="ethernet">
        <capabilities>
          <speed-tx unit="Mbps">100</speed-tx>
          <speed-rx unit="Mbps">1000</speed-rx>
          <standard>802.3dm</standard>
          <phy role="master"/>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="eth2" iface="swp2" type="ethernet">
        <capabilities>
          <speed-tx unit="Mbps">100</speed-tx>
          <speed-rx unit="Mbps">1000</speed-rx>
          <standard>802.3dm</standard>
          <phy role="master"/>
          <eee supported="true"/>
        </capabilities>
      </port>
      <port name="sgmii0" iface="swp3" type="ethernet">
        <capabilities>
          <speed unit="Mbps">1000</speed>
          <standard>SGMII</standard>
        </capabilities>
      </port>
    </switch>

    <port name="pwr_in" type="POWER">
      <capabilities>
        <voltage unit="V" min="20" max="29.2">24</voltage>
        <current unit="A" max="3">1</current>
        <power unit="W" max="72">24</power>
        <typical-power unit="W">10</typical-power>
      </capabilities>
    </port>
  </comp>

  <!-- Right wrist stereo camera -->
  <comp name="cam-r" role="sensor">
    <description>Right wrist stereo camera — ~7 Gbps raw via 802.3dm upstream to S32N79</description>
    <inertial>
      <mass>0.05</mass>
      <com>0 0 0</com>
    </inertial>
    <port name="eth0" iface="eth0" type="ethernet">
      <capabilities>
        <speed-tx unit="Mbps">10000</speed-tx>
        <speed-rx unit="Mbps">100</speed-rx>
        <standard>802.3dm</standard>
        <phy role="slave"/>
        <tsn><gptp hw-timestamping="true" gm-capable="false"/></tsn>
        <eee supported="false"/>
      </capabilities>
    </port>
    <port name="pwr_in" type="POWER">
      <capabilities>
        <voltage unit="V" min="20" max="29.2">24</voltage>
        <current unit="A" max="0.3">0.2</current>
        <power unit="W" max="7">5</power>
        <typical-power unit="W">4</typical-power>
      </capabilities>
    </port>
    <sensor name="stereo_cam_r" update-rate="30">
      <optical type="camera">
        <fov name="left_eye" color="#44ff44">
          <geometry>
            <frustum shape="pyramidal">
              <near>0.1</near>
              <far>20.0</far>
              <hfov>1.22</hfov>
              <vfov>0.96</vfov>
            </frustum>
          </geometry>
          <intrinsics>
            <width>1920</width>
            <height>1080</height>
            <format>RGB8</format>
            <fx>960</fx>
            <fy>960</fy>
            <cx>960</cx>
            <cy>540</cy>
          </intrinsics>
        </fov>
        <fov name="right_eye" color="#4444ff">
          <pose>-0.06 0 0 0 0 0</pose>
          <geometry>
            <frustum shape="pyramidal">
              <near>0.1</near>
              <far>20.0</far>
              <hfov>1.22</hfov>
              <vfov>0.96</vfov>
            </frustum>
          </geometry>
        </fov>
        <data-output>
          <bandwidth unit="Mbps">7000</bandwidth>
          <frame-size unit="bytes">6220800</frame-size>
        </data-output>
        <camera-params>
          <shutter>global</shutter>
          <hdr>true</hdr>
          <compression>raw</compression>
          <trigger>hardware</trigger>
        </camera-params>
      </optical>
    </sensor>
  </comp>

  <!-- ================================================================ -->
  <!-- JOINTS (kinematic tree)                                          -->
  <!-- ================================================================ -->

  <!-- Base structure -->
  <joint name="chassis_to_torso" type="fixed">
    <parent comp="chassis"/>
    <child comp="torso"/>
    <origin xyz="0 0 0.35"/>
  </joint>

  <joint name="chassis_to_s32n79" type="fixed">
    <parent comp="chassis"/>
    <child comp="s32n79"/>
    <origin xyz="0.1 0 0.05"/>
  </joint>

  <joint name="chassis_to_agx_thor" type="fixed">
    <parent comp="chassis"/>
    <child comp="agx-thor"/>
    <origin xyz="-0.1 0 0.05"/>
  </joint>

  <joint name="chassis_to_s32j100" type="fixed">
    <parent comp="chassis"/>
    <child comp="s32j100"/>
    <origin xyz="0 0 0.02"/>
  </joint>

  <joint name="chassis_to_zlac8015d" type="fixed">
    <parent comp="chassis"/>
    <child comp="zlac8015d"/>
    <origin xyz="0 0 -0.05"/>
  </joint>

  <joint name="chassis_to_wheel_left" type="continuous">
    <parent comp="chassis"/>
    <child comp="wheel-left"/>
    <origin xyz="-0.15 0.18 -0.1"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="chassis_to_wheel_right" type="continuous">
    <parent comp="chassis"/>
    <child comp="wheel-right"/>
    <origin xyz="-0.15 -0.18 -0.1"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="chassis_to_bms" type="fixed">
    <parent comp="chassis"/>
    <child comp="bms"/>
    <origin xyz="0 0 0.1"/>
  </joint>

  <joint name="chassis_to_caster_fl" type="continuous">
    <parent comp="chassis"/>
    <child comp="caster-fl"/>
    <origin xyz="0.25 0.15 -0.15"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="chassis_to_caster_fr" type="continuous">
    <parent comp="chassis"/>
    <child comp="caster-fr"/>
    <origin xyz="0.25 -0.15 -0.15"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="torso_to_head" type="fixed">
    <parent comp="torso"/>
    <child comp="head"/>
    <origin xyz="0 0 0.4"/>
  </joint>

  <joint name="chassis_to_lidar_front" type="fixed">
    <parent comp="chassis"/>
    <child comp="lidar-front"/>
    <origin xyz="0.3 0 0.15" rpy="0 0 0"/>
  </joint>

  <joint name="chassis_to_lidar_rear" type="fixed">
    <parent comp="chassis"/>
    <child comp="lidar-rear"/>
    <origin xyz="-0.3 0 0.15" rpy="0 0 3.14159"/>
  </joint>

  <joint name="chassis_to_radar" type="fixed">
    <parent comp="chassis"/>
    <child comp="radar-4d"/>
    <origin xyz="0.3 0 0.2" rpy="0 0 0"/>
  </joint>

  <!-- Left arm joints -->
  <joint name="l_shoulder_yaw" type="revolute">
    <parent comp="torso"/>
    <child comp="mcn1-l"/>
    <origin xyz="0 0.18 0.25" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.96" upper="2.96" effort="50" velocity="3.14"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <joint name="l_elbow" type="revolute">
    <parent comp="mcn1-l"/>
    <child comp="mcn2-l"/>
    <origin xyz="0 0 -0.3" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="2.5" effort="30" velocity="3.14"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <joint name="l_wrist_pitch" type="revolute">
    <parent comp="mcn2-l"/>
    <child comp="mcn3-l"/>
    <origin xyz="0 0 -0.25" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="6.28"/>
    <dynamics damping="0.1" friction="0.02"/>
  </joint>

  <joint name="l_hand" type="fixed">
    <parent comp="mcn3-l"/>
    <child comp="mcn4-l"/>
    <origin xyz="0 0 -0.1"/>
  </joint>

  <joint name="l_cam_mount" type="fixed">
    <parent comp="mcn3-l"/>
    <child comp="cam-l"/>
    <origin xyz="0.03 0 -0.02" rpy="0 0.3 0"/>
  </joint>

  <!-- Right arm joints -->
  <joint name="r_shoulder_yaw" type="revolute">
    <parent comp="torso"/>
    <child comp="mcn1-r"/>
    <origin xyz="0 -0.18 0.25" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.96" upper="2.96" effort="50" velocity="3.14"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <joint name="r_elbow" type="revolute">
    <parent comp="mcn1-r"/>
    <child comp="mcn2-r"/>
    <origin xyz="0 0 -0.3"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="2.5" effort="30" velocity="3.14"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <joint name="r_wrist_pitch" type="revolute">
    <parent comp="mcn2-r"/>
    <child comp="mcn3-r"/>
    <origin xyz="0 0 -0.25"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="6.28"/>
    <dynamics damping="0.1" friction="0.02"/>
  </joint>

  <joint name="r_hand" type="fixed">
    <parent comp="mcn3-r"/>
    <child comp="mcn4-r"/>
    <origin xyz="0 0 -0.1"/>
  </joint>

  <joint name="r_cam_mount" type="fixed">
    <parent comp="mcn3-r"/>
    <child comp="cam-r"/>
    <origin xyz="0.03 0 -0.02" rpy="0 0.3 0"/>
  </joint>

  <!-- ================================================================ -->
  <!-- GROUPS                                                           -->
  <!-- ================================================================ -->

  <group name="left_arm" type="kinematic-chain">
    <description>Left arm kinematic chain (shoulder to wrist)</description>
    <joint ref="l_shoulder_yaw"/>
    <joint ref="l_elbow"/>
    <joint ref="l_wrist_pitch"/>
  </group>

  <group name="right_arm" type="kinematic-chain">
    <description>Right arm kinematic chain (shoulder to wrist)</description>
    <joint ref="r_shoulder_yaw"/>
    <joint ref="r_elbow"/>
    <joint ref="r_wrist_pitch"/>
  </group>

  <group name="left_hand" type="end-effector" tip-comp="mcn4-l">
    <description>Left dextrous hand</description>
    <joint ref="l_hand"/>
  </group>

  <group name="right_hand" type="end-effector" tip-comp="mcn4-r">
    <description>Right dextrous hand</description>
    <joint ref="r_hand"/>
  </group>

  <group name="left_manipulation">
    <description>Left arm + hand for manipulation tasks</description>
    <group ref="left_arm"/>
    <group ref="left_hand"/>
  </group>

  <group name="right_manipulation">
    <description>Right arm + hand for manipulation tasks</description>
    <group ref="right_arm"/>
    <group ref="right_hand"/>
  </group>

  <group name="locomotion" type="locomotion">
    <description>Differential drive wheels + passive casters</description>
    <joint ref="chassis_to_wheel_left"/>
    <joint ref="chassis_to_wheel_right"/>
    <joint ref="chassis_to_caster_fl"/>
    <joint ref="chassis_to_caster_fr"/>
  </group>

  <group name="head_group">
    <description>Head unit for display and microphone interaction</description>
    <joint ref="torso_to_head"/>
  </group>

  <!-- ================================================================ -->
  <!-- STATES (named kinematic configurations)                          -->
  <!-- ================================================================ -->

  <state name="home" default="true">
    <description>Default home position — arms at sides, elbows slightly bent</description>
    <joint-position joint="l_shoulder_yaw" value="0"/>
    <joint-position joint="l_elbow" value="0.5"/>
    <joint-position joint="l_wrist_pitch" value="0"/>
    <joint-position joint="r_shoulder_yaw" value="0"/>
    <joint-position joint="r_elbow" value="0.5"/>
    <joint-position joint="r_wrist_pitch" value="0"/>
  </state>

  <state name="transport">
    <description>Compact transport position — arms folded tight against torso</description>
    <joint-position joint="l_shoulder_yaw" value="0"/>
    <joint-position joint="l_elbow" value="2.4"/>
    <joint-position joint="l_wrist_pitch" value="1.0"/>
    <joint-position joint="r_shoulder_yaw" value="0"/>
    <joint-position joint="r_elbow" value="2.4"/>
    <joint-position joint="r_wrist_pitch" value="1.0"/>
  </state>

  <!-- ================================================================ -->
  <!-- SELF-COLLISION DISABLE                                           -->
  <!-- ================================================================ -->

  <self-collision-disable>
    <!-- Left arm adjacent pairs -->
    <pair comp1="torso" comp2="mcn1-l" reason="adjacent"/>
    <pair comp1="mcn1-l" comp2="mcn2-l" reason="adjacent"/>
    <pair comp1="mcn2-l" comp2="mcn3-l" reason="adjacent"/>
    <pair comp1="mcn3-l" comp2="mcn4-l" reason="adjacent"/>
    <pair comp1="mcn3-l" comp2="cam-l" reason="mounted"/>
    <!-- Right arm adjacent pairs -->
    <pair comp1="torso" comp2="mcn1-r" reason="adjacent"/>
    <pair comp1="mcn1-r" comp2="mcn2-r" reason="adjacent"/>
    <pair comp1="mcn2-r" comp2="mcn3-r" reason="adjacent"/>
    <pair comp1="mcn3-r" comp2="mcn4-r" reason="adjacent"/>
    <pair comp1="mcn3-r" comp2="cam-r" reason="mounted"/>
    <!-- Cross-body pairs that cannot collide -->
    <pair comp1="mcn1-l" comp2="mcn1-r" reason="unreachable"/>
    <pair comp1="mcn2-l" comp2="mcn2-r" reason="unreachable"/>
    <!-- Chassis-mounted -->
    <pair comp1="chassis" comp2="torso" reason="adjacent"/>
    <pair comp1="chassis" comp2="s32n79" reason="mounted"/>
    <pair comp1="chassis" comp2="agx-thor" reason="mounted"/>
    <pair comp1="chassis" comp2="s32j100" reason="mounted"/>
    <pair comp1="chassis" comp2="zlac8015d" reason="mounted"/>
    <pair comp1="chassis" comp2="wheel-left" reason="adjacent"/>
    <pair comp1="chassis" comp2="wheel-right" reason="adjacent"/>
    <pair comp1="chassis" comp2="bms" reason="mounted"/>
    <pair comp1="chassis" comp2="lidar-front" reason="mounted"/>
    <pair comp1="chassis" comp2="lidar-rear" reason="mounted"/>
    <pair comp1="chassis" comp2="radar-4d" reason="mounted"/>
    <pair comp1="chassis" comp2="caster-fl" reason="adjacent"/>
    <pair comp1="chassis" comp2="caster-fr" reason="adjacent"/>
    <pair comp1="torso" comp2="head" reason="adjacent"/>
  </self-collision-disable>

  <!-- ================================================================ -->
  <!-- NETWORKS                                                         -->
  <!-- ================================================================ -->

  <!-- Network 1: Backbone (S32N79 E810 <-> AGX Thor 25G) -->
  <network name="backbone">
    <description>25G backbone between S32N79 (E810 PCIe NIC) and AGX Thor. Dual redundant links.</description>

    <link name="s32n79_to_thor_p0">
      <wired standard="25gbase-sr">
        <port>s32n79/e810_p0</port>
        <port>agx-thor/mgbe0</port>
        <vlan id="1"/>
      </wired>
    </link>
    <link name="s32n79_to_thor_p1">
      <wired standard="25gbase-sr">
        <port>s32n79/e810_p1</port>
        <port>agx-thor/mgbe1</port>
        <vlan id="1"/>
      </wired>
    </link>

    <gptp domain="0">
      <clock device="s32n79" port="e810_p0" gm-capable="true" priority1="128" priority2="128"/>
      <clock device="agx-thor" port="mgbe0" gm-capable="false" priority1="255" priority2="255"/>
      <port-defaults log-sync-interval="-3" log-announce-interval="0" log-pdelay-req-interval="0" neighbor-prop-delay-thresh-ns="800"/>
    </gptp>

    <traffic-classes count="8">
      <class tc="7" pcp="7" name="ptp" preemption="express"/>
      <class tc="6" pcp="6" name="safety" preemption="express"/>
      <class tc="5" pcp="5" name="motion" preemption="express"/>
      <class tc="4" pcp="4" name="sensor" preemption="express"/>
      <class tc="3" pcp="3" name="camera" preemption="preemptable"/>
      <class tc="2" pcp="2" name="lidar" preemption="preemptable"/>
      <class tc="1" pcp="1" name="config" preemption="preemptable"/>
      <class tc="0" pcp="0" name="bulk" preemption="preemptable"/>
    </traffic-classes>

    <schedule name="uplink-1ms" cycle-time-us="1000">
      <gate tc-mask="0x80" duration-us="10"/>
      <gate tc-mask="0x60" duration-us="40"/>
      <gate tc-mask="0x10" duration-us="30"/>
      <gate tc-mask="0x0F" duration-us="920"/>
    </schedule>

    <schedule-assignment>
      <assign schedule="uplink-1ms" ports="s32n79/e810_p0 s32n79/e810_p1 agx-thor/mgbe0 agx-thor/mgbe1"/>
    </schedule-assignment>

    <macsec policy="must-secure" cipher="gcm-aes-256">
      <key-store type="tpm" ref="tpm0"/>
    </macsec>

    <eee-policy>disabled</eee-policy>
  </network>

  <!-- Network 2: Left arm 802.3dm chain -->
  <network name="left-arm">
    <description>Left arm 802.3dm daisy-chain: S32N79 XFI -> MCN1-L -> MCN2-L -> MCN3-L -> MCN4-L, camera spur at MCN3-L</description>

    <chain name="left-arm-chain" type="802.3dm" mode="switched">
      <description>Left arm motor chain (10G upstream / 100M downstream) with wrist camera spur</description>
      <vlan id="10" pcp="5"/>
      <macsec policy="must-secure" cipher="gcm-aes-128" key-agreement="psk" key-ref="arm-left-keys"/>
      <hop device="s32n79" port="xfi_left" role="root"/>
      <hop device="mcn1-l" ingress="eth0" egress="eth1"/>
      <hop device="mcn2-l" ingress="eth0" egress="eth1"/>
      <hop device="mcn3-l" ingress="eth0" egress="eth1">
        <spur device="cam-l" port="eth0" via="eth2">
          <description>Left wrist stereo camera (~7 Gbps upstream)</description>
          <vlan id="20" pcp="3"/>
        </spur>
      </hop>
      <hop device="mcn4-l" ingress="eth0" role="tail"/>
    </chain>

    <gptp domain="1">
      <clock device="s32n79" port="xfi_left" gm-capable="true" priority1="128" priority2="128"/>
      <clock device="mcn1-l" port="eth0" gm-capable="false" priority1="255" priority2="255"/>
      <clock device="mcn2-l" port="eth0" gm-capable="false" priority1="255" priority2="255"/>
      <clock device="mcn3-l" port="eth0" gm-capable="false" priority1="255" priority2="255"/>
      <clock device="mcn4-l" port="eth0" gm-capable="false" priority1="255" priority2="255"/>
      <clock device="cam-l" port="eth0" gm-capable="false" priority1="255" priority2="255"/>
      <port-defaults log-sync-interval="-3" log-announce-interval="0" log-pdelay-req-interval="0" neighbor-prop-delay-thresh-ns="2000"/>
    </gptp>

    <traffic-classes count="8">
      <class tc="7" pcp="7" name="ptp" preemption="express"/>
      <class tc="6" pcp="6" name="safety" preemption="express"/>
      <class tc="5" pcp="5" name="motion" preemption="express"/>
      <class tc="4" pcp="4" name="sensor" preemption="express"/>
      <class tc="3" pcp="3" name="camera" preemption="preemptable"/>
      <class tc="2" pcp="2" name="lidar" preemption="preemptable"/>
      <class tc="1" pcp="1" name="config" preemption="preemptable"/>
      <class tc="0" pcp="0" name="bulk" preemption="preemptable"/>
    </traffic-classes>

    <schedule name="arm-chain-1ms" cycle-time-us="1000">
      <gate tc-mask="0x80" duration-us="20"/>
      <gate tc-mask="0x60" duration-us="80"/>
      <gate tc-mask="0x10" duration-us="50"/>
      <gate tc-mask="0x0F" duration-us="850"/>
    </schedule>

    <schedule name="hand-link-1ms" cycle-time-us="1000">
      <gate tc-mask="0x80" duration-us="20"/>
      <gate tc-mask="0x60" duration-us="100"/>
      <gate tc-mask="0x10" duration-us="80"/>
      <gate tc-mask="0x0F" duration-us="800"/>
    </schedule>

    <schedule-assignment>
      <assign schedule="arm-chain-1ms" chains="left-arm-chain"/>
      <assign schedule="hand-link-1ms" ports="mcn3-l/eth1 mcn4-l/eth0"/>
    </schedule-assignment>

    <stream-profile uri="profiles/operational.streams.xml" active="true"/>

    <macsec policy="must-secure" cipher="gcm-aes-128" key-agreement="psk">
      <key-store type="secure-element" ref="se051"/>
    </macsec>

    <eee-policy>disabled</eee-policy>
  </network>

  <!-- Network 3: Right arm 802.3dm chain (mirror of left) -->
  <network name="right-arm">
    <description>Right arm 802.3dm daisy-chain: S32N79 XFI -> MCN1-R -> MCN2-R -> MCN3-R -> MCN4-R, camera spur at MCN3-R</description>

    <chain name="right-arm-chain" type="802.3dm" mode="switched">
      <description>Right arm motor chain (10G upstream / 100M downstream) with wrist camera spur</description>
      <vlan id="11" pcp="5"/>
      <macsec policy="must-secure" cipher="gcm-aes-128" key-agreement="psk" key-ref="arm-right-keys"/>
      <hop device="s32n79" port="xfi_right" role="root"/>
      <hop device="mcn1-r" ingress="eth0" egress="eth1"/>
      <hop device="mcn2-r" ingress="eth0" egress="eth1"/>
      <hop device="mcn3-r" ingress="eth0" egress="eth1">
        <spur device="cam-r" port="eth0" via="eth2">
          <description>Right wrist stereo camera (~7 Gbps upstream)</description>
          <vlan id="21" pcp="3"/>
        </spur>
      </hop>
      <hop device="mcn4-r" ingress="eth0" role="tail"/>
    </chain>

    <gptp domain="2">
      <clock device="s32n79" port="xfi_right" gm-capable="true" priority1="128" priority2="128"/>
      <clock device="mcn1-r" port="eth0" gm-capable="false" priority1="255" priority2="255"/>
      <clock device="mcn2-r" port="eth0" gm-capable="false" priority1="255" priority2="255"/>
      <clock device="mcn3-r" port="eth0" gm-capable="false" priority1="255" priority2="255"/>
      <clock device="mcn4-r" port="eth0" gm-capable="false" priority1="255" priority2="255"/>
      <clock device="cam-r" port="eth0" gm-capable="false" priority1="255" priority2="255"/>
      <port-defaults log-sync-interval="-3" log-announce-interval="0" log-pdelay-req-interval="0" neighbor-prop-delay-thresh-ns="2000"/>
    </gptp>

    <traffic-classes count="8">
      <class tc="7" pcp="7" name="ptp" preemption="express"/>
      <class tc="6" pcp="6" name="safety" preemption="express"/>
      <class tc="5" pcp="5" name="motion" preemption="express"/>
      <class tc="4" pcp="4" name="sensor" preemption="express"/>
      <class tc="3" pcp="3" name="camera" preemption="preemptable"/>
      <class tc="2" pcp="2" name="lidar" preemption="preemptable"/>
      <class tc="1" pcp="1" name="config" preemption="preemptable"/>
      <class tc="0" pcp="0" name="bulk" preemption="preemptable"/>
    </traffic-classes>

    <schedule name="arm-chain-1ms" cycle-time-us="1000">
      <gate tc-mask="0x80" duration-us="20"/>
      <gate tc-mask="0x60" duration-us="80"/>
      <gate tc-mask="0x10" duration-us="50"/>
      <gate tc-mask="0x0F" duration-us="850"/>
    </schedule>

    <schedule name="hand-link-1ms" cycle-time-us="1000">
      <gate tc-mask="0x80" duration-us="20"/>
      <gate tc-mask="0x60" duration-us="100"/>
      <gate tc-mask="0x10" duration-us="80"/>
      <gate tc-mask="0x0F" duration-us="800"/>
    </schedule>

    <schedule-assignment>
      <assign schedule="arm-chain-1ms" chains="right-arm-chain"/>
      <assign schedule="hand-link-1ms" ports="mcn3-r/eth1 mcn4-r/eth0"/>
    </schedule-assignment>

    <stream-profile uri="profiles/operational.streams.xml" active="true"/>

    <macsec policy="must-secure" cipher="gcm-aes-128" key-agreement="psk">
      <key-store type="secure-element" ref="se051"/>
    </macsec>

    <eee-policy>disabled</eee-policy>
  </network>

  <!-- Network 4: Base zone (S32N79 -> S32J100 -> peripherals + CAN) -->
  <network name="base">
    <description>Base zone network: S32N79 QXGMII to S32J100, S32J100 to peripherals (head, lidars, radar), CAN-FD bus (wheels, BMS)</description>

    <!-- QXGMII links: S32N79 -> S32J100 (4x 2.5G) -->
    <link name="n79_to_j100_p0">
      <wired standard="2.5gbase-t1">
        <port>s32n79/qxgmii_p0</port>
        <port>s32j100/eth_up0</port>
        <vlan id="30"/>
        <macsec policy="must-secure" cipher="gcm-aes-128" key-agreement="psk" key-ref="link-n79-j100-0"/>
      </wired>
    </link>
    <link name="n79_to_j100_p1">
      <wired standard="2.5gbase-t1">
        <port>s32n79/qxgmii_p1</port>
        <port>s32j100/eth_up1</port>
        <vlan id="30"/>
        <macsec policy="must-secure" cipher="gcm-aes-128" key-agreement="psk" key-ref="link-n79-j100-1"/>
      </wired>
    </link>
    <link name="n79_to_j100_p2">
      <wired standard="2.5gbase-t1">
        <port>s32n79/qxgmii_p2</port>
        <port>s32j100/eth_up2</port>
        <vlan id="30"/>
        <macsec policy="must-secure" cipher="gcm-aes-128" key-agreement="psk" key-ref="link-n79-j100-2"/>
      </wired>
    </link>
    <link name="n79_to_j100_p3">
      <wired standard="2.5gbase-t1">
        <port>s32n79/qxgmii_p3</port>
        <port>s32j100/eth_up3</port>
        <vlan id="30"/>
        <macsec policy="must-secure" cipher="gcm-aes-128" key-agreement="psk" key-ref="link-n79-j100-3"/>
      </wired>
    </link>

    <!-- S32J100 -> base peripherals -->
    <link name="j100_to_head">
      <wired standard="1000base-t1">
        <port>s32j100/eth_head</port>
        <port>head/eth0</port>
        <vlan id="40"/>
      </wired>
    </link>
    <link name="j100_to_lidar_f">
      <wired standard="1000base-t1">
        <port>s32j100/eth_lidar_front</port>
        <port>lidar-front/eth0</port>
        <vlan id="50"/>
      </wired>
    </link>
    <link name="j100_to_lidar_r">
      <wired standard="1000base-t1">
        <port>s32j100/eth_lidar_rear</port>
        <port>lidar-rear/eth0</port>
        <vlan id="50"/>
      </wired>
    </link>
    <link name="j100_to_radar">
      <wired standard="1000base-t1">
        <port>s32j100/eth_radar</port>
        <port>radar-4d/eth0</port>
        <vlan id="50"/>
      </wired>
    </link>

    <!-- SIGNAL links: ZLAC8015D controller -> hub motors -->
    <link name="zlac_to_wheel_left_sig">
      <wired standard="signal">
        <port>zlac8015d/sig_left</port>
        <port>wheel-left/sig0</port>
      </wired>
    </link>
    <link name="zlac_to_wheel_left_phase">
      <wired standard="signal">
        <port>zlac8015d/phase_left</port>
        <port>wheel-left/phase0</port>
      </wired>
    </link>
    <link name="zlac_to_wheel_right_sig">
      <wired standard="signal">
        <port>zlac8015d/sig_right</port>
        <port>wheel-right/sig0</port>
      </wired>
    </link>
    <link name="zlac_to_wheel_right_phase">
      <wired standard="signal">
        <port>zlac8015d/phase_right</port>
        <port>wheel-right/phase0</port>
      </wired>
    </link>

    <!-- CAN-FD bus: S32J100 -> ZLAC8015D + BMS -->
    <bus name="base_can" type="CAN" topology="daisy-chain">
      <bitrate>5000000</bitrate>
      <standard>CAN-FD</standard>
      <participant device="s32j100" port="can0" role="controller" position="1"/>
      <participant device="zlac8015d" port="can0" position="2" id="0x601">
        <protocol>CANopen</protocol>
      </participant>
      <participant device="bms" port="can0" position="3" id="0x610" terminator="true">
        <protocol>CAN-FD</protocol>
      </participant>
    </bus>

    <gptp domain="3">
      <clock device="s32n79" port="qxgmii_p0" gm-capable="true" priority1="128" priority2="128"/>
      <clock device="s32j100" port="eth_up0" gm-capable="false" priority1="255" priority2="255"/>
      <port-defaults log-sync-interval="-3" log-announce-interval="0" log-pdelay-req-interval="0" neighbor-prop-delay-thresh-ns="2000"/>
    </gptp>

    <traffic-classes count="8">
      <class tc="7" pcp="7" name="ptp" preemption="express"/>
      <class tc="6" pcp="6" name="safety" preemption="express"/>
      <class tc="5" pcp="5" name="motion" preemption="express"/>
      <class tc="4" pcp="4" name="sensor" preemption="express"/>
      <class tc="3" pcp="3" name="camera" preemption="preemptable"/>
      <class tc="2" pcp="2" name="lidar" preemption="preemptable"/>
      <class tc="1" pcp="1" name="config" preemption="preemptable"/>
      <class tc="0" pcp="0" name="bulk" preemption="preemptable"/>
    </traffic-classes>

    <schedule name="base-2ms" cycle-time-us="2000">
      <gate tc-mask="0x80" duration-us="20"/>
      <gate tc-mask="0x60" duration-us="100"/>
      <gate tc-mask="0x1C" duration-us="880"/>
      <gate tc-mask="0x03" duration-us="1000"/>
    </schedule>

    <schedule-assignment>
      <assign schedule="base-2ms" ports="s32n79/qxgmii_p0 s32n79/qxgmii_p1 s32n79/qxgmii_p2 s32n79/qxgmii_p3 s32j100/eth_up0 s32j100/eth_up1 s32j100/eth_up2 s32j100/eth_up3"/>
    </schedule-assignment>

    <macsec policy="must-secure" cipher="gcm-aes-128" key-agreement="psk">
      <key-store type="secure-element" ref="se051"/>
    </macsec>

    <eee-policy>disabled</eee-policy>
  </network>

  <!-- Network 5: Power distribution bus -->
  <network name="power">
    <description>24V power distribution from BMS to all powered components</description>

    <bus name="power_bus" type="power">
      <description>24V DC power distribution bus from MR-BMS771</description>
      <voltage>24</voltage>
      <participant device="bms" port="bat_out" role="source" position="0"/>
      <participant device="agx-thor" port="pwr_in" role="sink" position="1"/>
      <participant device="s32n79" port="pwr_in" role="sink" position="2"/>
      <participant device="s32j100" port="pwr_in" role="sink" position="3"/>
      <participant device="head" port="pwr_in" role="sink" position="4"/>
      <participant device="lidar-front" port="pwr_in" role="sink" position="5"/>
      <participant device="lidar-rear" port="pwr_in" role="sink" position="6"/>
      <participant device="radar-4d" port="pwr_in" role="sink" position="7"/>
      <participant device="zlac8015d" port="pwr_in" role="sink" position="8"/>
      <participant device="wheel-left" port="pwr_in" role="sink" position="19"/>
      <participant device="wheel-right" port="pwr_in" role="sink" position="20"/>
      <participant device="mcn1-l" port="pwr_in" role="sink" position="9"/>
      <participant device="mcn2-l" port="pwr_in" role="sink" position="10"/>
      <participant device="mcn3-l" port="pwr_in" role="sink" position="11"/>
      <participant device="mcn4-l" port="pwr_in" role="sink" position="12"/>
      <participant device="cam-l" port="pwr_in" role="sink" position="13"/>
      <participant device="mcn1-r" port="pwr_in" role="sink" position="14"/>
      <participant device="mcn2-r" port="pwr_in" role="sink" position="15"/>
      <participant device="mcn3-r" port="pwr_in" role="sink" position="16"/>
      <participant device="mcn4-r" port="pwr_in" role="sink" position="17"/>
      <participant device="cam-r" port="pwr_in" role="sink" position="18"/>
    </bus>
  </network>

  <!-- ================================================================ -->
  <!-- TRANSMISSIONS                                                    -->
  <!-- ================================================================ -->

  <transmission name="l_shoulder_yaw_tx" type="planetary">
    <motor ref="shoulder_yaw_motor"/>
    <joint ref="l_shoulder_yaw"/>
    <reduction>50</reduction>
    <efficiency>0.85</efficiency>
  </transmission>

  <transmission name="l_shoulder_pitch_tx" type="planetary">
    <motor ref="shoulder_pitch_motor"/>
    <joint ref="l_shoulder_yaw"/>
    <reduction>80</reduction>
    <efficiency>0.82</efficiency>
  </transmission>

  <transmission name="l_elbow_tx" type="planetary">
    <motor ref="elbow_l_motor"/>
    <joint ref="l_elbow"/>
    <reduction>50</reduction>
    <efficiency>0.85</efficiency>
  </transmission>

  <transmission name="l_wrist_pitch_tx" type="planetary">
    <motor ref="wrist_pitch_l_motor"/>
    <joint ref="l_wrist_pitch"/>
    <reduction>30</reduction>
    <efficiency>0.88</efficiency>
  </transmission>

  <transmission name="r_shoulder_yaw_tx" type="planetary">
    <motor ref="shoulder_yaw_r_motor"/>
    <joint ref="r_shoulder_yaw"/>
    <reduction>50</reduction>
    <efficiency>0.85</efficiency>
  </transmission>

  <transmission name="r_shoulder_pitch_tx" type="planetary">
    <motor ref="shoulder_pitch_r_motor"/>
    <joint ref="r_shoulder_yaw"/>
    <reduction>80</reduction>
    <efficiency>0.82</efficiency>
  </transmission>

  <transmission name="r_elbow_tx" type="planetary">
    <motor ref="elbow_r_motor"/>
    <joint ref="r_elbow"/>
    <reduction>50</reduction>
    <efficiency>0.85</efficiency>
  </transmission>

  <transmission name="r_wrist_pitch_tx" type="planetary">
    <motor ref="wrist_pitch_r_motor"/>
    <joint ref="r_wrist_pitch"/>
    <reduction>30</reduction>
    <efficiency>0.88</efficiency>
  </transmission>

  <transmission name="wheel_left_tx" type="simple">
    <motor ref="left_wheel_motor"/>
    <joint ref="chassis_to_wheel_left"/>
    <reduction>1</reduction>
    <efficiency>0.95</efficiency>
  </transmission>

  <transmission name="wheel_right_tx" type="simple">
    <motor ref="right_wheel_motor"/>
    <joint ref="chassis_to_wheel_right"/>
    <reduction>1</reduction>
    <efficiency>0.95</efficiency>
  </transmission>

  <!-- ================================================================ -->
  <!-- MATERIALS                                                        -->
  <!-- ================================================================ -->

  <material name="aluminum-anodized">
    <description>Anodized aluminum chassis and structural components</description>
    <color rgba="0.7 0.7 0.7 1.0"/>
    <surface>
      <friction static="0.5" dynamic="0.35"/>
      <restitution>0.1</restitution>
    </surface>
  </material>

  <material name="rubber-tire">
    <description>Rubber tire compound for driven wheels</description>
    <color rgba="0.15 0.15 0.15 1.0"/>
    <surface>
      <friction static="0.9" dynamic="0.7"/>
      <restitution>0.05</restitution>
    </surface>
  </material>

  <material name="abs-black">
    <description>ABS plastic enclosure material</description>
    <color rgba="0.1 0.1 0.1 1.0"/>
    <surface>
      <friction static="0.4" dynamic="0.3"/>
      <restitution>0.2</restitution>
    </surface>
  </material>

</hcdf>
